# lib-biss-select-search wraps the mat-select; mat-error with "Required" confirms the field is invalid
iParcelUseRequired=//mat-dialog-container//lib-biss-select-search[@formcontrolname='parcelUse']//mat-error[contains(normalize-space(),'Required')]

# Parcel Use mat-select trigger inside the Edit Parcel drawer
