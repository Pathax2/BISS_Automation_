# Parcel Use Dropdown
iParcelUseSelect     = //label[normalize-space()='Parcel use']/following::mat-select[1]
iParcelUseOption     = //mat-option//span[normalize-space()='%s']

@And("the agent changes parcel use to {string}")
public void theAgentChangesParcelUseTo(String pParcelUse)
{
    log.info("[STEP] And the agent changes parcel use to: " + pParcelUse);

    // Step 1 — Open the dropdown
    iAction("CLICK", "XPATH", ObjReader.getLocator("iParcelUseSelect"), null);

    // Step 2 — Build option XPath dynamically and select
    String iOptionXpath = String.format(ObjReader.getLocator("iParcelUseOption"), pParcelUse);
    iAction("LIST", "XPATH", iOptionXpath, pParcelUse);
}
