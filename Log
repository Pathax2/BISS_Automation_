    // Step          : Staff should see the Generate Map Setting section
    // Description    : Asserts the Generate Map Setting section is visible after a successful
    //                  parcel search (used by the case-sensitive search scenarios).
    // Parameters     : None
    // Author         : Aniket Pathare | aniket.pathare@government.ie
    // Date Created   : 14-07-2026
    // ***************************************************************************************************************************************************************************************
    @Then("Staff should see the Generate Map Setting section")
    public void staffShouldSeeTheGenerateMapSettingSection()
    {
        log.info("[STEP] Staff verifies Generate Map Setting section is visible");
        boolean iVisible = !getDriver().findElements(By.xpath(ObjReader.getLocator("iStaffGenerateMapSettingSection"))).isEmpty();
        Assertions.assertTrue(iVisible, "Generate Map Setting section not visible");
    }
