private String getPrelimHerd(String pCheckType)
{
    switch (pCheckType)
    {
        case "Overclaim":             return Hooks.OVERCLAIM_HERD;
        case "Dual claim":            return Hooks.DUAL_CLAIM_HERD;
        case "Agricultural Activity": return Hooks.AGRI_ACTIVITY_HERD;
        default: throw new IllegalArgumentException("Unknown: " + pCheckType);
    }
}

private String getPrelimUsername(String pCheckType)
{
    switch (pCheckType)
    {
        case "Overclaim":             return Hooks.OVERCLAIM_USERNAME;
        case "Dual claim":            return Hooks.DUAL_CLAIM_USERNAME;
        case "Agricultural Activity": return Hooks.AGRI_ACTIVITY_USERNAME;
        default: throw new IllegalArgumentException("Unknown: " + pCheckType);
    }
}

private void setPrelimHerd(String pCheckType, String pHerd, String pUsername)
{
    switch (pCheckType)
    {
        case "Overclaim":
            Hooks.OVERCLAIM_HERD     = pHerd; Hooks.OVERCLAIM_USERNAME    = pUsername; break;
        case "Dual claim":
            Hooks.DUAL_CLAIM_HERD    = pHerd; Hooks.DUAL_CLAIM_USERNAME   = pUsername; break;
        case "Agricultural Activity":
            Hooks.AGRI_ACTIVITY_HERD = pHerd; Hooks.AGRI_ACTIVITY_USERNAME = pUsername; break;
        default: throw new IllegalArgumentException("Unknown: " + pCheckType);
    }
    log.info("[PRELIM-SWAP] Hooks committed → " + pCheckType
            + " : herd=" + pHerd + " | username=" + pUsername);
}

