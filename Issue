/**
 * Description : Verifies element visibility with scroll-into-view and stale element retry.
 *               Use for Angular Material tables that re-render after DOM mutations (undo, delete, etc.)
 * Parameters  : pDriver - WebDriver instance
 *               pBy     - locator for the target element
 *               pObjectName - locator string for logging/error messages
 * Author      : Aniket Pathare
 * Date        : 10/04/2026
 */
private static void performVerifyElementStable(WebDriver pDriver, By pBy, String pObjectName) {

    boolean iVerified = false;

    for (int iAttempt = 0; iAttempt < 5; iAttempt++) {
        try {
            WebDriverWait iShortWait = new WebDriverWait(pDriver, Duration.ofSeconds(2));

            WebElement iElement = iShortWait.until(
                ExpectedConditions.presenceOfElementLocated(pBy)
            );

            ((JavascriptExecutor) pDriver).executeScript(
                "arguments[0].scrollIntoView({block:'center', inline:'center'});", iElement
            );

            // Re-fetch after scroll — Angular CDK table may re-render on scroll events
            iElement = new WebDriverWait(pDriver, Duration.ofSeconds(2))
                .until(ExpectedConditions.visibilityOfElementLocated(pBy));

            highlightElement(pDriver, iElement);

            if (iElement.isDisplayed()) {
                iVerified = true;
                break;
            }

        } catch (StaleElementReferenceException | TimeoutException e) {
            log.warn("VERIFYELEMENT_STABLE attempt " + (iAttempt + 1) + " – stale/timeout for: " + pObjectName + ", retrying...");
            try { Thread.sleep(1000); } catch (InterruptedException ie) { Thread.currentThread().interrupt(); }
        }
    }

    if (!iVerified) {
        throw new AssertionError("VERIFYELEMENT_STABLE failed. Element not visible after retries: " + pObjectName);
    }
}
