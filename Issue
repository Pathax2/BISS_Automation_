    @Then("the staff user should be able to download the generated map")
    public void theStaffUserShouldBeAbleToDownloadTheGeneratedMap() {
        log.info("[STEP] the staff user should be able to download the generated map");

        String iParentWindow = getDriver().getWindowHandle();
        int    iHandlesBefore = getDriver().getWindowHandles().size();

        iAction("VERIFYELEMENT", "XPATH", ObjReader.getLocator("iReadyToDownloadLink"), null);
        iAction("CLICK",         "XPATH", ObjReader.getLocator("iReadyToDownloadLink"), null);

        // Wait for the PDF tab to actually appear rather than guessing with a fixed sleep.
        try {
            new WebDriverWait(getDriver(), Duration.ofSeconds(30))
                    .until(ExpectedConditions.numberOfWindowsToBe(iHandlesBefore + 1));
        } catch (TimeoutException e) {
            log.warning("[STEP] No new tab opened for the generated map within 30s.");
            getDriver().switchTo().window(iParentWindow);
            return;
        }

        for (String iHandle : getDriver().getWindowHandles()) {
            if (!iHandle.equals(iParentWindow)) {
                getDriver().switchTo().window(iHandle);
                log.info("[STEP] Closing map PDF tab: " + getDriver().getCurrentUrl());
                getDriver().close();
            }
        }

        getDriver().switchTo().window(iParentWindow);
    }


import org.openqa.selenium.TimeoutException;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;
import java.time.Duration;
