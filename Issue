    @When("the agent provides responses for all parcels on the Prelim Checks screen")
    public void theAgentProvidesResponsesForAllParcels()
    {
        log.info("[STEP] Provide responses for ALL parcels");
        List<WebElement> iControls = getDriver().findElements(
                By.xpath(ObjReader.getLocator("iPrelimChecksResponseControls")));

        for (int i = 0; i < iControls.size(); i++)
        {
            try
            {
                WebElement iCtrl = iControls.get(i);
                if (!iCtrl.isDisplayed()) continue;
                iCtrl.click();
                iAction("WAITVISIBLE", "XPATH", ObjReader.getLocator("iMatSelectOpenPanel"), null);
                iAction("CLICK", "XPATH", "(//mat-option)[1]", null);
            }
            catch (Exception e) { log.warning("Response " + (i+1) + ": " + e.getMessage()); }
        }
    }

    @When("the agent provides responses for remaining parcels on the Prelim Checks screen")
    public void theAgentProvidesResponsesForRemainingParcels()
    {
        log.info("[STEP] Provide responses for REMAINING unanswered parcels");
        List<WebElement> iControls = getDriver().findElements(
                By.xpath(ObjReader.getLocator("iPrelimChecksResponseControls")));

        for (WebElement iCtrl : iControls)
        {
            try
            {
                if (!iCtrl.isDisplayed()) continue;
                // Skip already-answered controls
                String iVal = iCtrl.getAttribute("aria-expanded");
                String iClass = iCtrl.getAttribute("class");
                if (iClass != null && iClass.contains("mat-select-filled")) continue;

                iCtrl.click();
                iAction("WAITVISIBLE", "XPATH", ObjReader.getLocator("iMatSelectOpenPanel"), null);
                iAction("CLICK", "XPATH", "(//mat-option)[1]", null);
            }
            catch (Exception e) { /* already answered or not applicable */ }
        }
    }

    @When("the agent clears one parcel response to make submission incomplete")
    public void theAgentClearsOneParcelResponse()
    {
        log.info("[STEP] Clear one parcel response");
        try
        {
            iAction("CLICK", "XPATH",
