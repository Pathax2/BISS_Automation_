    // ***************************************************************************************************************************************************************************************
    // Step          : the info icon for category {string} should display the correct description
    // Description   : Clicks the info icon (mat-icon with class "icon") next to the category checkbox.
    //                 The icon TOGGLES the div.info-categories panel below — it is NOT a tooltip.
    //                 After clicking, verifies the description panel is visible and not empty.
    //
    //                 FIX 1 (DOM audit 19-05-2026):
    //                   OLD: (//button[contains(@class,'info') or contains(@aria-label,'info')])[N]
    //                        → WRONG — no button wrapper exists in the DOM; query never matched.
    //                   NEW: (//app-nr-cisyf-category-select-popup//mat-icon[contains(@class,'icon')])[N]
    //                        → Matches the mat-icon with class "icon" (not "mat-icon-no-color")
    //                        → Indexed 1=CatA, 2=CatB, 3=CatC
    //                   Description verified via:
    //                        (//app-nr-cisyf-category-select-popup//div[contains(@class,'info-categories')])[N]
    //
    // Parameters    : pCategory — "A", "B", or "C"
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026 | Updated : 19-05-2026
    // ***************************************************************************************************************************************************************************************
    @Then("the info icon for category {string} should display the correct description")
    public void theInfoIconForCategoryShouldDisplayTheCorrectDescription(String pCategory)
    {
        log.info("[STEP] Then the info icon for category '" + pCategory + "' should display the correct description");

        // Map category letter to 1-based index within the dialog
        String iIndex;
        switch (pCategory.trim().toUpperCase())
        {
            case "A": iIndex = "1"; break;
            case "B": iIndex = "2"; break;
            case "C": iIndex = "3"; break;
            default:  throw new RuntimeException("[TC13] Unknown category: '" + pCategory
                              + "'. Expected: A | B | C");
        }

        // ── Click the info icon — mat-icon with class "icon", toggles description panel ──────
        // Replace {index} placeholder with the 1-based index for this category
        String iIconXpath = ObjReader.getLocator("iNRCISYFInfoIcon")
                .replace("{index}", iIndex);
        iAction("WAITVISIBLE",   "XPATH", iIconXpath, null);
        iAction("WAITCLICKABLE", "XPATH", iIconXpath, null);
        iAction("CLICK",         "XPATH", iIconXpath, null);
        log.info("[TC13] Clicked info icon for category " + pCategory + " (index=" + iIndex + ")");

        // ── Wait for the description panel to appear after click ──────────────────────────────
        String iDescXpath = ObjReader.getLocator("iNRCISYFInfoContent")
                .replace("{index}", iIndex);
        iAction("WAITVISIBLE", "XPATH", iDescXpath, null);

        // ── Read and verify description text is not empty ─────────────────────────────────────
        String iInfoText = iAction("GETTEXT", "XPATH", iDescXpath, null);
        Assertions.assertFalse(
                iInfoText == null || iInfoText.trim().isEmpty(),
                "[TC13] Info description for category " + pCategory
                        + " should be visible and non-empty after clicking the info icon.");

        log.info("[TC13] Category " + pCategory + " info description verified ("
                + iInfoText.trim().substring(0, Math.min(60, iInfoText.trim().length())) + "...)");
    }


