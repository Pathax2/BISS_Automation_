SELECT table_name 
FROM all_tables
WHERE table_name LIKE '%NRCISYF%'
OR    table_name LIKE '%NR_CISYF%'
OR    table_name LIKE '%NATIONAL_RESERVE%'
OR    table_name LIKE '%YOUNG_FARMER%'
ORDER BY table_name;

SELECT column_name, data_type
FROM all_tab_columns
WHERE table_name = 'VWBS_APPLICATION_HERD'
ORDER BY column_id;


SELECT view_name
FROM all_views
WHERE view_name LIKE '%NRCISYF%'
OR    view_name LIKE '%NR_CISYF%'
OR    view_name LIKE '%YOUNG_FARMER%'
ORDER BY view_name;
