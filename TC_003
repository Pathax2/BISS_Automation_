    // ===============================================================================================================================
    // SECTION 14 : ExecutionControl.xlsx — Description Cache
    // ===============================================================================================================================

    // ***************************************************************************************************************************************************************************************
    // Function Name : loadDescriptionCache
    // Description   : Reads ExecutionControl.xlsx once into memory. Thread-safe via double-checked locking.
    // ***************************************************************************************************************************************************************************************
    public static void loadDescriptionCache()
    {
        if (iDescriptionCacheLoaded) { return; }

        synchronized (iDescriptionCache)
        {
            if (iDescriptionCacheLoaded) { return; }

            try (FileInputStream iFis     = new FileInputStream(iExecutionControlFilePath);
                 Workbook         iWorkbook = WorkbookFactory.create(iFis))
            {
                Sheet iSheet = iWorkbook.getSheetAt(0);
                if (iSheet == null)
                {
                    throw new RuntimeException("Sheet at index 0 not found in : " + iExecutionControlFilePath);
                }

                Row iHeaderRow = iSheet.getRow(0);
                if (iHeaderRow == null)
                {
                    throw new RuntimeException("Header row missing in ExecutionControl.xlsx.");
                }

                int iTestCaseIDCol  = -1;
                int iDescriptionCol = -1;

                for (int i = 0; i < iHeaderRow.getLastCellNum(); i++)
                {
                    String iColName = getCellValue(iHeaderRow, i).trim();
                    if (iColName.equalsIgnoreCase("TestCase_ID"))  { iTestCaseIDCol  = i; }
                    if (iColName.equalsIgnoreCase("Description"))  { iDescriptionCol = i; }
                }

                if (iTestCaseIDCol == -1 || iDescriptionCol == -1)
                {
                    throw new RuntimeException("TestCase_ID and/or Description columns not found in ExecutionControl.xlsx.");
                }

                for (int iRowIdx = 1; iRowIdx <= iSheet.getLastRowNum(); iRowIdx++)
                {
                    Row iRow = iSheet.getRow(iRowIdx);
                    if (iRow == null) { continue; }

                    String iId   = getCellValue(iRow, iTestCaseIDCol).trim();
                    String iDesc = getCellValue(iRow, iDescriptionCol).trim();

                    if (!iId.isEmpty())
                    {
                        iDescriptionCache.put(iId.toUpperCase(), iDesc);
                    }
                }

                iDescriptionCacheLoaded = true;
                log.info("[" + getCurrentTimestamp() + "] Description cache loaded. Entries: " + iDescriptionCache.size());
            }
            catch (Exception iException)
            {
                throw new RuntimeException("Failed to load ExecutionControl.xlsx : " + iException.getMessage(), iException);
            }
        }
    }

    // ***************************************************************************************************************************************************************************************
    // Function Name : getDescriptionFromExecutionControl
    // ***************************************************************************************************************************************************************************************
    private static String getDescriptionFromExecutionControl(String pTestCaseID)
    {
        if (!iDescriptionCacheLoaded) { loadDescriptionCache(); }

        String iDescription = iDescriptionCache.get(pTestCaseID.trim().toUpperCase());
        if (iDescription == null)
        {
            throw new RuntimeException("No description found for TestCase_ID : '" + pTestCaseID + "'.");
        }
        return iDescription;
    }

    // ***************************************************************************************************************************************************************************************
    // Function Name : getCellValue
    // ***************************************************************************************************************************************************************************************
    private static String getCellValue(Row pRow, int pColumnIndex)
    {
        if (pRow == null)                         { return ""; }
        if (pRow.getCell(pColumnIndex) == null)   { return ""; }
        return iDataFormatter.formatCellValue(pRow.getCell(pColumnIndex));
    }
