SELECT a.app_herd_no, a.aph_cust_id
FROM vwbs_application_herd a
WHERE a.app_herd_no LIKE 'J%'
AND a.app_year = 2026
AND a.mde_abbrev = 'I'
AND a.applicant_type = 'I'
AND nvl(pkbs_payment_utils.fn_GetSchemeApplied(a.aph_app_id, 3), 'N') = 'Y'
AND NOT EXISTS (
    SELECT 1 FROM vwen_biss_cisyf v
    WHERE v.app_from_herd = a.app_herd_no
    AND v.app_scheme_year = 2026
)
AND ROWNUM <= 20
ORDER BY a.app_herd_no DESC;
