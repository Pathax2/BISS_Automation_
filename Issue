    // ---------------------------------------------------------------------------------------------------------------------------------
    // Function Name : theStaffUserRequestsAMapWithTheFollowingSettings
    // Description   : Composes and submits a map generation request from a settings table. This is the step that
    //                 replaces the legacy sequence of dropdown clicks, checkbox clicks and a Generate click.
    //
    //                 Supported keys (all optional - only supply what the scenario needs):
    //                   parcels  - "single" selects one parcel, "all" selects every parcel
    //                   mapType  - map layout, e.g. "Full Color Ortho A4", "Custom Layer A4"
    //                   imagery  - imagery layer, custom layouts only
    //                   raster   - raster layer, custom layouts only
    //                   vector   - "default" picks the first available vector layer
    //                   legend   - "yes" ticks the legend indicator
    //
    //                 Generation is only submitted when a mapType is supplied. That is deliberate: the validation
    //                 scenarios build a PARTIAL request (e.g. parcels only, then dismiss the map type selector)
    //                 to prove the field is mandatory, and must not click Generate.
    // Parameters    : pSettings (DataTable) - key/value settings map
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ---------------------------------------------------------------------------------------------------------------------------------
    @And("the staff user requests a map with the following settings")
    public void theStaffUserRequestsAMapWithTheFollowingSettings(DataTable pSettings)
    {
        Map<String, String> iSettings = pSettings.asMap(String.class, String.class);

        String iParcels = iSettings.get("parcels");
        String iMapType = iSettings.get("mapType");
        String iImagery = iSettings.get("imagery");
        String iRaster  = iSettings.get("raster");
        String iVector  = iSettings.get("vector");
        String iLegend  = iSettings.get("legend");

        if (iParcels != null)
        {
            if ("all".equalsIgnoreCase(iParcels))
            {
                iAction("CLICK", "XPATH", ObjReader.getLocator("iParcelSelect"), null);
                iAction("CLICK", "XPATH", ObjReader.getLocator("iParcelSelectAllOption"), null);
                iAction("CLICK", "XPATH", ObjReader.getLocator("iDropdownBackdrop"), null);
            }
            else
            {
                iAction("CLICK", "XPATH", ObjReader.getLocator("iParcelSelect"), null);
