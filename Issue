    private int iParcelCursor         = 0;
    private int iReferenceCursor      = 0;

    // Holds the value most recently taken from a pool, so a step can re-use the SAME herd rather than advance
    // to the next one. Needed where legacy deliberately re-visits one herd across several scheme years.
    private String iCurrentHerd = null;

    // ---------------------------------------------------------------------------------------------------------------------------------
    // Function Name : iNextFromPool
    // Description   : Returns the next unused value from a runtime pool and advances the cursor. Fails loudly
    //                 rather than wrapping around - a scenario asking for more herds than the query returned is
    //                 a data problem that must surface, not be silently masked by re-using row 1.
    // Parameters    : pPool      (List<String>) - the resolved pool from Hooks
    //                 pCursor    (int)          - current position
    //                 pPoolName  (String)       - for the error message
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ---------------------------------------------------------------------------------------------------------------------------------
    private String iNextFromPool(List<String> pPool, int pCursor, String pPoolName)
    {
        if (pPool == null || pPool.isEmpty())
        {
            throw new IllegalStateException(
                    "Runtime pool '" + pPoolName + "' is empty. Check the @staffdata tag on the feature and the "
                            + "corresponding DBRouter query returned rows.");
        }

        if (pCursor >= pPool.size())
        {
            throw new IllegalStateException(
                    "Scenario requested more values from pool '" + pPoolName + "' than the query returned ("
                            + pPool.size() + "). Increase the count in the feature tag, e.g. @herds:10:submitted.");
        }

        return pPool.get(pCursor);
    }

