# Declaration checkbox 1 — Change to Herd Number Declaration
# Scoped to app-nr-cisyf-submission-declaration-popup host.
# DOM has NO 'declaration' class anywhere in the ancestor chain —
# the previous ancestor::*[contains(@class,'declaration')] matched nothing.
iNRCISYFDeclarationCheckbox1        = (//app-nr-cisyf-submission-declaration-popup//mat-checkbox//input[@type='checkbox'])[1]

# Declaration checkbox 2 — Terms and Conditions Declaration
iNRCISYFDeclarationCheckbox2        = (//app-nr-cisyf-submission-declaration-popup//mat-checkbox//input[@type='checkbox'])[2]

# Final submit confirm button inside the declaration dialog
# DOM: span text is "Submit Application" NOT "Submit" — previous locator never matched.
# Scoped to host + excludes clearBtn (the Close button).
iNRCISYFSubmitConfirmBtn            = //app-nr-cisyf-submission-declaration-popup//button[.//span[normalize-space()='Submit Application']][not(contains(@class,'clearBtn'))]

# Submit Application button — on the summary page (before dialog opens)
# OK — no change needed
iNRCISYFSubmitApplicationBtn        = //button[.//span[normalize-space()='Submit Application'] or normalize-space()='Submit Application']

# Submission success message — shown after successful submit
# UNVERIFIED — no success page DOM shared yet. Broad fallback retained.
iNRCISYFSubmitSuccessMsg            = //*[contains(@class,'success') or contains(@class,'confirmation') or contains(normalize-space(),'successfully submitted') or contains(normalize-space(),'application has been submitted')]


# Submission success message — green mat-card banner shown after successful submit
# DOM: mat-card with background-color:#82e0aa containing <b> with exact success text.
# Scoped to the banner section for precision — avoids false matches on other pages.
iNRCISYFSubmitSuccessMsg            = //section[contains(@class,'banner')]//mat-card[.//b[contains(normalize-space(),'successfully submitted your National Reserve')]]
