    // ***************************************************************************************************************************************************************************************
    // Function Name : performTextBox
    // Description   : Waits for element to be visible, clickable, and editable (not disabled/readonly)
    //                 before clearing and typing. Angular readiness checked before and after.
    // ***************************************************************************************************************************************************************************************
    private static void performTextBox(WebDriver pDriver, WebDriverWait pWait, By pBy, String pValue)
    {
        if (pValue == null)
        {
            throw new RuntimeException("TEXTBOX action requires a non-null value.");
        }

        waitForAngularReady(pDriver);

        WebElement iElement = pWait.until(ExpectedConditions.visibilityOfElementLocated(pBy));
        pWait.until(ExpectedConditions.elementToBeClickable(iElement));

        // Wait until the field is genuinely editable — not disabled, not readonly
        // Angular forms sometimes render fields as readonly while the model is still loading
        pWait.until(iWebDriver ->
        {
            String iReadOnly = iElement.getAttribute("readonly");
            return iElement.isEnabled() && (iReadOnly == null || iReadOnly.equalsIgnoreCase("false"));
        });

        scrollIntoView(pDriver, iElement);
        highlightElement(pDriver, iElement);
        iElement.clear();

        // Small pause after clear — Angular reactive forms can re-validate on clear
        // which may temporarily disable the field before re-enabling it
        try { Thread.sleep(100); } catch (InterruptedException ignored) { Thread.currentThread().interrupt(); }

        iElement.sendKeys(pValue);

        // After sendKeys, wait for Angular to process the input event
        waitForAngularReady(pDriver);
    }

