## 🗃️ Test Data — SQL Queries

### BISS_DATA — Herd with Red AMS Findings (Individual)

```sql
-- Find individual herds with AMS Red findings (Round 1, 2026)
SELECT DISTINCT lvl_herd_no
FROM vwbs_land_validation
WHERE lvl_year  = 2026
AND   lvt_desc  = 'Preliminary Check'
AND   lvs_desc  = 'Pending'
AND   lvc_desc  IN ('Overclaim', 'Dual claim', 'Agricultural Activity')
AND   substr(lvl_herd_no, 1, 1) > 'A'
AND   ROWNUM <= 10
ORDER BY lvl_herd_no;
```

### BISS_DATA — Herd with NO AMS Findings (for Scenario 2)

```sql
-- Find individual herds with NO AMS findings (Not Started, no errors)
SELECT ap_ri.app_herd_no
FROM vwbs_application ap_ri
WHERE ap_ri.app_mde_code = 1
AND ap_ri.app_year = 2026
AND ap_ri.app_herd_no LIKE 'A%'
AND EXISTS (
    SELECT 1 FROM tdbs_application_land x
    WHERE x.apl_year        = ap_ri.app_year
    AND   x.apl_app_id      = ap_ri.app_id
    AND   x.apl_deleted_ind = 'N'
)
AND NOT EXISTS (
    SELECT 1 FROM vwbs_application app
    WHERE app.app_year     = ap_ri.app_year
    AND   app.app_herd_no  = ap_ri.app_herd_no
    AND   app.app_mde_code IN (3, 4, 6, 8)
)
AND NOT EXISTS (
    SELECT 1 FROM vwbs_land_validation lv
    WHERE lv.lvl_year     = ap_ri.app_year
    AND   lv.lvl_herd_no  = ap_ri.app_herd_no
    AND   lv.lvt_desc     = 'Preliminary Check'
    AND   lv.lvs_desc     = 'Pending'
)
AND ROWNUM <= 10
ORDER BY ap_ri.app_herd_no;
```

### BISS_DATA — Partnership Herd — Primary Partner (PP) with AMS Findings (for Scenario 3)

```sql
-- Find partnership herds with AMS findings where primary partner exists
SELECT DISTINCT lvl_herd_no
FROM vwbs_land_validation lv
WHERE lv.lvl_year  = 2026
AND   lv.lvt_desc  = 'Preliminary Check'
AND   lv.lvs_desc  = 'Pending'
AND   lv.lvc_desc  IN ('Overclaim', 'Dual claim', 'Agricultural Activity')
AND   EXISTS (
    SELECT 1 FROM vwbs_application a
    WHERE a.app_herd_no        = lv.lvl_herd_no
    AND   a.app_year           = lv.lvl_year
    AND   a.app_mde_code       = 1
    AND   a.app_applicant_type = 'P'   -- Partnership
)
AND ROWNUM <= 5
ORDER BY lvl_herd_no;
```

### BISS_INET — Get Agent Login for Herd (Single Agent Only)

```sql
-- Run on BISS_INET — replace herd number with result from above queries
SELECT hbcus.bcus_bus_id   AS HERDNO,
       MIN(ui.uri_username) AS USERNAME
  FROM tdco_customer_asscs ca,
       tdco_business_customers abcus,
       tdco_business_customers hbcus,
       tdcr_user_info ui
 WHERE SYSDATE BETWEEN ca.ca_start_date AND ca.ca_end_date
   AND ca.ca_cac_code     = 194
   AND ca.ca_bcus_id_from = abcus.bcus_id
   AND ca.ca_bcus_id_to   = hbcus.bcus_id
   AND ui.uri_ccs_bus_id  = abcus.bcus_bus_id
   AND hbcus.bcus_bus_id  = '<HERD_NUMBER_HERE>'
 GROUP BY hbcus.bcus_bus_id
HAVING COUNT(DISTINCT ui.uri_username) = 1;
```

### BISS_DATA — AMS Round 1 Herds (for reference)

```sql
-- Find herds notified in AMS Round 1 with response still required
SELECT lvl_herd_no, lvc_desc, COUNT(*) AS findings_count
FROM vwbs_land_validation
WHERE lvl_year = 2026
AND   lvt_desc = 'Preliminary Check'
AND   lvs_desc = 'Pending'
AND   lvc_desc IN ('Overclaim', 'Dual claim', 'Agricultural Activity')
GROUP BY lvl_herd_no, lvc_desc
ORDER BY lvl_herd_no;
```

