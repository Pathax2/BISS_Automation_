# AP4 — Planting of Native Trees and/or Hedgerows
iEcoAP4_FirstOptionRadio   = (//biss-eco-ap4-content//td[contains(@class,'cdk-column-selectOption')]//input[@type='radio'])[1]
iEcoAP4_CommitCheckbox     = //biss-eco-ap4-content//input[@type='checkbox'][ancestor::mat-checkbox]


case "AP4":
    // ── Step 1: Select the first radio option in the options table ────────────────
    // Options are: Standard Trees, Standard Hedgerows, Enhanced Trees,
    //              Enhanced Hedgerows, Enhanced Trees & Hedgerows.
    // Always select the first one — scoped to biss-eco-ap4-content so we
    // never accidentally click a radio from another AP panel.
    iAction("WAITVISIBLE",   "XPATH", ObjReader.getLocator("iEcoAP4_FirstOptionRadio"), null);
    iAction("WAITCLICKABLE", "XPATH", ObjReader.getLocator("iEcoAP4_FirstOptionRadio"), null);
    iAction("RADIOBUTTON",   "XPATH", ObjReader.getLocator("iEcoAP4_FirstOptionRadio"), null);
    log.info("AP4: Selected first radio option (Standard Trees).");

    // ── Step 2: Tick the "I commit to planting X Trees/Hedgerows" checkbox ────────
    // Checkbox is mandatory — blocks Save & Select if unticked.
    // Scoped to biss-eco-ap4-content to avoid touching AP6 checkboxes.
    // Using CHECKBOX action with CHECK value — idempotent, won't double-tick.
    iAction("WAITVISIBLE",   "XPATH", ObjReader.getLocator("iEcoAP4_CommitCheckbox"), null);
    iAction("WAITCLICKABLE", "XPATH", ObjReader.getLocator("iEcoAP4_CommitCheckbox"), null);
    iAction("CHECKBOX",      "XPATH", ObjReader.getLocator("iEcoAP4_CommitCheckbox"), "CHECK");
    log.info("AP4: Ticked 'I commit to planting' checkbox.");

    // Note: Upload receipts is skipped — not required in test environment.
    // Note: Save & Select is handled by the caller after this method returns.
    break;
