    // ---------------------------------------------------------------------------------------------------------------------------------
    // Function Name : theStaffUserAppliesAndRemovesForceMajeureAcrossTheFollowingYears
    // Description   : Applies Force Majeure with a note, then removes it with another, for each year in the table.
    //                 Each transition requires its own note because it changes how deadlines and penalties are
    //                 applied to the application.
    // Parameters    : pRows (DataTable) - columns: year, applyNote, removeNote
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ---------------------------------------------------------------------------------------------------------------------------------
    @When("the staff user applies and removes Force Majeure for the same submitted herd across the following years")
    public void theStaffUserAppliesAndRemovesForceMajeureAcrossTheFollowingYears(DataTable pRows)
    {
        if (iCurrentHerd == null)
        {
            iCurrentHerd = iNextFromPool(Hooks.STAFF_SUBMITTED_HERDS, iSubmittedHerdCursor, "submitted herds");
            iSubmittedHerdCursor++;
        }

        List<Map<String, String>> iYearRows = pRows.asMaps(String.class, String.class);

        for (Map<String, String> iRow : iYearRows)
        {
            iSearchHomeByHerd(iCurrentHerd, iRow.get("year"));
            iOpenFirstApplication();

            iAction("CHECKBOX", "XPATH", ObjReader.getLocator("iForceMajeureInput"), null);
            iAction("TEXTBOX",  "XPATH", ObjReader.getLocator("iAddNoteText"), iRow.get("applyNote"));
            iAction("CLICK",    "XPATH", ObjReader.getLocator("iDialogButton").replace("{LABEL}", "Save"), null);

            iAction("CHECKBOX", "XPATH", ObjReader.getLocator("iForceMajeureInput"), null);
            iAction("TEXTBOX",  "XPATH", ObjReader.getLocator("iAddNoteText"), iRow.get("removeNote"));
            iAction("CLICK",    "XPATH", ObjReader.getLocator("iDialogButton").replace("{LABEL}", "Save"), null);
        }
    }

