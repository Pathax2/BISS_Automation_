SELECT ui.uri_username,
       bc.bcus_bus_id,
       bc.bcus_bus_end_date,
       CASE WHEN bc.bcus_bus_end_date > SYSDATE 
            THEN 'ACTIVE' ELSE 'EXPIRED' END AS status
FROM tdcr_user_info ui
JOIN tdco_business_customers bc
    ON bc.bcus_bus_id = ui.uri_ccs_bus_id
WHERE ui.uri_username IN ('aga6059', 'aga6553', 'aga6505')
ORDER BY ui.uri_username;
