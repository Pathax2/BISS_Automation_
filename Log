    // ***************************************************************************************************************************************************************************************
    // Step          : the agent enters group member details (DataTable)
    // Description   : Fills member name, DOB, and eligible checkbox per row.
    //                 FIX 14: Dead code iFieldOffset removed.
    //                 FIX 17: DOB is a mat-datepicker — opens calendar and injects date via JS.
    //                 FIX 18: All locators use ObjReader {index} placeholders.
    //                 DataTable cols: memberIndex, name, dobDay, dobMonth, dobYear, eligible
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026 | Updated : 21-05-2026
    // ***************************************************************************************************************************************************************************************
    @And("the agent enters group member details")
    public void theAgentEntersGroupMemberDetails(DataTable pDataTable)
    {
        log.info("[STEP] And the agent enters group member details");
        List<Map<String, String>> iMembers = pDataTable.asMaps(String.class, String.class);

        for (Map<String, String> iMember : iMembers)
        {
            String iIdx      = iMember.get("memberIndex").trim();
            String iName     = iMember.get("name").trim();
            String iDobDay   = iMember.get("dobDay").trim();
            String iDobMonth = iMember.get("dobMonth").trim();
            String iDobYear  = iMember.get("dobYear").trim();
            String iEligible = iMember.get("eligible").trim();

            log.info("[TC13] Entering member " + iIdx + ": " + iName);

            // ── Name input ──────────────────────────────────────────────────────────────────
            String iNameXpath = ObjReader.getLocator("iNRCISYFMemberNameInput").replace("{index}", iIdx);
            iAction("WAITVISIBLE", "XPATH", iNameXpath, null);
            iAction("TEXTBOX",     "XPATH", iNameXpath, iName);

            // ── DOB — mat-datepicker: open calendar, inject date via JS into input ──────────
            // The DOB input is disabled in the DOM — it must be set via JavaScript on the
            // underlying input, then a change event dispatched for Angular to pick it up.
            String iDobInputXpath = "(" + ObjReader.getLocator("iNRCISYFMemberTable")
                    + "//tr)[" + iIdx + "]//input[contains(@class,'mat-datepicker-input')]";
            String iDobFormatted  = iDobDay + "/" + iDobMonth + "/" + iDobYear;

            try
            {
                WebElement iDobInput = getDriver().findElement(By.xpath(iDobInputXpath));
                JavascriptExecutor iJs = (JavascriptExecutor) getDriver();
                iJs.executeScript("arguments[0].removeAttribute('disabled');",        iDobInput);
                iJs.executeScript("arguments[0].value = arguments[1];",                iDobInput, iDobFormatted);
                iJs.executeScript("arguments[0].dispatchEvent(new Event('input',  {bubbles:true}));", iDobInput);
                iJs.executeScript("arguments[0].dispatchEvent(new Event('change', {bubbles:true}));", iDobInput);
                log.info("[TC13] Member " + iIdx + " DOB set: " + iDobFormatted);
            }
            catch (Exception e)
            {
                log.warning("[TC13] Could not set DOB for member " + iIdx + ": " + e.getMessage());
            }

            // ── Eligible farmer checkbox ─────────────────────────────────────────────────────
            if ("Yes".equalsIgnoreCase(iEligible))
            {
                String iCbXpath = ObjReader.getLocator("iNRCISYFMemberEligibleCheckbox").replace("{index}", iIdx);
                try
                {
                    WebElement iCb = getDriver().findElement(By.xpath(iCbXpath));
                    if (!iCb.isSelected())
                    {
                        iAction("CLICK", "XPATH", iCbXpath, null);
                        log.info("[TC13] Member " + iIdx + " eligible checkbox checked.");
                    }
                }
                catch (Exception e)
                {
                    iAction("CLICK", "XPATH", iCbXpath, null);
                }
            }

            log.info("[TC13] Member " + iIdx + " complete: " + iName + " DOB=" + iDobFormatted);
        }
    }


