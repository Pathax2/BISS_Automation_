        log.info("[STEP] Staff clicks pagination button: " + pLabel);
        String iLocator = ObjReader.getLocator("iStaffPaginationButton").replace("{LABEL}", pLabel);
        iAction("CLICK", "XPATH", iLocator, null);
    }

