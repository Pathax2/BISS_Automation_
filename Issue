// ***************************************************************************************************************************************************************************************
// Step          : When the agent opens a farmer dashboard for the {string} preliminary check herd
// Description   : Validates the preliminary check herd at UI level (Layer 3).
//                 Layers 1 and 2 are already done by Hooks @Before("@preliminary").
//
//                 Layer 3 checks in order:
//                   3A — Search herd on My Clients → must return at least 1 row
//                   3B — Row must NOT have "Herd expired" flag
//                   3C — Preliminary Checks tab must show at least 1 record
//
//                 On any failure → swapPrelimHerd() → re-login if agent changed → retry.
//
// Parameters    : pCheckType (String) — "Overclaim" | "Dual claim" | "Agricultural Activity"
// Author        : Aniket Pathare | aniket.pathare@government.ie
// Date          : 20-04-2026
// ***************************************************************************************************************************************************************************************
@When("the agent opens a farmer dashboard for the {string} preliminary check herd")
public void theAgentOpensAFarmerDashboardForPreliminaryCheckHerd(String pCheckType)
{
    log.info("[PRELIM-STEP] Opening farmer dashboard | checkType='" + pCheckType + "'");

    final int    MAX_UI_RETRIES = 5;
    final String YEAR           = System.getProperty("herd.year", "2026").trim();
    final By     iClientRowsBy  = By.xpath(ObjReader.getLocator("clientTableRows"));

    boolean iFound = false;

    for (int iAttempt = 0; iAttempt < MAX_UI_RETRIES; iAttempt++)
    {
        String iHerd     = getPrelimHerd(pCheckType);
        String iUsername = getPrelimUsername(pCheckType);

        log.info("[PRELIM-STEP] Attempt " + (iAttempt + 1) + "/" + MAX_UI_RETRIES
                + " | herd=" + iHerd + " | agent=" + iUsername);

        // ────────────────────────────────────────────────────────────────
        // LAYER 3A — Search for herd on My Clients
        // ────────────────────────────────────────────────────────────────
        iAction("CLEAR",   "XPATH", ObjReader.getLocator("herdSearchInput"), null);
        iAction("TEXTBOX", "XPATH", ObjReader.getLocator("herdSearchInput"), iHerd);
        iAction("CLICK",   "XPATH", ObjReader.getLocator("herdSearchBtn"),   null);
        pauseMs(1500);

        List<WebElement> iClientRows = getDriver().findElements(iClientRowsBy);

        // SCENARIO A — 0 rows
        if (iClientRows.isEmpty())
        {
            log.warning("[PRELIM-STEP] SCENARIO A | herd=" + iHerd
                    + " returned 0 rows in My Clients UI → swapping herd.");
            boolean iSwapped = swapPrelimHerd(pCheckType, iAttempt + 1, YEAR, iUsername);
            if (!iSwapped) break;
            continue;
        }

        // ────────────────────────────────────────────────────────────────
        // LAYER 3B — Find a non-expired row
        // ────────────────────────────────────────────────────────────────
        WebElement iUsableRow = null;

        for (WebElement iRow : iClientRows)
        {
            boolean iExpired = !iRow.findElements(By.xpath(EXPIRED_CELL_XPATH)).isEmpty();
            if (!iExpired)
            {
                iUsableRow = iRow;
                log.info("[PRELIM-STEP] Non-expired row found for herd " + iHerd);
                break;
            }
            log.info("[PRELIM-STEP] Row for herd " + iHerd + " is expired — skipping.");
        }

        // SCENARIO B — all rows expired
        if (iUsableRow == null)
        {
            log.warning("[PRELIM-STEP] SCENARIO B | all " + iClientRows.size()
                    + " row(s) for herd=" + iHerd + " are expired → swapping herd.");
            boolean iSwapped = swapPrelimHerd(pCheckType, iAttempt + 1, YEAR, iUsername);
            if (!iSwapped) break;
            continue;
        }

        // ────────────────────────────────────────────────────────────────
        // LAYER 3C — Click through and check Preliminary Checks tab
        // ────────────────────────────────────────────────────────────────
        iUsableRow.findElement(By.xpath(ROW_NAME_LINK_XPATH)).click();
        pauseMs(1500);

        iAction("CLICK", "XPATH", PRELIM_TAB_XPATH, null);
        pauseMs(2000);

        List<WebElement> iPrelimRows = getDriver()
                .findElements(By.xpath(PRELIM_TABLE_ROW_XPATH));

        boolean iHasRecords = !iPrelimRows.isEmpty();

        // Double-check: rows present but "no records" text also present
        // means the row IS the Angular empty-state element
        if (iHasRecords && !getDriver()
                .findElements(By.xpath(PRELIM_NO_RECORDS_XPATH)).isEmpty())
        {
            iHasRecords = false;
        }

        // SCENARIO C — Prelim tab empty
        if (!iHasRecords)
        {
            log.warning("[PRELIM-STEP] SCENARIO C | herd=" + iHerd
                    + " Preliminary Checks tab is empty → swapping herd.");
            navigateBackToMyClients();
            boolean iSwapped = swapPrelimHerd(pCheckType, iAttempt + 1, YEAR, iUsername);
            if (!iSwapped) break;
            continue;
        }

        // All 3 layers passed
        log.info("[PRELIM-STEP] ✓ herd=" + iHerd + " | "
                + iPrelimRows.size() + " prelim record(s) | all checks passed.");
        iFound = true;
        break;
    }

    if (!iFound)
    {
        throw new RuntimeException(
            "[PRELIM-STEP] Could not find usable herd for '" + pCheckType
            + "' after " + MAX_UI_RETRIES + " attempts."
            + " Last herd=" + getPrelimHerd(pCheckType)
            + " | Last agent=" + getPrelimUsername(pCheckType));
    }
}

// ===================================================================================================================================
//  PRIVATE — HERD SWAP (DB re-query + INET validation + re-login if agent changed)
// ===================================================================================================================================

// ***************************************************************************************************************************************************************************************
// Function Name : swapPrelimHerd
// Description   : Fetches the next candidate herd from BISS_DATA for pCheckType
//                 at pStartOffset, validates against BISS_INET, and if valid:
//                   - Agent changed → performLogout() + performLogin() + navigateToMyClients()
//                   - Same agent    → just update Hooks fields, no re-login
//                 Tries up to 3 consecutive offsets per call before giving up.
// Returns       : true if replacement found and committed, false if exhausted
// ***************************************************************************************************************************************************************************************
private boolean swapPrelimHerd(String pCheckType, int pStartOffset,
                               String pYear, String pCurrentUsername)
{
    for (int iOff = pStartOffset; iOff < pStartOffset + 3; iOff++)
    {
        log.info("[PRELIM-SWAP] BISS_DATA query | checkType=" + pCheckType
                + " | offset=" + iOff);

        database.DBRouter.runDB("DATA", "Preliminary checks herds",
                pYear, String.valueOf(iOff));

        List<Map<String, Object>> iRows = database.DBRouter.getRows();

        if (iRows == null || iRows.isEmpty())
        {
            log.warning("[PRELIM-SWAP] 0 rows from DB at offset=" + iOff
                    + " — no more candidates.");
            return false;
        }

        for (Map<String, Object> iRow : iRows)
        {
            String iLvc  = Objects.toString(iRow.get("LVC_DESC"),    "").trim();
            String iHerd = Objects.toString(iRow.get("LVL_HERD_NO"), "").trim();

            if (!iLvc.equals(pCheckType) || iHerd.isEmpty()) continue;

            // BISS_INET validation
            database.DBRouter.runDB("INET", "Get Login Id for herd", iHerd);
            String iUsername = database.DBRouter.getValue("USERNAME");

            if (iUsername == null || iUsername.isBlank())
            {
                log.info("[PRELIM-SWAP] No INET agent for " + pCheckType
                        + " herd=" + iHerd + " (offset=" + iOff + ") — skipping.");
                continue;
            }

            iUsername = iUsername.trim();
            log.info("[PRELIM-SWAP] Valid replacement: " + pCheckType
                    + " → herd=" + iHerd + " | username=" + iUsername);

            // Re-login only if agent has changed
            if (!iUsername.equalsIgnoreCase(pCurrentUsername))
            {
                log.info("[PRELIM-SWAP] Agent change: "
                        + pCurrentUsername + " → " + iUsername
                        + " | Performing logout → login → navigate.");
                performLogout();
                performLogin(iUsername);
                navigateToMyClients();
                Hooks.RUNTIME_USERNAME = iUsername;
            }
            else
            {
                log.info("[PRELIM-SWAP] Same agent (" + iUsername
                        + ") — no re-login needed.");
            }

            setPrelimHerd(pCheckType, iHerd, iUsername);
            return true;
        }
    }

    return false;
}

