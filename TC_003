    // Check current date and compare to verify if document created
    public int[] CheckDateToVerifyIfDocumentUploaded() throws ParseException, InterruptedException {
        // Capture Currrent Date
        Date date = new Date();
        SimpleDateFormat formatter = new SimpleDateFormat("dd/MM/yyyy");
        String currentdate = formatter.format(date);
        System.out.println("Current date: "+currentdate);
        // Check no of Docs prior to Upload
        By DocumentDate = By.xpath("//td[contains(@class,'cdk-column-dateIssued') and contains(text(),'"+currentdate+"')]");
        int PreDocUploadCount = driver.findElements(DocumentDate).size();
        System.out.println(PreDocUploadCount);
        // Upload Doc
        AgentClickOnUploadDocAccordion();
        AgentSelectDocumentTypeInDropdown("doc-type","Commonage Evidence");
        UploadDocument();
        AgentClickOnNextOrBackOrSubmitButton("Submit file");
        Thread.sleep(4000);
        // Check no of Docs post Upload
