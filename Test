SELECT YFS_ENTRY_COMPLETE_IND, 
       YFS_TAO_COMPLETE_IND,
       YFS_APPLICATION_YEAR, 
       COUNT(*)
FROM TDSP_YOUNG_FARMER_SUMMARY
WHERE YFS_APPLICATION_YEAR = 2026
GROUP BY YFS_ENTRY_COMPLETE_IND, 
         YFS_TAO_COMPLETE_IND,
         YFS_APPLICATION_YEAR
ORDER BY 1, 2;

SELECT t.SPH_SPS_HOLDING_ID, 
       v.APH_CUST_ID, 
       v.APP_CUST_ID,
       v.APP_HERD_NO, 
       v.APP_YEAR
FROM TDSP_YOUNG_FARMER_SUMMARY t
JOIN vwbs_application_herd v 
  ON v.APH_CUST_ID = t.SPH_SPS_HOLDING_ID
WHERE v.APP_YEAR = 2026
AND ROWNUM <= 5;
