    // ***************************************************************************************************************************************************************************************
    // Method        : fillQualificationForm
    // Description   : Shared qualification form filling logic for single and per-member flows.
    //                 FIX 7: All radio/dropdown interactions use ObjReader formcontrolname locators.
    //                 Handles: hasQualification, dateOfCompletion, certificateAwarded,
    //                          college (colId), customCollege, qualification (qualId), customQualification
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026 | Updated : 21-05-2026
    // ***************************************************************************************************************************************************************************************
    private void fillQualificationForm(Map<String, String> pData)
    {
        // ── Has qualification radio — formcontrolname="selectedValueQualification" ────────────
        String iHasQual = pData.getOrDefault("hasQualification", "Yes").trim();
        String iHasQualXpath = ObjReader.getLocator("iNRCISYFHasQualRadio").replace("{value}", iHasQual);
        iAction("WAITVISIBLE", "XPATH", iHasQualXpath, null);
        iAction("CLICK",       "XPATH", iHasQualXpath, null);

        if ("No".equalsIgnoreCase(iHasQual))
        {
            log.info("[TC13] hasQualification=No — skipping remaining fields.");
            return;
        }

        // ── Date of completion — mat-datepicker, formcontrolname="dateOfCompletion" ─────────
        // Datepicker input is disabled by default — inject value via JavaScript
        if (pData.containsKey("dateOfCompletion"))
        {
            String iDateValue = pData.get("dateOfCompletion").trim();
            try
            {
                WebElement iDateInput = getDriver().findElement(
                        By.xpath(ObjReader.getLocator("iNRCISYFDateOfCompletionInput")));
                JavascriptExecutor iJs = (JavascriptExecutor) getDriver();
                iJs.executeScript("arguments[0].removeAttribute('disabled');", iDateInput);
                iJs.executeScript("arguments[0].value = arguments[1];", iDateInput, iDateValue);
                iJs.executeScript("arguments[0].dispatchEvent(new Event('input',  {bubbles:true}));", iDateInput);
                iJs.executeScript("arguments[0].dispatchEvent(new Event('change', {bubbles:true}));", iDateInput);
                log.info("[TC13] Date of completion set: " + iDateValue);
            }
            catch (Exception e)
            {
                log.warning("[TC13] Could not set date of completion: " + e.getMessage());
            }
        }

        // ── Certificate awarded radio — formcontrolname="certificateHasBeenAwarded" ──────────
        if (pData.containsKey("certificateAwarded"))
        {
            String iCert = pData.get("certificateAwarded").trim();
            String iCertXpath = ObjReader.getLocator("iNRCISYFCertAwardedRadio").replace("{value}", iCert);
            iAction("WAITVISIBLE", "XPATH", iCertXpath, null);
            iAction("CLICK",       "XPATH", iCertXpath, null);
        }

        // ── College dropdown — formcontrolname="colId" ────────────────────────────────────────
        if (pData.containsKey("college"))
        {
            iAction("LIST", "XPATH", ObjReader.getLocator("iNRCISYFCollegeDropdown"),
                    pData.get("college").trim());
        }

        // ── Custom college free-text ───────────────────────────────────────────────────────────
        if (pData.containsKey("customCollege"))
        {
            iAction("TEXTBOX", "XPATH", ObjReader.getLocator("iNRCISYFCustomCollegeField"),
                    pData.get("customCollege").trim());
        }

        // ── Qualification dropdown — formcontrolname="qualId" ─────────────────────────────────
        if (pData.containsKey("qualification"))
        {
            iAction("LIST", "XPATH", ObjReader.getLocator("iNRCISYFQualificationDropdown"),
                    pData.get("qualification").trim());
        }

        // ── Custom qualification free-text ────────────────────────────────────────────────────
        if (pData.containsKey("customQualification"))
        {
            iAction("TEXTBOX", "XPATH", ObjReader.getLocator("iNRCISYFCustomQualificationField"),
                    pData.get("customQualification").trim());
        }

        log.info("[TC13] Qualification form filled: college=" + pData.getOrDefault("college", "N/A"));
    }


    // ***************************************************************************************************************************************************************************************
    // Method        : isVisible
    // Description   : Short-wait visibility check — returns true/false, never throws
    // Parameters    : pLocator — By locator
    //                 pSeconds — max wait seconds
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026
    // ***************************************************************************************************************************************************************************************
    private boolean isVisible(By pLocator, int pSeconds)
    {
        try
        {
            new WebDriverWait(getDriver(), Duration.ofSeconds(pSeconds))
                    .until(ExpectedConditions.visibilityOfElementLocated(pLocator));
            return true;
        }
        catch (Exception e) { return false; }
    }
