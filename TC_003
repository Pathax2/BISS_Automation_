    // ***************************************************************************************************************************************************************************************
    // Function Name : performWaitInvisible
    // Description   : Waits until a loading element is no longer blocking the UI.
    //
    //                 Standard invisibilityOfElementLocated is unreliable for SVG-based MDC spinners
    //                 because the inner SVG <circle> element is always rendered in the viewport.
    //                 MDC signals spinner completion via aria-hidden="true" on the parent container.
    //
    //                 Strategy (first match wins):
    //                   1. Custom polling loop — checks aria-hidden + isDisplayed on parent container
    //                   2. StaleElementReferenceException — element removed from DOM (spinner gone)
    //                   3. JS computed style fallback — opacity:0 or display:none check
    //
    //                 SVG locator auto-resolution:
    //                   If the caller passes the deep SVG circle locator, resolveSpinnerParentLocator()
    //                   redirects it to .mdc-circular-progress which carries aria-hidden.
    // ***************************************************************************************************************************************************************************************
    private static void performWaitInvisible(WebDriver pDriver, WebDriverWait pWait, By pBy, String pObjectName)
    {
        By iParentBy = resolveSpinnerParentLocator(pBy, pObjectName);

        log.info("[" + getCurrentTimestamp() + "] WAITINVISIBLE | Watching: " + pObjectName);

        try
        {
            pWait.until(iWebDriver ->
            {
                try
                {
                    List<WebElement> iElements = iWebDriver.findElements(iParentBy);

                    if (iElements.isEmpty())
                    {
                        log.info("[" + getCurrentTimestamp() + "] WAITINVISIBLE | Element not in DOM — spinner dismissed.");
                        return true;
                    }

                    WebElement iSpinner   = iElements.get(0);
                    String     iAriaHidden = iSpinner.getAttribute("aria-hidden");
                    boolean    iIsHidden  = "true".equalsIgnoreCase(iAriaHidden);
                    boolean    iIsGone    = !iSpinner.isDisplayed();

                    if (iIsHidden || iIsGone)
                    {
                        log.info("[" + getCurrentTimestamp() + "] WAITINVISIBLE | Resolved"
                                + " | aria-hidden=" + iAriaHidden
                                + " | isDisplayed=" + iSpinner.isDisplayed());
                        return true;
                    }

                    return false;
                }
                catch (StaleElementReferenceException iStale)
                {
                    log.info("[" + getCurrentTimestamp() + "] WAITINVISIBLE | Spinner element went stale (removed from DOM).");
                    return true;
                }
            });

            log.info("[" + getCurrentTimestamp() + "] WAITINVISIBLE | Spinner dismissed : " + pObjectName);
        }
        catch (TimeoutException iTimeout)
        {
            // Fallback — JS computed style check
            try
            {
                List<WebElement> iElements = pDriver.findElements(iParentBy);
                if (iElements.isEmpty())
                {
                    log.info("[" + getCurrentTimestamp() + "] WAITINVISIBLE | Spinner gone after timeout check.");
                    return;
                }

                WebElement iSpinner = iElements.get(0);
                String     iOpacity = (String) ((JavascriptExecutor) pDriver)
                        .executeScript("return window.getComputedStyle(arguments[0]).opacity;", iSpinner);
                String     iDisplay = (String) ((JavascriptExecutor) pDriver)
                        .executeScript("return window.getComputedStyle(arguments[0]).display;", iSpinner);

                if ("0".equals(iOpacity) || "none".equals(iDisplay))
                {
                    log.info("[" + getCurrentTimestamp() + "] WAITINVISIBLE | Resolved via JS style | opacity=" + iOpacity + " | display=" + iDisplay);
                    return;
                }

                throw new RuntimeException("WAITINVISIBLE timed out — spinner still visible | opacity=" + iOpacity
                        + " | display=" + iDisplay + " | Locator: " + pObjectName);
            }
            catch (RuntimeException iRe)
            {
                throw iRe;
            }
            catch (Exception iJsEx)
            {
                throw new RuntimeException("WAITINVISIBLE failed. Spinner did not dismiss. Locator: " + pObjectName, iJsEx);
            }
        }
    }

    // ***************************************************************************************************************************************************************************************
    // Function Name : resolveSpinnerParentLocator
    // Description   : When the caller passes the deep SVG circle locator, redirects to the
    //                 .mdc-circular-progress parent which carries aria-hidden.
    // ***************************************************************************************************************************************************************************************
    private static By resolveSpinnerParentLocator(By pBy, String pObjectName)
    {
        if (pObjectName != null && (
                pObjectName.contains("mdc-circular-progress__gap-patch") ||
                pObjectName.contains("name()='circle'")                  ||
                pObjectName.contains("name()='svg'")))
        {
            log.info("[" + getCurrentTimestamp() + "] WAITINVISIBLE | SVG spinner locator detected — resolving to .mdc-circular-progress parent.");
            return By.cssSelector(".mdc-circular-progress");
        }
        return pBy;
    }

