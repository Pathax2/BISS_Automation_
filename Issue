// ***************************************************************************************************************************************************************************************
// Step          : When the agent opens a farmer dashboard for preliminary check herd {string}
// Description   : Resolves the runtime herd from Hooks based on pCheckType, then performs
//                 three layers of UI validation:
//
//                   Layer 3A — My Clients search returns >= 1 row
//                   Layer 3B — The row is NOT marked "Herd expired"
//                   Layer 3C — Preliminary Checks tab shows >= 1 record
//
//                 On any failure → swapPrelimHerd() fetches next DB candidate,
//                 re-logins if agent changed, then the loop retries from 3A.
//
//                 pCheckType accepted values: OVERCLAIM | DUAL_CLAIM | AGRI_ACTIVITY
// Parameters    : pCheckType — string key identifying which check type herd to open
// Author        : Aniket Pathare | aniket.pathare@government.ie
// Date          : 20-04-2026
// ***************************************************************************************************************************************************************************************
@When("the agent opens a farmer dashboard for preliminary check herd {string}")
public void theAgentOpensAFarmerDashboardForPreliminaryCheckHerd(String pCheckType)
{
    log.info("[STEP] When the agent opens a farmer dashboard for preliminary check herd: " + pCheckType);

    final int    MAX_UI_RETRIES = 5;
    final String YEAR           = System.getProperty("herd.year", "2026").trim();
    final By     iClientRowsBy  = By.xpath(ObjReader.getLocator("clientTableRows"));

    boolean iFound = false;

    for (int iAttempt = 0; iAttempt < MAX_UI_RETRIES; iAttempt++)
    {
        String iHerd     = getPrelimHerd(pCheckType);
        String iUsername = getPrelimUsername(pCheckType);

        Assertions.assertNotNull(iHerd,
            "Herd for '" + pCheckType + "' is null — verify @preliminary hook ran successfully.");
        Assertions.assertNotNull(iUsername,
            "Username for '" + pCheckType + "' is null — verify BISS_INET returned a login for herd: " + iHerd);

        log.info("[PRELIM-STEP] Attempt " + (iAttempt + 1) + "/" + MAX_UI_RETRIES
                + " | checkType=" + pCheckType + " | herd=" + iHerd + " | agent=" + iUsername);

        // ════════════════════════════════════════════════════════════════
        // LAYER 3A — Search for herd on My Clients
        // ════════════════════════════════════════════════════════════════
        iAction("CLEAR",   "XPATH", ObjReader.getLocator("herdSearchInput"), null);
        iAction("TEXTBOX", "XPATH", ObjReader.getLocator("herdSearchInput"), iHerd);
        iAction("CLICK",   "XPATH", ObjReader.getLocator("herdSearchBtn"),   null);
        pauseMs(1500);

        List<WebElement> iClientRows = getDriver().findElements(iClientRowsBy);

        // SCENARIO A — 0 rows returned
        if (iClientRows.isEmpty())
        {
            log.warning("[PRELIM-STEP] SCENARIO A | herd=" + iHerd
                    + " returned 0 rows in My Clients → swapping herd.");
            boolean iSwapped = swapPrelimHerd(pCheckType, iAttempt + 1, YEAR, iUsername);
            if (!iSwapped) break;
            continue;
        }

        // ════════════════════════════════════════════════════════════════
        // LAYER 3B — Find a non-expired row
        // (same herd can appear multiple times — check each row individually)
        // ════════════════════════════════════════════════════════════════
        WebElement iUsableRow = null;

        for (WebElement iRow : iClientRows)
        {
            boolean iExpired = !iRow.findElements(By.xpath(EXPIRED_CELL_XPATH)).isEmpty();
            if (!iExpired)
            {
                iUsableRow = iRow;
                log.info("[PRELIM-STEP] Non-expired row found for herd " + iHerd + ".");
                break;
            }
            log.info("[PRELIM-STEP] Row for herd " + iHerd + " is 'Herd expired' — checking next row.");
        }

        // SCENARIO B — all rows are expired
        if (iUsableRow == null)
        {
            log.warning("[PRELIM-STEP] SCENARIO B | all " + iClientRows.size()
                    + " row(s) for herd=" + iHerd + " are expired → swapping herd.");
            boolean iSwapped = swapPrelimHerd(pCheckType, iAttempt + 1, YEAR, iUsername);
            if (!iSwapped) break;
            continue;
        }

        // ════════════════════════════════════════════════════════════════
        // LAYER 3C — Click through to dashboard + check Preliminary Checks tab
        // ════════════════════════════════════════════════════════════════
        iUsableRow.findElement(By.xpath(ROW_NAME_LINK_XPATH)).click();
        pauseMs(1500);

        iAction("CLICK", "XPATH", PRELIM_TAB_XPATH, null);
        pauseMs(2000);

        List<WebElement> iPrelimRows = getDriver()
                .findElements(By.xpath(PRELIM_TABLE_ROW_XPATH));

        boolean iHasRecords = !iPrelimRows.isEmpty();

        // Belt-and-braces: if rows exist but "no records" text is also visible,
        // the row IS the Angular empty-state element — not a real data record
        if (iHasRecords && !getDriver()
                .findElements(By.xpath(PRELIM_NO_RECORDS_XPATH)).isEmpty())
        {
            iHasRecords = false;
        }

        // SCENARIO C — Preliminary Checks tab is empty
        if (!iHasRecords)
        {
            log.warning("[PRELIM-STEP] SCENARIO C | herd=" + iHerd
                    + " Preliminary Checks tab has no records → swapping herd.");
            navigateBackToMyClients();
            boolean iSwapped = swapPrelimHerd(pCheckType, iAttempt + 1, YEAR, iUsername);
            if (!iSwapped) break;
            continue;
        }

        // All 3 layers passed
        log.info("[PRELIM-STEP] All checks passed | herd=" + iHerd
                + " | " + iPrelimRows.size() + " prelim record(s) found.");
        iFound = true;
        break;
    }

    if (!iFound)
    {
        throw new RuntimeException(
            "[PRELIM-STEP] Could not find a usable herd for check type '" + pCheckType
            + "' after " + MAX_UI_RETRIES + " attempts."
            + " Last herd=" + getPrelimHerd(pCheckType)
            + " | Last agent=" + getPrelimUsername(pCheckType)
            + ". Verify vwbs_land_validation has LVT_DESC='Preliminary Check'"
            + " AND LVS_DESC='Pending' AND LVC_DESC matching check type"
            + " with a non-expired herd and a valid BISS_INET agent.");
    }

    // Expand page size so all clients are visible for downstream steps
    iAction("CLICK",         "XPATH", ObjReader.getLocator("iListItemsPerPage"),    null);
    iAction("WAITVISIBLE",   "XPATH", ObjReader.getLocator("iMatSelectOpenPanel"),  null);
    iAction("WAITCLICKABLE", "XPATH", ObjReader.getLocator("iMatSelectOpenPanel"),  null);
    iAction("CLICK",         "XPATH", ObjReader.getLocator("iMatSelectLastOption"), null);

    log.info("[STEP] Resolved herd=" + getPrelimHerd(pCheckType)
            + " | username=" + getPrelimUsername(pCheckType)
            + " | checkType=" + pCheckType);
}


