105	
105 List the Specific ECO AP’s each herd has applied for in 2025

SELECT app.app_herd_no,
       COALESCE(eco.ap1,'N') ap1_ind,
       COALESCE(eco.ap2,'N') ap2_ind,
       COALESCE(eco.ap3,'N') ap3_ind,
       COALESCE(eco.ap4,'N') ap4_ind,
       COALESCE(eco.ap5,'N') ap5_ind,
       COALESCE(eco.ap6,'N') ap6_ind,
       COALESCE(eco.ap7,'N') ap7_ind,
       COALESCE(eco.ap8,'N') ap8_ind
FROM vwbs_application app,
     (SELECT axi_app_id,
            MAX((CASE WHEN axi_step LIKE 'AP1%' THEN 'Y' ELSE NULL END)) AP1,
            MAX((CASE WHEN axi_step LIKE 'AP2%' THEN 'Y' ELSE NULL END)) AP2,
            MAX((CASE WHEN axi_step LIKE 'AP3%' THEN 'Y' ELSE NULL END)) AP3,
            MAX((CASE WHEN axi_step LIKE 'AP4%' THEN 'Y' ELSE NULL END)) AP4,
            MAX((CASE WHEN axi_step LIKE 'AP5%' THEN 'Y' ELSE NULL END)) AP5,
            MAX((CASE WHEN axi_step LIKE 'AP6%' THEN 'Y' ELSE NULL END)) AP6,
            MAX((CASE WHEN axi_step LIKE 'AP7%' THEN 'Y' ELSE NULL END)) AP7,
            MAX((CASE WHEN axi_step LIKE 'AP8%' THEN 'Y' ELSE NULL END)) AP8
     FROM tdbs_application_ext_info axi,
     JSON_TABLE(axi.axi_draft_json, '$' columns (  points,
                                                   selected) ) jsn
     WHERE axi_step LIKE 'AP%'
     AND LOWER(jsn.selected) ='true'
     GROUP BY axi_app_id) eco
WHERE app.app_year=2025 and mde_abbrev='I'
AND app.app_id = eco.axi_app_id ;

