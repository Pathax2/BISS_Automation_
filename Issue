    private JPanel labeledRow(String label, JComponent field)
    {
        JPanel row = new JPanel(new BorderLayout(8, 0));
        row.setBackground(C_BG);
        row.setMaximumSize(new Dimension(Integer.MAX_VALUE, 34));
        JLabel l = new JLabel(label);
        l.setFont(FONT_SMALL);
        l.setForeground(C_MUTED);
        l.setPreferredSize(new Dimension(80, 0));
        row.add(l,     BorderLayout.WEST);
        row.add(field, BorderLayout.CENTER);
        return row;
    }

    private JButton styledButton(String text, Color bg, Color hover)
    {
        JButton b = new JButton(text);
        b.setFont(FONT_BUTTON);
        b.setBackground(bg);
        b.setForeground(Color.WHITE);
        b.setFocusPainted(false);
        b.setBorderPainted(false);
        b.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        b.setAlignmentX(Component.LEFT_ALIGNMENT);
        b.addMouseListener(new MouseAdapter()
        {
            public void mouseEntered(MouseEvent e) { if (b.isEnabled()) b.setBackground(hover); }
            public void mouseExited(MouseEvent e)  { b.setBackground(bg); }
        });
        return b;
    }

    private void setStatus(String msg, Color color)
    {
        SwingUtilities.invokeLater(() -> {
            iStatusLabel.setText(msg);
            iStatusLabel.setForeground(color);
        });
    }

    private void log(String msg)
    {
        SwingUtilities.invokeLater(() -> {
            iLogArea.append(msg + "\n");
            iLogArea.setCaretPosition(iLogArea.getDocument().getLength());
        });
    }

    private void showError(String msg)
    {
        JOptionPane.showMessageDialog(this, msg, "Error", JOptionPane.ERROR_MESSAGE);
    }

