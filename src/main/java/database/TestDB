package database;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.ResultSet;
import java.sql.Statement;

public class DBConnection
{
    private static final String DB_URL = "jdbc:oracle:thin:@//dbconn.agriculture.gov.ie:1532/CENTEST.agriculture.gov.ie";
    private static final String USERNAME = "BISS_DATA";
    private static final String PASSWORD = "BISS_DATA";

    public String getNotStartedHerdNumber()
    {
        String herdNumber = "";

        try
        {
            Connection connection = DriverManager.getConnection(DB_URL, USERNAME, PASSWORD);
            System.out.println("Database connection successful");

            String query =
                    "SELECT app_herd_no " +
                    "FROM tdbs_application " +
                    "WHERE app_status = 'NOT_STARTED' " +
                    "FETCH FIRST 1 ROWS ONLY";

            Statement statement = connection.createStatement();
            ResultSet rs = statement.executeQuery(query);

            while (rs.next())
            {
                herdNumber = rs.getString("app_herd_no");
                System.out.println("Herd Number Found: " + herdNumber);
            }

            connection.close();
        }
        catch (Exception e)
        {
            e.printStackTrace();
        }

        return herdNumber;
    }

    public static void main(String[] args)
    {
        DBConnection db = new DBConnection();
        db.getNotStartedHerdNumber();
    }
}
