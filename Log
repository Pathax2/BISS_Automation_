    // ***************************************************************************************************************************************************************************************
    // Step          : Staff searches on the Home screen with the following details (DataTable)
    // Description    : Same shape as the Map Printing search but for the Home/Application search
    //                  screen. Enters herd/parcel/reference value, selects scheme year, clicks
    //                  Search — all from one DataTable.
    // Parameters     : pDataTable (DataTable) - keys: field, herdValue|parcelValue|referenceValue, schemeYear
    // Author         : Aniket Pathare | aniket.pathare@government.ie
    // Date Created   : 14-07-2026
    // ***************************************************************************************************************************************************************************************
    @When("Staff searches on the Home screen with the following details")
    public void staffSearchesOnTheHomeScreenWithTheFollowingDetails(DataTable pDataTable)
    {
        Map<String, String> iData = pDataTable.asMap(String.class, String.class);
        String iField      = iData.get("field").trim();
        String iSchemeYear = iData.containsKey("schemeYear") ? iData.get("schemeYear").trim() : null;
        String iValue      = iData.containsKey("herdValue") ? iData.get("herdValue")
                           : iData.containsKey("parcelValue") ? iData.get("parcelValue")
                           : iData.get("referenceValue");
        iValue = (iValue == null) ? null : iValue.trim();

        log.info("[STEP] Staff Home search — field=" + iField + ", value=" + iValue + ", year=" + iSchemeYear);
        staffEntersValueInField(iValue, iField);
        if (iSchemeYear != null) staffSelectsSchemeYear(iSchemeYear);
        staffClicksButton("Search");
    }

    // ***************************************************************************************************************************************************************************************
    // Step          : Staff re-logs in as a different user with the Username "<username>"
    // Description    : Resets the session back to the staff login page and logs in as a different
    //                  account (used by role/permission scenarios such as non-internal users).
    //                  Navigating to the login URL lands on the username field; password comes
    //                  from the TestData "Password" column via the TD: mechanism.
    // Parameters     : pUsername (String) - the staff account to switch to
    // Author         : Aniket Pathare | aniket.pathare@government.ie
    // Date Created   : 14-07-2026
    // ***************************************************************************************************************************************************************************************
    @When("Staff re-logs in as a different user with the Username {string}")
    public void staffReLogsInAsADifferentUserWithTheUsername(String pUsername)
    {
        log.info("[STEP] Staff re-logs in as a different user: " + pUsername);
        getDriver().navigate().to(Hooks.iUrl);
        staffLogsInWithTheUsername(pUsername);
    }

    // ***************************************************************************************************************************************************************************************
    // Step          : Staff should not see the "<tab>" tab
    // Description    : Asserts a top-level tab is NOT visible — used for permission checks where a
    //                  restricted user must not have access (e.g. non-internal user has no Map
    //                  Printing tab).
    // Parameters     : pTab (String) - the tab label expected to be absent
    // Author         : Aniket Pathare | aniket.pathare@government.ie
    // Date Created   : 14-07-2026
    // ***************************************************************************************************************************************************************************************
    @Then("Staff should not see the {string} tab")
    public void staffShouldNotSeeTheTab(String pTab)
    {
        log.info("[STEP] Staff verifies tab is NOT present: " + pTab);
        String iLocator = ObjReader.getLocator("iStaffGenericTab").replace("{TAB}", pTab);
        boolean iAbsent = getDriver().findElements(By.xpath(iLocator)).isEmpty();
        Assertions.assertTrue(iAbsent, "Tab should not be visible for this user: " + pTab);
    }

    // ***************************************************************************************************************************************************************************************
    // Step          : Staff prints the "<attribute>" of the herd
    // Description    : Reads and logs a herd attribute (e.g. "name", "address") shown on the Map
    //                  Printing / search results — diagnostic print, no assertion (mirrors the
    //                  legacy "Staff print X of the herd" steps).
    // Parameters     : pAttribute (String) - logical attribute name
    // Author         : Aniket Pathare | aniket.pathare@government.ie
    // Date Created   : 14-07-2026
    // ***************************************************************************************************************************************************************************************
    @And("Staff prints the {string} of the herd")
    public void staffPrintsTheOfTheHerd(String pAttribute)
    {
        String iLocator = ObjReader.getLocator("iStaffHerdAttribute").replace("{ATTR}", pAttribute);
        String iValue = getDriver().findElement(By.xpath(iLocator)).getText();
        log.info("[STEP] Herd " + pAttribute + " = " + iValue);
    }

    // ***************************************************************************************************************************************************************************************
    // Step          : Staff verifies the "<attribute>" of the generated map
    // Description    : Asserts a generated-map metadata field is present/non-empty in the results
    //                  table (e.g. "status", "id", "herdNumber", "date").
    // Parameters     : pAttribute (String) - the generated-map column to verify
    // Author         : Aniket Pathare | aniket.pathare@government.ie
    // Date Created   : 14-07-2026
    // ***************************************************************************************************************************************************************************************
    @And("Staff verifies the {string} of the generated map")
    public void staffVerifiesTheOfTheGeneratedMap(String pAttribute)
    {
        log.info("[STEP] Staff verifies generated map attribute: " + pAttribute);
        String iLocator = ObjReader.getLocator("iStaffGeneratedMapAttribute").replace("{ATTR}", pAttribute);
        boolean iPresent = !getDriver().findElements(By.xpath(iLocator)).isEmpty();
        Assertions.assertTrue(iPresent, "Generated map attribute not present: " + pAttribute);
    }

    // ***************************************************************************************************************************************************************************************
    // Step          : Staff verifies the final status of the generated map
    // Description    : Waits for and asserts the generated map reaches its final/ready status in
    //                  the results table.
    // Parameters     : None
    // Author         : Aniket Pathare | aniket.pathare@government.ie
    // Date Created   : 14-07-2026
    // ***************************************************************************************************************************************************************************************
    @And("Staff verifies the final status of the generated map")
    public void staffVerifiesTheFinalStatusOfTheGeneratedMap()
    {
        log.info("[STEP] Staff verifies final status of the generated map");
        iAction("WAITVISIBLE", "XPATH", ObjReader.getLocator("iStaffGeneratedMapFinalStatus"), null);
        boolean iPresent = !getDriver().findElements(By.xpath(ObjReader.getLocator("iStaffGeneratedMapFinalStatus"))).isEmpty();
        Assertions.assertTrue(iPresent, "Generated map did not reach final status");
    }

    // ***************************************************************************************************************************************************************************************
    // Step          : Staff clicks the first Ready to Download link
    // Description    : Clicks the first "Ready to download" link in the generated maps table.
    // Parameters     : None
    // Author         : Aniket Pathare | aniket.pathare@government.ie
    // Date Created   : 14-07-2026
    // ***************************************************************************************************************************************************************************************
    @Then("Staff clicks the first Ready to Download link")
    public void staffClicksTheFirstReadyToDownloadLink()
    {
        log.info("[STEP] Staff clicks first Ready to Download link");
        iAction("CLICK", "XPATH", ObjReader.getLocator("iStaffReadyToDownloadFirst"), null);
    }

    // ***************************************************************************************************************************************************************************************
    // Step          : Staff clicks the "<label>" pagination button
    // Description    : Clicks a paginator control by its aria-label (e.g. "Next page",
    //                  "Previous page").
    // Parameters     : pLabel (String) - paginator button aria-label
    // Author         : Aniket Pathare | aniket.pathare@government.ie
    // Date Created   : 14-07-2026
    // ***************************************************************************************************************************************************************************************
    @Then("Staff clicks the {string} pagination button")
    public void staffClicksThePaginationButton(String pLabel)
