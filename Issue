    // =================================================================================================================================

    // ---------------------------------------------------------------------------------------------------------------------------------
    // Function Name : theStaffUserIsLoggedInToTheBissInternalPortal
    // Description   : Logs into the CENTEST internal portal and opens the BISS application. Combines what legacy
    //                 spread across four steps (open page, enter username, enter password, click login, open app).
    // Parameters    : pUsername (String) - staff account, a permission fixture from the feature file
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ---------------------------------------------------------------------------------------------------------------------------------
    @Given("the staff user is logged in to the BISS internal portal as {string}")
    public void theStaffUserIsLoggedInToTheBissInternalPortal(String pUsername)
    {
        log.info("[STEP] the staff user is logged in to the BISS internal portal as {string}");
        iPerformStaffLogin(pUsername);
        //Below flow is commented as login flow is rerouted
