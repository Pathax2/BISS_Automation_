    // ***************************************************************************************************************************************************************************************
    // Function Name : takeScreenshot
    // Description   : Captures screenshot and saves to framework screenshots folder
    // ***************************************************************************************************************************************************************************************
    public static String takeScreenshot(String pStepName)
    {
        try
        {
            WebDriver iDriver = iDriverHolder.get();
            if (iDriver == null)
            {
                throw new RuntimeException("Driver not initialised. Cannot capture screenshot.");
            }

            File iDir = new File(iReportScreenshotsDirectoryPath);
            if (!iDir.exists()) { iDir.mkdirs(); }

            String iSafeName  = sanitizeFileName(pStepName);
            String iTimestamp = LocalDateTime.now().format(iFileDateTimeFormatterWithMilliSeconds);
            String iFileName  = iSafeName + "_" + iTimestamp + ".png";
            String iFullPath  = iDir.getAbsolutePath() + File.separator + iFileName;

            File iSource = ((TakesScreenshot) iDriver).getScreenshotAs(OutputType.FILE);
            Files.copy(iSource.toPath(), new File(iFullPath).toPath(), StandardCopyOption.REPLACE_EXISTING);

            log.info("[" + getCurrentTimestamp() + "] Screenshot captured : " + iFullPath);
            return iFullPath;
        }
        catch (Exception iException)
        {
            throw new RuntimeException("Failed to capture screenshot : " + iException.getMessage(), iException);
        }
    }


    // ===============================================================================================================================
    // SECTION 12 : Word Report
    // ===============================================================================================================================

    // ***************************************************************************************************************************************************************************************
    // Function Name : startWordReport
    // Description   : Creates a Word (.docx) report for the executing test case. Returns Object[]{XWPFDocument, String}.
    // ***************************************************************************************************************************************************************************************
    public static Object[] startWordReport(String pTestCaseID)
    {
        try
        {
            if (pTestCaseID == null || pTestCaseID.trim().isEmpty())
            {
                throw new RuntimeException("TestCase_ID cannot be blank.");
            }

            String iDescription = getDescriptionFromExecutionControl(pTestCaseID);
            String iTimestamp   = getCurrentFileTimestamp();

            File iDocsDir = new File(iReportDocsDirectoryPath);
            if (!iDocsDir.exists()) { iDocsDir.mkdirs(); }

            String       iFileName = sanitizeFileName(pTestCaseID) + "_" + iTimestamp + ".docx";
            String       iFullPath = iDocsDir.getAbsolutePath() + File.separator + iFileName;
            XWPFDocument iDoc      = new XWPFDocument();

            XWPFParagraph iHdr = iDoc.createParagraph();
            iHdr.setAlignment(ParagraphAlignment.CENTER);
            XWPFRun iHdrRun = iHdr.createRun();
            iHdrRun.setBold(true);
            iHdrRun.setFontSize(16);
            iHdrRun.setText("Test Report: " + pTestCaseID);

            XWPFRun iDescRun = iDoc.createParagraph().createRun();
            iDescRun.setText("Description: " + iDescription);

            XWPFRun iStartRun = iDoc.createParagraph().createRun();
            iStartRun.setText("Started at: " + getCurrentTimestamp());

            try (FileOutputStream iFos = new FileOutputStream(iFullPath))
            {
                iDoc.write(iFos);
            }

            log.info("[" + getCurrentTimestamp() + "] Word report created : " + iFullPath);
            return new Object[]{iDoc, iFullPath};
        }
        catch (Exception iException)
        {
            log.severe("[" + getCurrentTimestamp() + "] Failed to create Word report : " + iException.getMessage());
            throw new RuntimeException("Failed to create Word report : " + iException.getMessage(), iException);
        }
    }

    // ***************************************************************************************************************************************************************************************
    // Function Name : addScreenshotToReport
    // Description   : Captures screenshot and appends it to the in-memory Word document
    // ***************************************************************************************************************************************************************************************
    public static void addScreenshotToReport(XWPFDocument pDocument, String pDocPath, String pTestCaseID)
    {
        try
        {
            WebDriver iDriver = iDriverHolder.get();
            if (iDriver == null)  { throw new RuntimeException("Driver not initialised."); }
            if (pDocument == null){ throw new RuntimeException("Word document is null."); }
            if (pDocPath == null || pDocPath.trim().isEmpty()) { throw new RuntimeException("Doc path is blank."); }

            File iDir = new File(iReportScreenshotsDirectoryPath);
            if (!iDir.exists()) { iDir.mkdirs(); }

            String iTimestamp = LocalDateTime.now().format(iFileDateTimeFormatterWithMilliSeconds);
            String iPngName   = sanitizeFileName(pTestCaseID) + "_" + iTimestamp + ".png";
            String iPngPath   = iDir.getAbsolutePath() + File.separator + iPngName;

            File iSource = ((TakesScreenshot) iDriver).getScreenshotAs(OutputType.FILE);
            Files.copy(iSource.toPath(), new File(iPngPath).toPath(), StandardCopyOption.REPLACE_EXISTING);

            String iCaption = pTestCaseID + " - " + getDescriptionFromExecutionControl(pTestCaseID)
                    + " | Captured at: " + getCurrentTimestamp();

            XWPFRun iCaptionRun = pDocument.createParagraph().createRun();
            iCaptionRun.setBold(true);
            iCaptionRun.setText(iCaption);
            iCaptionRun.addBreak();

            XWPFRun iImgRun = pDocument.createParagraph().createRun();
            try (InputStream iStream = new FileInputStream(iPngPath))
            {
                iImgRun.addPicture(iStream, Document.PICTURE_TYPE_PNG, iPngName,
                        Units.toEMU(450), Units.toEMU(300));
            }

            log.info("[" + getCurrentTimestamp() + "] Screenshot appended to report : " + iPngPath);
        }
        catch (Exception iException)
        {
            log.severe("[" + getCurrentTimestamp() + "] Failed to append screenshot : " + iException.getMessage());
            throw new RuntimeException("Failed to append screenshot : " + iException.getMessage(), iException);
        }
    }

    // ***************************************************************************************************************************************************************************************
    // Function Name : finalizeWordReport
    // Description   : Writes the in-memory Word document to disk and closes the stream
    // ***************************************************************************************************************************************************************************************
    public static void finalizeWordReport(XWPFDocument pDocument, String pDocPath)
    {
        try
        {
            if (pDocument == null)
            {
                log.warning("[" + getCurrentTimestamp() + "] Word document is null — finalize skipped.");
                return;
            }
            if (pDocPath == null || pDocPath.trim().isEmpty())
            {
                throw new RuntimeException("Word report path is blank.");
            }

            XWPFRun iEndRun = pDocument.createParagraph().createRun();
            iEndRun.setText("Ended at: " + getCurrentTimestamp());

            try (FileOutputStream iFos = new FileOutputStream(pDocPath))
            {
                pDocument.write(iFos);
            }

            pDocument.close();
            log.info("[" + getCurrentTimestamp() + "] Word report finalized : " + pDocPath);
        }
        catch (Exception iException)
        {
            log.severe("[" + getCurrentTimestamp() + "] Failed to finalize Word report : " + iException.getMessage());
            throw new RuntimeException("Failed to finalize Word report : " + iException.getMessage(), iException);
        }
    }


