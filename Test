-- Check 1: Find accessible views that might hold NR/CISYF submission status
SELECT view_name FROM all_views
WHERE view_name LIKE '%YOUNG%'
OR    view_name LIKE '%CISYF%'
OR    view_name LIKE '%NR_%'
OR    view_name LIKE '%ENTITLE%'
ORDER BY view_name;

-- Check 2: Find accessible tables with similar names
SELECT table_name FROM all_tables
WHERE table_name LIKE '%YOUNG%'
OR    table_name LIKE '%CISYF%'
OR    table_name LIKE '%NATRES%'
OR    table_name LIKE '%NAT_RES%'
ORDER BY table_name;
