    // ***************************************************************************************************************************************************************************************
    // Function Name : selectSearchableMatSelect
    // Description   : Handles Angular Material searchable dropdowns that use lib-biss-select-search
    //                 + ngx-mat-select-search. These are fundamentally different from standard
    //                 mat-select because the panel contains a live search input as the first item.
    //
    //                 Standard performMatSelect() fails on these because:
    //                   - The disabled search mat-option appears first and must be skipped
    //                   - Matching must only look at mat-options with class "optionListItem"
    //                   - Text matching must happen AFTER filtering via the search input
    //
    //                 Interaction sequence:
    //                   1. Click the mat-select trigger to open the panel
    //                   2. Wait for the panel and search input to appear
    //                   3. Clear any existing text and type the search value
    //                   4. Wait for filtered options to load (optionListItem class)
    //                   5. Click the first mat-option whose text matches the target
    //                   6. Wait for the panel to close
    //
    // Parameters    : pTriggerXpath      (String) - XPATH of the mat-select trigger element
    //                 pSearchInputXpath  (String) - XPATH of the search input inside the panel
    //                 pValueToSelect     (String) - visible text to match in the filtered options
    // ***************************************************************************************************************************************************************************************
    private void selectSearchableMatSelect(String pTriggerXpath, String pSearchInputXpath, String pValueToSelect)
    {
        log.info("[SEARCHABLE-SELECT] Trigger=" + pTriggerXpath + " | Value=" + pValueToSelect);

        // ── Step 1 : Click the trigger to open the panel ──────────────────────────────────────
        iAction("CLICK", "XPATH", pTriggerXpath, "");

        // ── Step 2 : Wait for the search input to be visible and ready ───────────────────────
        iAction("WAITVISIBLE", "XPATH", pSearchInputXpath, "");

        // ── Step 3 : Clear and type into the search input ────────────────────────────────────
        // Use iAction TEXTBOX so Angular receives proper input events for reactive form filtering
        iAction("TEXTBOX", "XPATH", pSearchInputXpath, pValueToSelect);

        // ── Step 4 : Wait for filtered options to appear ─────────────────────────────────────
        // optionListItem is the class Angular adds only to actual selectable options
        // excludes the disabled search row (contains-mat-select-search class)
        By iOptionBy = By.xpath(
                "//div[role='listbox'][contains(@class,'mdc-menu-surface--open')]" +
                "//mat-option[contains(@class,'optionListItem')]"
        );

        CommonFunctions.getWait().until(ExpectedConditions.visibilityOfElementLocated(iOptionBy));

        // ── Step 5 : Click the matching option ───────────────────────────────────────────────
        // Find all visible selectable options and click the one whose trimmed text matches
        final String iFinalValue = pValueToSelect.trim();

        WebElement iTargetOption = CommonFunctions.getWait().until(iWebDriver ->
        {
            List<WebElement> iOptions = iWebDriver.findElements(iOptionBy);
            for (WebElement iOption : iOptions)
            {
                try
                {
                    String iText = iOption.getText().trim();
                    if (iText.equalsIgnoreCase(iFinalValue) || iText.toLowerCase().contains(iFinalValue.toLowerCase()))
                    {
                        return iOption;
                    }
                }
                catch (Exception ignored) {}
            }
            return null;
        });

        if (iTargetOption == null)
        {
            // Close panel cleanly before throwing
            CommonFunctions.getDriver().switchTo().activeElement().sendKeys(Keys.ESCAPE);
            throw new RuntimeException("SEARCHABLE-SELECT | Option not found: '" + pValueToSelect
                    + "' | Trigger: " + pTriggerXpath
                    + " | Verify the exact text matches a visible option after filtering.");
        }

        iTargetOption.click();

        // ── Step 6 : Wait for the panel to close ─────────────────────────────────────────────
        CommonFunctions.getWait().until(ExpectedConditions.invisibilityOfElementLocated(
                By.cssSelector("div[role='listbox'].mdc-menu-surface--open")));

        log.info("[SEARCHABLE-SELECT] Selected: '" + pValueToSelect + "'");
    }


    // ***************************************************************************************************************************************************************************************
    // Function Name : waitForMatSelectEnabled
    // Description   : Waits until a mat-select element no longer has aria-disabled="true".
    //                 Used before interacting with Townland which is disabled until County is set.
    //
    // Parameters    : pMatSelectXpath (String) - XPATH of the mat-select to check
    // ***************************************************************************************************************************************************************************************
    private void waitForMatSelectEnabled(String pMatSelectXpath)
    {
        log.info("[WAIT-ENABLED] Waiting for mat-select to become enabled: " + pMatSelectXpath);

        CommonFunctions.getWait().until(iWebDriver ->
        {
            try
            {
                List<WebElement> iElements = iWebDriver.findElements(By.xpath(pMatSelectXpath));
                if (iElements.isEmpty()) { return false; }

                String iAriaDisabled = iElements.get(0).getAttribute("aria-disabled");
                return !"true".equalsIgnoreCase(iAriaDisabled);
            }
            catch (Exception ignored) { return false; }
        });

        log.info("[WAIT-ENABLED] mat-select is now enabled: " + pMatSelectXpath);
    }


    // ***************************************************************************************************************************************************************************************
    // Function Name : selectMapAmendmentRadio
    // Description   : Selects a map amendment radio button by matching the label text.
    //                 Clicks the <label> element rather than the hidden radio input to
    //                 ensure Angular's change detection fires correctly.
    //
    //                 Valid values: "Edit Map Online" | "Upload Map" | "Submit Paper Map By Post"
    //
    // Parameters    : pAmendmentType (String) - label text to match
    // ***************************************************************************************************************************************************************************************
    private void selectMapAmendmentRadio(String pAmendmentType)
    {
        log.info("[RADIO] Selecting map amendment type: " + pAmendmentType);

        // Click the mdc-label whose text matches — triggers Angular's radio change event
        iAction("CLICK", "XPATH",
                "//mat-radio-group[@formcontrolname='mapAmendmentType']" +
                "//label[contains(normalize-space(.),' " + pAmendmentType.trim() + " ') or normalize-space(.)='" + pAmendmentType.trim() + "']",
                "");

        log.info("[RADIO] Map amendment type selected: " + pAmendmentType);
    }
