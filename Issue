    // ---------------------------------------------------------------------------------------------------------------------------------
    // Function Name : theSchemeCardsShouldBePresentedAsFollows
    // Description   : Verifies each scheme card carries the expected acronym and full title, optionally at a
    //                 given position. Replaces four separate verify steps per card in legacy.
    // Parameters    : pCards (DataTable) - columns: acronym, title; optional column: position
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ---------------------------------------------------------------------------------------------------------------------------------
    @Then("the scheme cards should be presented as follows")
    public void theSchemeCardsShouldBePresentedAsFollows(DataTable pCards)
    {
        log.info("[STEP] the scheme cards should be presented as follows");
        List<Map<String, String>> iRows = pCards.asMaps(String.class, String.class);

        for (Map<String, String> iRow : iRows)
        {
            String iAcronym  = iRow.get("acronym");
            String iTitle    = iRow.get("title");
            String iPosition = iRow.get("position");

            if (iPosition != null)
            {
                iAction("VERIFYTEXT", "XPATH",
                        ObjReader.getLocator("iSchemeCardByPosition").replace("{INDEX}", iPosition), iAcronym);
            }
            else
            {
                iAction("VERIFYTEXT", "XPATH",
                        ObjReader.getLocator("iSchemeCardTitle").replace("{SCHEME}", iAcronym), iAcronym);
            }

            iAction("VERIFYTEXT", "XPATH",
                    ObjReader.getLocator("iSchemeCardAcronym").replace("{SCHEME}", iAcronym), iTitle);
        }
    }

