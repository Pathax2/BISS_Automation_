-- Should return 1 row (single agent herd)
SELECT hbcus.bcus_bus_id AS HERDNO,
       MIN(ui.uri_username) AS USERNAME
FROM tdco_customer_asscs ca,
     tdco_business_customers abcus,
     tdco_business_customers hbcus,
     tdcr_user_info ui
WHERE SYSDATE BETWEEN ca.ca_start_date AND ca.ca_end_date
AND ca.ca_cac_code     = 194
AND ca.ca_bcus_id_from = abcus.bcus_id
AND ca.ca_bcus_id_to   = hbcus.bcus_id
AND ui.uri_ccs_bus_id  = abcus.bcus_bus_id
AND hbcus.bcus_bus_id  = 'A1010096'
GROUP BY hbcus.bcus_bus_id
HAVING COUNT(DISTINCT ui.uri_username) = 1;

-- Should return 0 rows (multi agent herd)
SELECT hbcus.bcus_bus_id AS HERDNO,
       MIN(ui.uri_username) AS USERNAME
FROM tdco_customer_asscs ca,
     tdco_business_customers abcus,
     tdco_business_customers hbcus,
     tdcr_user_info ui
WHERE SYSDATE BETWEEN ca.ca_start_date AND ca.ca_end_date
AND ca.ca_cac_code     = 194
AND ca.ca_bcus_id_from = abcus.bcus_id
AND ca.ca_bcus_id_to   = hbcus.bcus_id
AND ui.uri_ccs_bus_id  = abcus.bcus_bus_id
AND hbcus.bcus_bus_id  = 'A1010592'
GROUP BY hbcus.bcus_bus_id
HAVING COUNT(DISTINCT ui.uri_username) = 1;
