# Parcel Use — anchored to formcontrolname inside the dialog, not the label
iParcelUseSelect     = //biss-land-details-dialog//lib-biss-select-search[@formcontrolname='parcelUse']//div[contains(@class,'mat-mdc-select-trigger')]

# Option — root search still valid; dialog options render as sibling in cdk-overlay-container
iParcelUseOption     = //mat-option//span[normalize-space()='%s']


@And("the agent changes parcel use to {string}")
public void theAgentChangesParcelUseTo(String pParcelUse)
{
    log.info("[STEP] And the agent changes parcel use to: " + pParcelUse);

    // Step 1 — Click the trigger, anchored to formcontrolname inside the dialog
    iAction("CLICK", "XPATH", ObjReader.getLocator("iParcelUseSelect"), null);

    // Step 2 — Build option XPath and select
    String iOptionXpath = String.format(ObjReader.getLocator("iParcelUseOption"), pParcelUse);
    iAction("LIST", "XPATH", iOptionXpath, pParcelUse);
}
