SELECT  hbcus.bcus_bus_id HerdNo, 
(SELECT ui.uri_username 
FROM tdcr_user_info ui 
WHERE uri_ccs_bus_id =  abcus.bcus_bus_id 
AND ROWNUM = 1)   LoginId
FROM   tdco_customer_asscs ca, 
tdco_business_customers abcus, 
tdco_business_customers hbcus
WHERE SYSDATE BETWEEN ca.ca_start_date 
AND ca.ca_end_date 
AND ca.ca_cac_code = 194
AND ca.ca_bcus_id_from = abcus.bcus_id 
AND ca.ca_bcus_id_to = hbcus.bcus_id 
AND hbcus.bcus_bus_id = 'A127C510'
AND ca.ca_end_date > trunc(sysdate)
order by 2,1;

 

select bc_100.bcus_bus_id herdnumber, ui.uri_username login
from tdcr_user_info ui, tdco_business_customers bc_100, tdco_business_customers bc_115
where ui.uri_ccs_bus_id = bc_115.bcus_bus_id
and bc_100.bcus_cust_id = bc_115.bcus_cust_id
and bc_100.bcus_bus_id in ('B1440948')
and bc_100.BCUS_ROLE_CODE = 100
and bc_115.BCUS_ROLE_CODE = 115
and bc_100.bcus_bus_end_date > trunc(sysdate)
and bc_115.bcus_bus_end_date > trunc(sysdate);
