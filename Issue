# =============================================================================================================================================================================================================================
#                                                                          SECTION 14 : NR / CISYF
#
#  Locators for the full NR/CISYF (National Reserve / Complementary Income Support for Young Farmers)
#  application flow. Scoped to component host elements wherever possible to avoid conflicts.
#
#  HOST COMPONENTS:
#    Landing page     : section.banner (no dedicated host)
#    Category dialog  : app-nr-cisyf-category-select-popup
#    CISYF prompt     : app-nr-cisyf-apply-complementary-income-support-popup
#    CISYF notice     : app-nr-cisyf-complementary-income-support-notice-popup
#    Status page      : app-nr-cisyf-group-status
#    Education page   : app-nr-cisyf-education-screen
#    Summary page     : app-nr-cisyf-application-summary
#
#  PLACEHOLDER CONVENTION:
#    {index}  — replaced at runtime with 1/2/3 for Cat A/B/C
#    {answer} — replaced at runtime with "Yes" or "No"
#    {value}  — replaced at runtime with "Yes" or "No" for radio values
#
#  formcontrolname reference (education page):
#    selectedValueQualification → Has qualification radio
#    dateOfCompletion           → Date of completion datepicker
#    certificateHasBeenAwarded  → Certificate awarded radio
#    colId                      → College / institution dropdown
#    qualId                     → Qualification dropdown
#
#  Author   : Aniket Pathare | aniket.pathare@government.ie
#  Updated  : 21-05-2026
# =============================================================================================================================================================================================================================


# ───────────────────────────────────────────────────────── NR/CISYF — Landing Page ─────────────────────────────────────────────────────────────────────────

# Landing page card title — confirms we are on the NR/CISYF overview page
iNRCISYFLandingHeader                       = //mat-card-title[contains(normalize-space(),'National Reserve/Complementary')]

# Closing date — red bold span on the landing page banner
iNRCISYFCloseDate                           = //span[contains(@style,'color: red') and contains(normalize-space(),'May')]

# Apply or Edit button — nav-button with span text "Apply" or "Edit"
iNRCISYFApplyEditBtn                        = //button[contains(@class,'nav-button') and (.//span[normalize-space()='Apply'] or .//span[normalize-space()='Edit'])]

# View Application button in the action column of the results table
iNRCISYFViewLink                            = (//td[contains(@class,'cdk-column-button')]//button)[1]


# ───────────────────────────────────────────────────────── NR/CISYF — Category Dialog ──────────────────────────────────────────────────────────────────────

# Root host — used for WAITVISIBLE (dialog open) and WAITINVISIBLE (dialog closed)
iNRCISYFDialogOverlay                       = //app-nr-cisyf-category-select-popup

# Dialog title
iNRCISYFDialogTitle                         = //app-nr-cisyf-category-select-popup//mat-card-title[contains(normalize-space(),'Select Category')]

# Close button — button.clearBtn inside the category dialog
iNRCISYFCloseBtn                            = //app-nr-cisyf-category-select-popup//button[contains(@class,'clearBtn')]

# Next button — nav-button without clearBtn class (not the Close button)
iNRCISYFNextBtn                             = //app-nr-cisyf-category-select-popup//button[not(contains(@class,'clearBtn'))][.//span[normalize-space()='Next']]

# Validation error — shown when Next clicked without any category selected
iNRCISYFCategoryError                       = //app-nr-cisyf-category-select-popup//mat-error

# All three mat-checkbox elements — used by reset loop to uncheck all
iNRCISYFCategoryCheckboxes                  = //app-nr-cisyf-category-select-popup//mat-checkbox

# Indexed info icon (1=CatA, 2=CatB, 3=CatC) — mat-icon with class "icon", toggles description
# Replace {index} at runtime: ObjReader.getLocator("iNRCISYFInfoIcon").replace("{index}", iIndex)
iNRCISYFInfoIcon                            = (//app-nr-cisyf-category-select-popup//mat-icon[contains(@class,'icon')])[{index}]

# Indexed description panel — visible after info icon click
# Replace {index} at runtime: ObjReader.getLocator("iNRCISYFInfoContent").replace("{index}", iIndex)
iNRCISYFInfoContent                         = (//app-nr-cisyf-category-select-popup//div[contains(@class,'info-categories')])[{index}]

# Cat A label — click target scoped by formcontrolname (avoids ripple interception)
iNRCISYFCatALabel                           = //mat-checkbox[@formcontrolname='nrYoungFarmer']//label[contains(@class,'mdc-label')]

# Cat B label
iNRCISYFCatBLabel                           = //mat-checkbox[@formcontrolname='nrNewFarmer']//label[contains(@class,'mdc-label')]

# Cat C label
iNRCISYFCatCLabel                           = //mat-checkbox[@formcontrolname='nrCisyf']//label[contains(@class,'mdc-label')]

# Cat A mat-checkbox — used for mat-mdc-checkbox-checked state check
iNRCISYFCatACheckbox                        = //mat-checkbox[@formcontrolname='nrYoungFarmer']

# Cat B mat-checkbox
iNRCISYFCatBCheckbox                        = //mat-checkbox[@formcontrolname='nrNewFarmer']

# Cat C mat-checkbox
iNRCISYFCatCCheckbox                        = //mat-checkbox[@formcontrolname='nrCisyf']

# Cat A native input — for direct checked state read
iNRCISYFCatAInput                           = //mat-checkbox[@formcontrolname='nrYoungFarmer']//input[@type='checkbox']

# Cat B native input
iNRCISYFCatBInput                           = //mat-checkbox[@formcontrolname='nrNewFarmer']//input[@type='checkbox']

# Cat C native input
iNRCISYFCatCInput                           = //mat-checkbox[@formcontrolname='nrCisyf']//input[@type='checkbox']


# ───────────────────────────────────────────────────────── NR/CISYF — CISYF Prompt Dialog ──────────────────────────────────────────────────────────────────

# Root host — scoped to CISYF prompt popup
iNRCISYFCISYFPromptOverlay                  = //app-nr-cisyf-apply-complementary-income-support-popup

# "Select additional CISYF category and continue" button
iNRCISYFSelectAdditionalCISYFBtn            = //app-nr-cisyf-apply-complementary-income-support-popup//button[.//span[contains(normalize-space(),'Select additional CISYF')]]

# "Do not select CISYF category and continue" button
iNRCISYFDoNotSelectCISYFBtn                 = //app-nr-cisyf-apply-complementary-income-support-popup//button[.//span[contains(normalize-space(),'Do not select CISYF')]]


# ───────────────────────────────────────────────────────── NR/CISYF — CISYF Notice Popup ───────────────────────────────────────────────────────────────────

# OK button on the "Important Information Notice for Applicants" popup
# Scoped to app-nr-cisyf-complementary-income-support-notice-popup
iNRCISYFOKBtn                               = //app-nr-cisyf-complementary-income-support-notice-popup//button[.//span[normalize-space()='OK']]


# ───────────────────────────────────────────────────────── NR/CISYF — Status Page (Step 1) ─────────────────────────────────────────────────────────────────

# Farming Entity dropdown — identified by mat-label text (no formcontrolname on mat-select)
iNRCISYFFarmingEntityDropdown               = //app-nr-cisyf-group-status//mat-form-field[.//mat-label[normalize-space()='Farming Entity']]//mat-select

# Number of group members dropdown
iNRCISYFMemberCountDropdown                 = //app-nr-cisyf-group-status//mat-form-field[.//mat-label[normalize-space()='Number of group members']]//mat-select

# Member table — plain HTML table inside app-nr-cisyf-group-status
iNRCISYFMemberTable                         = //app-nr-cisyf-group-status//table//tbody

# Member name input — indexed by row {index}
# Replace {index} at runtime: ObjReader.getLocator("iNRCISYFMemberNameInput").replace("{index}", iIdx)
iNRCISYFMemberNameInput                     = (//app-nr-cisyf-group-status//table//tbody//tr)[{index}]//input[@type='text']

# Member DOB calendar toggle — indexed by row {index}
# DOB is a mat-datepicker — click calendar icon to open, or inject via JS
iNRCISYFMemberDOBCalendarBtn                = (//app-nr-cisyf-group-status//table//tbody//tr)[{index}]//button[@aria-label='Open calendar']

# Member eligible farmer checkbox native input — indexed by row {index}
iNRCISYFMemberEligibleCheckbox              = (//app-nr-cisyf-group-status//table//tbody//tr)[{index}]//input[@type='checkbox']

# Group status radio — "Has the Applicant effective control and decision making power?"
# Replace {answer} at runtime with "Yes" or "No"
iNRCISYFGroupStatusRadio                    = //app-nr-cisyf-group-status//mat-radio-button[.//label[normalize-space()='{answer}']]//input[@type='radio']

# Status page Next button
iNRCISYFStatusNextBtn                       = //app-nr-cisyf-group-status//button[.//span[normalize-space()='Next']]

# Status page Save and Exit button
iNRCISYFStatusSaveExitBtn                   = //app-nr-cisyf-group-status//button[.//span[normalize-space()='Save and Exit']]

# Status page Back button
iNRCISYFStatusBackBtn                       = //app-nr-cisyf-group-status//button[.//span[normalize-space()='Back']]

# NR/CISYF Overview button — returns to landing page from status
iNRCISYFOverviewBtn                         = //app-nr-cisyf-group-status//button[.//span[normalize-space()='NR/CISYF Overview']]


# ───────────────────────────────────────────────────────── NR/CISYF — Education Page (Step 2) ──────────────────────────────────────────────────────────────

# Has qualification radio group — formcontrolname="selectedValueQualification"
# Replace {value} with "Yes" or "No" at runtime
iNRCISYFHasQualRadio                        = //mat-radio-group[@formcontrolname='selectedValueQualification']//mat-radio-button[.//label[normalize-space()='{value}']]//input[@type='radio']

# Date of completion — mat-datepicker input, formcontrolname="dateOfCompletion"
# Use JS inject (disabled by default): removeAttribute('disabled') then set value + dispatch events
iNRCISYFDateOfCompletionInput               = //input[@formcontrolname='dateOfCompletion']

# Date of completion calendar open button
iNRCISYFDateOfCompletionCalendarBtn         = //mat-form-field[.//input[@formcontrolname='dateOfCompletion']]//button[@aria-label='Open calendar']

# Certificate awarded radio group — formcontrolname="certificateHasBeenAwarded"
# Replace {value} with "Yes" or "No" at runtime
iNRCISYFCertAwardedRadio                    = //mat-radio-group[@formcontrolname='certificateHasBeenAwarded']//mat-radio-button[.//label[normalize-space()='{value}']]//input[@type='radio']

# College / educational institution dropdown — formcontrolname="colId"
iNRCISYFCollegeDropdown                     = //mat-select[@formcontrolname='colId']

# Qualification dropdown — formcontrolname="qualId"
iNRCISYFQualificationDropdown               = //mat-select[@formcontrolname='qualId']

# Custom college free-text input — rendered when "not in list" selected from colId
iNRCISYFCustomCollegeField                  = //input[@formcontrolname='customCollege'] | //input[@formcontrolname='customInstitution']

# Custom qualification free-text input — rendered when "not in list" selected from qualId
iNRCISYFCustomQualificationField            = //input[@formcontrolname='customQualification']

# Next to Summary button — advances to Step 3
iNRCISYFNextToSummaryBtn                    = //app-nr-cisyf-education-screen//button[.//span[normalize-space()='Next to Summary']]

# Education page Save and Exit button
iNRCISYFEduSaveExitBtn                      = //app-nr-cisyf-education-screen//button[.//span[normalize-space()='Save and Exit']]

# Education page Back button
iNRCISYFEduBackBtn                          = //app-nr-cisyf-education-screen//button[.//span[normalize-space()='Back']]

# Next Farmer button — advances to next member's qualification in multi-member flows
iNRCISYFNextFarmerBtn                       = //button[.//span[contains(normalize-space(),'Next Farmer')]]

# No qualification info message — displayed when hasQualification = No
iNRCISYFNoQualMessage                       = //app-nr-cisyf-education-screen//*[contains(normalize-space(),'no qualification') or contains(normalize-space(),'Covid') or contains(@class,'no-qual')]


# ───────────────────────────────────────────────────────── NR/CISYF — Summary Page (Step 3) ────────────────────────────────────────────────────────────────

# Upload button scoped to document label — replace {label} with first 40 chars of doc type
# Example: ObjReader.getLocator("iNRCISYFUploadBtn").replace("{label}", "Upload Invoice/Receipt")
iNRCISYFUploadBtn                           = //mat-card-content[.//p[contains(normalize-space(),'{label}')]]//button[.//span[normalize-space()='Upload']]

# Generic Upload button fallback
iNRCISYFUploadBtnGeneric                    = //button[.//mat-icon[normalize-space()='cloud_upload'] and .//span[normalize-space()='Upload']]

# File input — hidden input[@type='file'] for all uploads on summary page
iNRCISYFFileUploadInput                     = //input[@type='file']

# Upload Document confirm button inside upload dialog
iNRCISYFUploadDocumentBtn                   = //button[.//span[normalize-space()='Upload Document'] or contains(normalize-space(),'Upload Document')]

# Upload dialog close/cancel button
iNRCISYFUploadCloseBtn                      = //mat-dialog-container//button[.//span[normalize-space()='Close'] or .//span[normalize-space()='Cancel']]

# Upload error — mat-error when no document uploaded
iNRCISYFUploadError                         = //mat-error[contains(normalize-space(),'Documents have been uploaded')]

# Summary page Save and Next button
iNRCISYFSaveAndNextBtn                      = //app-nr-cisyf-application-summary//button[.//span[normalize-space()='Save and Next']]

# Summary page Back button
iNRCISYFSummaryBackBtn                      = //app-nr-cisyf-application-summary//button[.//span[normalize-space()='Back']]

# Educational Institution Details value on summary review
iNRCISYFEduInstitutionSummary               = //p[contains(normalize-space(),'Educational Institution Details')]/following-sibling::div//b | //mat-card-content[.//p[contains(normalize-space(),'Educational Institution')]]//b

# Qualification Details value on summary review
iNRCISYFQualDetailsSummary                  = //p[contains(normalize-space(),'Qualification Details')]/following-sibling::div//b | //mat-card-content[.//p[contains(normalize-space(),'Qualification Details')]]//b

# Education Documentation section card title — used for post-submission doc link clicks
iNRCISYFEduDocSection                       = //mat-card-title[normalize-space()='Education Documentation']


# ───────────────────────────────────────────────────────── NR/CISYF — Submission & Declaration ─────────────────────────────────────────────────────────────

# Submit Application button on declaration step
iNRCISYFSubmitApplicationBtn                = //button[.//span[normalize-space()='Submit Application'] or normalize-space()='Submit Application']

# Declaration checkbox 1 — first of two required ticks
iNRCISYFDeclarationCheckbox1                = (//mat-checkbox[ancestor::*[contains(@class,'declaration')]]//input[@type='checkbox'])[1]

# Declaration checkbox 2 — second required tick
iNRCISYFDeclarationCheckbox2                = (//mat-checkbox[ancestor::*[contains(@class,'declaration')]]//input[@type='checkbox'])[2]

# Final submit confirm button in submission dialog
iNRCISYFSubmitConfirmBtn                    = //button[.//span[normalize-space()='Submit'] or normalize-space()='Submit'][not(@disabled)][not(contains(@class,'clearBtn'))]

# Submission success message — shown after successful submit
iNRCISYFSubmitSuccessMsg                    = //*[contains(@class,'success') or contains(@class,'confirmation') or contains(normalize-space(),'successfully submitted') or contains(normalize-space(),'application has been submitted')]


# ───────────────────────────────────────────────────────── NR/CISYF — Post Submission ──────────────────────────────────────────────────────────────────────

# View Application button on landing page for a submitted herd
iNRCISYFViewApplicationBtn                  = //button[.//span[normalize-space()='View Application']]

# Correspondence navigation link in the application view
iNRCISYFCorrespondenceNavBtn                = //a[normalize-space()='Correspondence'] | //button[contains(normalize-space(),'Correspondence')]

# Correspondence document rows — links to uploaded documents
iNRCISYFCorrespondenceDocLinks              = //a[contains(@href,'download')] | //a[contains(normalize-space(),'.pdf')]


# ───────────────────────────────────────────────────────── NR/CISYF — Angular Material CDK ─────────────────────────────────────────────────────────────────

# Open CDK overlay panel — wait for mat-select options to render
iMatSelectOpenPanel                         = //div[contains(@class,'mat-mdc-select-panel') and not(contains(@class,'ng-animating'))]

# mat-option text span — used to read dropdown options
iMatOptionText                              = //mat-option//span[contains(@class,'mdc-list-item__primary-text')]
