// ── Find the last View button in the Transfers In table ───────────────────────────
// Iterates through all rows, filters to rows that have a real transfer key
// (excludes rows showing the warningText "Please request the transfer key" message),
// then clicks the View button of the last qualifying row.
// This is robust to row count changes between runs.
List<WebElement> iAllRows = getDriver().findElements(
        By.xpath("//tr[contains(@class,'mat-mdc-row')]"));

log.info("[TRANSFER] Total rows in transfer table: " + iAllRows.size());

WebElement iLastValidViewBtn = null;
int        iLastValidRowIndex = -1;

for (int i = 0; i < iAllRows.size(); i++)
{
    WebElement iRow = iAllRows.get(i);

    // ── Check if this row has a real transfer key ─────────────────────────────
    // Rows without a key show a <p class="warningText"> in the key column.
    // Rows with a key have plain text (e.g. "HUBCFUUA") — no warningText element.
    List<WebElement> iWarning = iRow.findElements(
            By.xpath(".//td[contains(@class,'cdk-column-transferKey')]//p[contains(@class,'warningText')]"));

    if (!iWarning.isEmpty())
    {
        log.info("[TRANSFER] Row " + (i + 1) + " — no transfer key (warningText) — skipping.");
        continue;
    }

    // ── Row has a real transfer key — find its View button ────────────────────
    List<WebElement> iViewBtns = iRow.findElements(
            By.xpath(".//button[normalize-space()='View']"));

    if (iViewBtns.isEmpty())
    {
        log.info("[TRANSFER] Row " + (i + 1) + " — has transfer key but no View button — skipping.");
        continue;
    }

    // ── Track this as the latest valid row seen so far ────────────────────────
    iLastValidViewBtn   = iViewBtns.get(0);
    iLastValidRowIndex  = i + 1;

    String iStatus = iRow.findElement(
            By.xpath(".//td[contains(@class,'cdk-column-transferStatus')]"))
            .getText().trim();
    String iKey = iRow.findElement(
            By.xpath(".//td[contains(@class,'cdk-column-transferKey')]"))
            .getText().trim();
    log.info("[TRANSFER] Row " + (i + 1) + " — valid | status=" + iStatus
            + " | key=" + iKey);
}

if (iLastValidViewBtn == null)
{
    throw new RuntimeException(
            "[TRANSFER] No valid transfer row found with a transfer key. "
            + "Total rows scanned: " + iAllRows.size());
}

log.info("[TRANSFER] Clicking View on last valid row: " + iLastValidRowIndex
        + " of " + iAllRows.size());

((JavascriptExecutor) getDriver())
        .executeScript("arguments[0].scrollIntoView({block:'center'});", iLastValidViewBtn);
((JavascriptExecutor) getDriver())
        .executeScript("arguments[0].click();", iLastValidViewBtn);

log.info("[TRANSFER] View clicked — row " + iLastValidRowIndex);
