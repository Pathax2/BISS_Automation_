SELECT yfs.sph_sps_holding_id,
       yfs.syr_scheme_year_code,
       yfs.yfs_application_year,
       yfs.yfs_entry_complete_ind,
       yfs.yfs_tao_complete_ind,
       v.app_herd_no,
       v.app_year
FROM TDSP_YOUNG_FARMER_SUMMARY yfs
JOIN vwbs_application_herd v
  ON v.aph_cust_id = yfs.sph_sps_holding_id
WHERE v.app_herd_no = 'J1994001'
ORDER BY yfs.syr_scheme_year_code DESC;
