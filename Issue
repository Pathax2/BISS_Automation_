@When("the agent selects the {string} scheme")
public void theAgentSelectsTheScheme(String pSchemeName)
{
    log.info("[STEP] When the agent selects the scheme: " + pSchemeName);

    WebDriver iDriver = CommonFunctions.getDriver();

    // ── Locate the toggle button scoped to the card that contains this scheme name ──
    // Anchor on the scheme name span inside mat-card, then walk up to the card root,
    // then find the toggle button within that same card — avoids cross-component
    // preceding:: traversal that breaks when Angular wraps in separate host elements
    String iToggleXpath = String.format(
        "//mat-card[.//*[normalize-space()='%s']]//button[@role='switch']", pSchemeName);

    // ── Check the toggle exists at all ───────────────────────────────────────────
    List<WebElement> iToggles = iDriver.findElements(By.xpath(iToggleXpath));

    if (iToggles.isEmpty())
    {
        log.warning("Scheme '" + pSchemeName + "' toggle button not found in DOM — skipping.");
        return;
    }

    WebElement iToggle = iToggles.get(0);

    // ── Check if the toggle is disabled — scheme not eligible for this herd ──────
    boolean iIsDisabled = iToggle.getAttribute("disabled") != null
        || iToggle.getAttribute("class").contains("mdc-switch--disabled");

    if (iIsDisabled)
    {
        log.warning("Scheme '" + pSchemeName + "' toggle is DISABLED for this herd — skipping.");
        return;
    }

    // ── Read current state — only turn ON, never accidentally flip OFF ────────────
    String iState = iToggle.getAttribute("aria-checked");

    if ("true".equalsIgnoreCase(iState))
    {
        log.info("Scheme '" + pSchemeName + "' is already ON → no action.");
        return;
    }

    // ── Toggle is enabled and OFF — click the scheme name span to activate ────────
    // Clicking the span fires the Angular toggle binding reliably;
    // clicking the button directly can be intercepted by the ripple overlay
    log.info("Scheme '" + pSchemeName + "' is OFF → turning ON.");
    iAction("CLICK", "XPATH",
        String.format("//mat-card[.//*[normalize-space()='%s']]//span[normalize-space()='%s']",
            pSchemeName, pSchemeName),
        null);

    // ── Verify toggle flipped to ON after click ───────────────────────────────────
    iToggle = iDriver.findElement(By.xpath(iToggleXpath)); // re-fetch after DOM update
    String iNewState = iToggle.getAttribute("aria-checked");

    if (!"true".equalsIgnoreCase(iNewState))
    {
        throw new AssertionError("Scheme '" + pSchemeName
            + "' toggle did not switch ON after click. Current aria-checked: " + iNewState);
    }

    log.info("✅ Scheme '" + pSchemeName + "' successfully turned ON.");
}
