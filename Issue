    // ***************************************************************************************************************************************************************************************
    // Step          : the agent resets all category selections
    // Description   : Unchecks all three category checkboxes in the dialog to start from a clean slate.
    //                 FIX 2: iNRCISYFCategoryCheckboxes now defined in ObjectRepository as
    //                          //app-nr-cisyf-category-select-popup//mat-checkbox
    //                         Checks aria-checked on mat-checkbox; unchecks by clicking native input.
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026 | Updated : 19-05-2026
    // ***************************************************************************************************************************************************************************************
    @And("the agent resets all category selections")
    public void theAgentResetsAllCategorySelections()
    {
        log.info("[STEP] And the agent resets all category selections");

        List<WebElement> iCheckboxes = getDriver().findElements(
                By.xpath(ObjReader.getLocator("iNRCISYFCategoryCheckboxes")));

        if (iCheckboxes.isEmpty())
        {
            log.warning("[TC13] No category checkboxes found during reset — dialog may not be open.");
            return;
        }

        int iUnchecked = 0;
        for (WebElement iCb : iCheckboxes)
        {
            try
            {
                // aria-checked lives on the mat-checkbox element
                String iAriaChecked = iCb.getAttribute("aria-checked");
                if ("true".equalsIgnoreCase(iAriaChecked))
                {
                    // Click the native input inside the mat-checkbox to uncheck
                    WebElement iNativeInput = iCb.findElement(By.xpath(".//input[@type='checkbox']"));
                    iNativeInput.click();
                    iUnchecked++;
                    log.info("[TC13] Unchecked: " + iCb.getText().trim().replaceAll("\\s+", " "));
                }
            }
            catch (Exception e)
            {
                log.warning("[TC13] Could not reset checkbox: " + e.getMessage());
            }
        }
        log.info("[TC13] Category reset complete. Unchecked " + iUnchecked + " of "
                + iCheckboxes.size() + " checkbox(es).");
    }


    // ***************************************************************************************************************************************************************************************
    // Step          : the agent selects NRCISYF categories (DataTable)
    // Description   : Selects each category listed in the DataTable.
    //                 FIX 3: Clicks via the mdc-label inside the mat-checkbox, scoped by formcontrolname.
    //                         Label click is more reliable than clicking mat-checkbox directly in
    //                         Angular Material 2+ (avoids click interception by ripple overlay).
    //                 Falls back to native input click if label is not found.
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026 | Updated : 19-05-2026
    // ***************************************************************************************************************************************************************************************
    @And("the agent selects NRCISYF categories")
    public void theAgentSelectsNRCISYFCategories(DataTable pDataTable)
    {
        log.info("[STEP] And the agent selects NRCISYF categories");

        List<String> iCategories = pDataTable.asList();

        for (String iCategory : iCategories)
        {
            String iClean = iCategory.trim();
            log.info("[TC13] Selecting category: " + iClean);

            // ── Resolve formcontrolname from category label ───────────────────────────────────
            // Using formcontrolname makes the locator immune to label text changes
            String iFormControlName;
            if      (iClean.startsWith("A.")) iFormControlName = "nrYoungFarmer";
            else if (iClean.startsWith("B.")) iFormControlName = "nrNewFarmer";
            else if (iClean.startsWith("C.")) iFormControlName = "nrCisyf";
            else
            {
                // Fallback: match by label text directly
                iFormControlName = null;
                log.warning("[TC13] Category label not prefixed with A/B/C — falling back to text match: "
                        + iClean);
            }

            String iClickXpath;
            if (iFormControlName != null)
            {
                // Primary: click the mdc-label scoped to formcontrolname
                // Label click fires Angular binding without ripple interception
                iClickXpath = "//mat-checkbox[@formcontrolname='" + iFormControlName
                        + "']//label[contains(@class,'mdc-label')]";
            }
            else
            {
                // Fallback: match by label text
                iClickXpath = "//label[contains(normalize-space(),'" + iClean + "')]";
            }

            // ── Check current state — skip if already selected ────────────────────────────────
            try
            {
                String iCheckXpath = (iFormControlName != null)
                        ? "//mat-checkbox[@formcontrolname='" + iFormControlName + "']"
                        : "//mat-checkbox[.//label[contains(normalize-space(),'" + iClean + "')]]";

                WebElement iMatCheckbox = getDriver().findElement(By.xpath(iCheckXpath));
                String iAriaChecked = iMatCheckbox.getAttribute("aria-checked");

                if ("true".equalsIgnoreCase(iAriaChecked))
                {
                    log.info("[TC13] Category '" + iClean + "' already selected — skipping.");
                    continue;
                }
            }
            catch (Exception e)
            {
                log.info("[TC13] Could not read aria-checked for '" + iClean + "' — proceeding to click.");
            }

            // ── Click the label ───────────────────────────────────────────────────────────────
            iAction("WAITVISIBLE",   "XPATH", iClickXpath, null);
            iAction("WAITCLICKABLE", "XPATH", iClickXpath, null);
            iAction("CLICK",         "XPATH", iClickXpath, null);
            log.info("[TC13] Selected: " + iClean);
        }
    }


