    // =================================================================
    // CORE LOGIC — run extraction via DBRouter
    // =================================================================
    private void runExtraction()
    {
        String iSql     = iQueryArea.getText().trim();
        String iColName = iColumnNameField.getText().trim().toUpperCase();
        String iLimStr  = iHerdLimitField.getText().trim();

        // ── Validation ───────────────────────────────────────────────
        if (iSql.isEmpty())
        {
            showError("SQL query cannot be empty.");
            return;
        }
        if (iColName.isEmpty())
        {
            showError("Column name cannot be empty.\nEnter the column that contains herd numbers e.g. APP_HERD_NO");
            return;
        }

        int iLimit = -1;
        if (!iLimStr.isEmpty())
        {
            try { iLimit = Integer.parseInt(iLimStr); }
            catch (NumberFormatException e) { showError("Herd limit must be a whole number or leave blank for all rows."); return; }
        }

        final int iFinalLimit = iLimit;

        // ── Reset UI ─────────────────────────────────────────────────
        iRunButton.setEnabled(false);
        iExportButton.setEnabled(false);
        iTableModel.setRowCount(0);
        iResultRows.clear();
        iLogArea.setText("");
        setStatus("Running...", C_ACCENT);

        // ── Background worker ─────────────────────────────────────────
        SwingWorker<Void, String[]> iWorker = new SwingWorker<>()
        {
            @Override
            protected Void doInBackground()
            {
                log("Step 1 — Running SQL on BISS_DATA via DBRouter...");

                // ── Run user SQL on BISS_DATA ─────────────────────────
                // DBRouter handles the connection via db.properties.
                // We pass the raw SQL as a custom label so DBRouter executes
                // it directly via executeQuery().
                List<String> iHerds = new ArrayList<>();

                try
                {
                    // Use DBRouter's connection directly — avoids duplicating
                    // connection logic. Execute user SQL and read the result.
                    database.DBRouter.runDB("DATA", iSql.contains("?")
                            ? "LIST OF HERDS WITH NO ERRORS AT ALL"
                            : iSql, "2026", "999");

                    List<Map<String, Object>> iRows = database.DBRouter.getRows();

                    if (iRows == null || iRows.isEmpty())
                    {
                        log("WARNING: Query returned no rows from BISS_DATA.");
                        log("Check the SQL query and year parameters.");
                        return null;
                    }

                    log("Query returned " + iRows.size() + " row(s) from BISS_DATA.");

                    // Extract herd numbers from the specified column
                    for (Map<String, Object> iRow : iRows)
                    {
                        // Try exact match first, then case-insensitive
                        Object iVal = iRow.get(iColName);
                        if (iVal == null)
                        {
                            for (String k : iRow.keySet())
                            {
                                if (k.equalsIgnoreCase(iColName)) { iVal = iRow.get(k); break; }
                            }
                        }

                        if (iVal != null)
                        {
                            String h = iVal.toString().trim();
                            if (!h.isEmpty()) iHerds.add(h);
                        }

                        if (iFinalLimit > 0 && iHerds.size() >= iFinalLimit) break;
                    }

                    if (iHerds.isEmpty())
                    {
                        log("ERROR: Column '" + iColName + "' not found or returned no values.");
                        log("Available columns in result:");
                        if (!iRows.isEmpty())
                        {
                            iRows.get(0).keySet().forEach(k -> log("  • " + k));
                        }
                        return null;
                    }

                    log("Extracted " + iHerds.size() + " herd number(s).");
                    log("─".repeat(55));
                    log("Step 2 — Querying BISS_INET for agent logins...");
                    log("─".repeat(55));

                    // ── For each herd query BISS_INET via DBRouter ────
                    int iRowNum = 0;
                    for (String iHerd : iHerds)
                    {
                        iRowNum++;
                        try
                        {
                            database.DBRouter.runDB("INET", "Get Login Id for herd", iHerd);
                            String iAgent = database.DBRouter.getValue("USERNAME");

                            if (iAgent != null && !iAgent.isBlank())
                            {
                                String[] iRowData = {
                                        String.valueOf(iRowNum),
                                        iHerd,
                                        iAgent.trim(),
                                        "FOUND"
                                };
                                publish(iRowData);
                                log("[" + iRowNum + "] " + iHerd + "  →  " + iAgent.trim());
                            }
                            else
                            {
                                String[] iRowData = {
                                        String.valueOf(iRowNum),
                                        iHerd,
                                        "",
                                        "NO AGENT"
                                };
                                publish(iRowData);
                                log("[" + iRowNum + "] " + iHerd + "  →  (no active agent found in INET)");
                            }
                        }
                        catch (Exception iEx)
                        {
                            String[] iRowData = {
                                    String.valueOf(iRowNum),
                                    iHerd,
                                    "",
                                    "ERROR"
                            };
                            publish(iRowData);
                            log("[" + iRowNum + "] " + iHerd + "  →  ERROR: " + iEx.getMessage());
                        }
                    }

                    log("─".repeat(55));
                    log("Done — " + iRowNum + " herd(s) processed.");

                    long iFount = iResultRows.stream()
                            .filter(r -> "FOUND".equals(r[3])).count();
                    log("FOUND: " + iFount + "  |  NO AGENT: " + (iRowNum - iFount));
                }
                catch (Exception iEx)
                {
                    log("ERROR: " + iEx.getMessage());
                    log("Check db.properties and DBRouter configuration.");
                }

                return null;
            }

            @Override
            protected void process(List<String[]> chunks)
            {
                for (String[] row : chunks)
                {
                    iTableModel.addRow(row);
                    iResultRows.add(row);
                }
                // Refresh renderer on each batch so colours apply immediately
                iResultTable.setDefaultRenderer(Object.class, buildRenderer());
            }

            @Override
            protected void done()
            {
                iRunButton.setEnabled(true);
                iExportButton.setEnabled(!iResultRows.isEmpty());
                long iFount = iResultRows.stream().filter(r -> "FOUND".equals(r[3])).count();
                setStatus("Completed  —  " + iResultRows.size() + " herd(s)  |  "
                        + iFount + " agent(s) found.", C_GREEN);
            }
        };

        iWorker.execute();
    }

    // =================================================================
    // TABLE RENDERER — colour by status
    // =================================================================
    private TableCellRenderer buildRenderer()
    {
        return new DefaultTableCellRenderer()
        {
            @Override
            public Component getTableCellRendererComponent(
                    JTable t, Object v, boolean sel, boolean foc, int r, int c)
            {
                super.getTableCellRendererComponent(t, v, sel, foc, r, c);
                String iStatus = Objects.toString(t.getValueAt(r, 3), "");
                Color iFg = switch (iStatus)
                {
                    case "FOUND"    -> C_GREEN;
                    case "NO AGENT" -> C_ORANGE;
                    default         -> C_RED;
                };
                setForeground(iFg);
                setBackground(sel ? C_BORDER : C_PANEL);
                setFont(FONT_TABLE);
                setBorder(BorderFactory.createEmptyBorder(0, 8, 0, 8));
                return this;
            }
        };
    }

    // =================================================================
    // EXPORT TO CSV
    // =================================================================
    private void exportToCsv()
    {
        JFileChooser iChooser = new JFileChooser();
        iChooser.setDialogTitle("Export Results to CSV");
        iChooser.setSelectedFile(new File(
                "BISS_Herd_Agents_"
                + new SimpleDateFormat("yyyyMMdd_HHmmss").format(new Date())
                + ".csv"));

        if (iChooser.showSaveDialog(this) != JFileChooser.APPROVE_OPTION) return;

        File iFile = iChooser.getSelectedFile();
        if (!iFile.getName().endsWith(".csv"))
        {
            iFile = new File(iFile.getAbsolutePath() + ".csv");
        }

        try (PrintWriter iWriter = new PrintWriter(new FileWriter(iFile)))
        {
            iWriter.println("Row,Herd Number,Agent Username,Status");
            for (String[] iRow : iResultRows)
            {
                iWriter.println(String.join(",", iRow));
            }
            setStatus("Exported: " + iFile.getAbsolutePath(), C_GREEN);
            log("Exported to: " + iFile.getAbsolutePath());
            JOptionPane.showMessageDialog(this,
                    "Exported successfully:\n" + iFile.getAbsolutePath(),
                    "Export Complete",
                    JOptionPane.INFORMATION_MESSAGE);
        }
        catch (IOException e)
        {
            showError("Export failed: " + e.getMessage());
        }
    }

    // =================================================================
    // UI HELPERS
    // =================================================================
    private void styleTable(JTable t)
    {
        t.setBackground(C_PANEL);
        t.setForeground(C_TEXT);
        t.setFont(FONT_TABLE);
        t.setRowHeight(28);
        t.setShowGrid(false);
        t.setIntercellSpacing(new Dimension(0, 1));
        t.setSelectionBackground(C_BORDER);
        t.setSelectionForeground(C_TEXT);
        t.setDefaultRenderer(Object.class, buildRenderer());

        JTableHeader iHeader = t.getTableHeader();
        iHeader.setBackground(C_HEADER_BG);
        iHeader.setForeground(C_MUTED);
        iHeader.setFont(FONT_LABEL);
        iHeader.setBorder(BorderFactory.createMatteBorder(0, 0, 1, 0, C_BORDER));

        t.getColumnModel().getColumn(0).setMaxWidth(50);
        t.getColumnModel().getColumn(3).setMaxWidth(120);
    }

