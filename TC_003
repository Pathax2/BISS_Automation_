    // ***************************************************************************************************************************************************************************************
    // Function Name : waitForAngularReady
    // Description   : Blocks execution until the Angular application is fully stable and ready for interaction.
    //
    //                 Three conditions must ALL be true before this method returns:
    //
    //                   Condition 1 — document.readyState === 'complete'
    //                     Ensures the HTML document and all synchronous resources have finished loading.
    //
    //                   Condition 2 — Angular Zone.js task queue is empty
    //                     Angular uses Zone.js to track all async tasks (HTTP calls, setTimeout, Promises).
    //                     When ngZone.hasPendingMacrotasks and hasPendingMicrotasks are both false,
    //                     Angular has finished processing and the DOM is stable.
    //                     Falls back gracefully if Angular is not present on the page (e.g. login page
    //                     served by a different framework).
    //
    //                   Condition 3 — No MDC circular progress spinner visible
    //                     The BISS application shows an MDC spinner during API response delays.
    //                     This check ensures the spinner is gone before any element interaction begins.
    //
    //                 This method is called automatically by iAction() before every single interaction.
    //                 It does NOT replace WAITINVISIBLE in step definitions — WAITINVISIBLE is the
    //                 explicit step-level wait; this is the implicit framework-level safety net.
    //
    // Parameters    : pDriver (WebDriver) - current thread driver
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 10-03-2026
    // ***************************************************************************************************************************************************************************************
    public static void waitForAngularReady(WebDriver pDriver)
    {
        if (pDriver == null)
        {
            return;
        }

        JavascriptExecutor iJs        = (JavascriptExecutor) pDriver;
        long               iDeadline  = System.currentTimeMillis() + iAngularTimeoutMs;

        while (System.currentTimeMillis() < iDeadline)
        {
            try
            {
                // ── Condition 1 : document.readyState ────────────────────────────────────
                Object iReadyState = iJs.executeScript("return document.readyState;");
                if (!"complete".equals(iReadyState))
                {
                    Thread.sleep(iAngularPollMs);
                    continue;
                }

                // ── Condition 2 : Angular Zone.js stability ───────────────────────────────
                // The JS checks for window.getAllAngularTestabilities() which is present in
                // Angular apps compiled with Zone.js (standard Angular build).
                // Returns true (stable) when no pending tasks remain in any Angular zone.
                Object iAngularStable = iJs.executeScript(
                    "try {" +
                    "  var testabilities = window.getAllAngularTestabilities();" +
                    "  if (!testabilities || testabilities.length === 0) { return true; }" +
                    "  for (var i = 0; i < testabilities.length; i++) {" +
                    "    if (!testabilities[i].isStable()) { return false; }" +
                    "  }" +
                    "  return true;" +
                    "} catch(e) {" +
                    "  return true;" +  // Angular not present on this page — treat as stable
                    "}"
                );

                if (!Boolean.TRUE.equals(iAngularStable))
                {
                    Thread.sleep(iAngularPollMs);
                    continue;
                }

                // ── Condition 3 : MDC spinner not visible ─────────────────────────────────
                // Checks both CSS visibility and aria-hidden on the spinner container.
                // Uses findElements (returns empty list instead of throwing) for safety.
                List<WebElement> iSpinners = pDriver.findElements(By.cssSelector(iSpinnerCss));

                boolean iSpinnerActive = false;

                for (WebElement iSpinner : iSpinners)
                {
                    try
                    {
                        boolean iDisplayed   = iSpinner.isDisplayed();
                        String  iAriaHidden  = iSpinner.getAttribute("aria-hidden");
                        boolean iHiddenByAria = "true".equalsIgnoreCase(iAriaHidden);

                        if (iDisplayed && !iHiddenByAria)
                        {
                            iSpinnerActive = true;
                            break;
                        }
                    }
                    catch (StaleElementReferenceException iStale)
                    {
                        // Spinner was removed from DOM while checking — treat as gone
                    }
                }

                if (iSpinnerActive)
                {
                    Thread.sleep(iAngularPollMs);
                    continue;
                }

                // All three conditions met — Angular is ready
                return;
            }
            catch (InterruptedException iInterrupted)
            {
                Thread.currentThread().interrupt();
                return;
            }
            catch (Exception iException)
            {
                // JS execution error or driver communication issue — log and continue polling
                log.warning("[" + getCurrentTimestamp() + "] waitForAngularReady poll error (non-fatal) : " + iException.getMessage());
                try { Thread.sleep(iAngularPollMs); } catch (InterruptedException ignored) { Thread.currentThread().interrupt(); }
            }
        }

        // Timeout reached — log warning but do NOT throw. Framework continues.
        // If the page is genuinely broken the subsequent element wait will fail with a clear message.
        log.warning("[" + getCurrentTimestamp() + "] waitForAngularReady timed out after " + iAngularTimeoutMs + "ms — proceeding with action.");
    }


