# View button — always clicks the LAST row in the transfer table.
# Table has multiple rows; the most recently created transfer is always last.
# (//td[...]) [last()] ensures we get the last row's View button, not the first.
iTransferViewApplicationBtn         = (//td[contains(@class,'cdk-column-detailsButton')]//button[normalize-space()='View'])[last()]


// ── Log transfer table row count then click last View button ─────────────────────
// Table may have multiple rows (same herd, multiple transfer types/states).
// The last row is always the most recently created transfer — that is the target.
// [last()] in the locator guarantees the correct row regardless of how many exist.
List<WebElement> iTransferRows = getDriver().findElements(
        By.xpath("//tr[contains(@class,'mat-mdc-row')]"));
log.info("[TRANSFER] Transfer table row count: " + iTransferRows.size()
        + " — clicking View on last row.");

iAction("WAITVISIBLE",   "XPATH", ObjReader.getLocator("iTransferViewApplicationBtn"), null);
iAction("WAITCLICKABLE", "XPATH", ObjReader.getLocator("iTransferViewApplicationBtn"), null);
iAction("CLICK",         "XPATH", ObjReader.getLocator("iTransferViewApplicationBtn"), null);

log.info("[TRANSFER] Last row View clicked — row " + iTransferRows.size() + " of "
        + iTransferRows.size());
