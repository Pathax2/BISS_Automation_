// =====================================================================================================================================
// File          : StaffSteps.java
// Purpose       : Single consolidated step definition library for every BISS internal (staff) portal feature:
//                 MAPS, SIM, CORRESPONDENCE, PAYMENTS, SCHEME, ACTIVE FARMER, AMS and OPENSHIFT.
//
// Common Background : All staff features log in through the internal portal (CENTEST or OpenShift), open the
//                     BISS application, and then work from the Home screen or a named tab. The login and
//                     application-open steps are shared by every feature in this library.
//
// DB Data       : Herds, parcels and reference numbers are resolved from the Oracle DB by the @staffdata hook
//                 in Hooks.java, which runs before any scenario tagged @staffdata and populates the pools
//                 below. Feature files never name a row index - they ask for "the next submitted herd" and
//                 this class pops the next unused value off the relevant pool. That keeps sections independent
//                 and the features free of Excel-era row references.
//
// Notes         : - Declarative step wording. A single business step (e.g. "requests a map with the following
//                   settings") performs the whole UI interaction sequence internally, so the feature files
//                   describe intent and this class owns the mechanics.
//                 - Staff usernames stay hardcoded in the features: they are permission fixtures, not test
//                   data. Each carries a specific role the scenario depends on.
//                 - Passwords resolve from TestData.xlsx via the "TD:Password" mechanism.
//
// Author        : Aniket Pathare | aniket.pathare@government.ie
// Date Created  : 15-07-2026
// =====================================================================================================================================
public class StaffSteps
{
    // =================================================================================================================================
    // SECTION 1 : Runtime data pools and cursors
    // =================================================================================================================================
    // The @staffdata hook fills these. Each cursor tracks how far through its pool the scenario has walked, so
    // "the next submitted herd" hands back a different herd each time it is called within one scenario.

    private int iSubmittedHerdCursor  = 0;
    private int iPenaltyHerdCursor    = 0;
    private int iNoAmendHerdCursor    = 0;
    private int iAdminCheckHerdCursor = 0;
    private int iQueryLetterCursor    = 0;
    private int iSimOptedHerdCursor   = 0;
    private int iParcelCursor         = 0;
    private int iReferenceCursor      = 0;

    // Holds the value most recently taken from a pool, so a step can re-use the SAME herd rather than advance
    // to the next one. Needed where legacy deliberately re-visits one herd across several scheme years.
    private String iCurrentHerd = null;

    // ---------------------------------------------------------------------------------------------------------------------------------
    // Function Name : iNextFromPool
    // Description   : Returns the next unused value from a runtime pool and advances the cursor. Fails loudly
    //                 rather than wrapping around - a scenario asking for more herds than the query returned is
    //                 a data problem that must surface, not be silently masked by re-using row 1.
    // Parameters    : pPool      (List<String>) - the resolved pool from Hooks
    //                 pCursor    (int)          - current position
    //                 pPoolName  (String)       - for the error message
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ---------------------------------------------------------------------------------------------------------------------------------
    private String iNextFromPool(List<String> pPool, int pCursor, String pPoolName)
    {
        if (pPool == null || pPool.isEmpty())
        {
            throw new IllegalStateException("Runtime pool '" + pPoolName + "' is empty. Check the @staffdata tag on the feature and the " + "corresponding DBRouter query returned rows.");
        }

        if (pCursor >= pPool.size())
        {
            throw new IllegalStateException("Scenario requested more values from pool '" + pPoolName + "' than the query returned (" + pPool.size() + "). Increase the count in the feature tag, e.g. @herds:10:submitted.");
        }

        return pPool.get(pCursor);
    }

