    // ***************************************************************************************************************************************************************************************
    // Step          : the agent completes the qualification details (DataTable)
    // Description   : Fills the qualification form from DataTable key-value pairs.
    //                 All UI interactions use ObjReader keys — no hardcoded XPaths.
    //                 Date of completion: mat-datepicker is disabled by default — injected via JS.
    //
    //                 Keys: hasQualification (Yes/No), dateOfCompletion, certificateAwarded,
    //                       college, customCollege, qualification, customQualification
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026
    // ***************************************************************************************************************************************************************************************
    @When("the agent completes the qualification details")
    public void theAgentCompletesTheQualificationDetails(DataTable pDataTable)
    {
        log.info("[STEP] When the agent completes the qualification details");
        Map<String, String> iData = pDataTable.asMap(String.class, String.class);

        // ── Has qualification — formcontrolname="selectedValueQualification" ─────────────
        String iHasQual    = iData.getOrDefault("hasQualification", "Yes").trim();
        String iHasQualXp  = ObjReader.getLocator("iNRCISYFHasQualRadio")
                .replace("{value}", iHasQual);
        iAction("WAITVISIBLE", "XPATH", iHasQualXp, null);
        iAction("CLICK",       "XPATH", iHasQualXp, null);

        if ("No".equalsIgnoreCase(iHasQual))
        {
            log.info("[TC13] hasQualification=No — no further fields needed.");
            return;
        }

        // ── Date of completion — mat-datepicker (disabled by default — JS inject) ─────────
        if (iData.containsKey("dateOfCompletion"))
        {
            String iDateValue = iData.get("dateOfCompletion").trim();
            try
            {
                WebElement iDateInput = getDriver().findElement(
                        By.xpath(ObjReader.getLocator("iNRCISYFDateOfCompletionInput")));
                JavascriptExecutor iJs = (JavascriptExecutor) getDriver();
                iJs.executeScript("arguments[0].removeAttribute('disabled');",            iDateInput);
                iJs.executeScript("arguments[0].value = arguments[1];",                   iDateInput, iDateValue);
                iJs.executeScript("arguments[0].dispatchEvent(new Event('input',  {bubbles:true}));", iDateInput);
                iJs.executeScript("arguments[0].dispatchEvent(new Event('change', {bubbles:true}));", iDateInput);
                log.info("[TC13] Date of completion set via JS: " + iDateValue);
            }
            catch (Exception e)
            {
                log.warning("[TC13] Could not set date of completion: " + e.getMessage());
            }
        }

        // ── Certificate awarded — formcontrolname="certificateHasBeenAwarded" ─────────────
        if (iData.containsKey("certificateAwarded"))
        {
            String iCert    = iData.get("certificateAwarded").trim();
            String iCertXp  = ObjReader.getLocator("iNRCISYFCertAwardedRadio")
                    .replace("{value}", iCert);
            iAction("WAITVISIBLE", "XPATH", iCertXp, null);
            iAction("CLICK",       "XPATH", iCertXp, null);
        }

        // ── College dropdown — formcontrolname="colId" ────────────────────────────────────
        if (iData.containsKey("college"))
        {
            iAction("LIST", "XPATH",
                    ObjReader.getLocator("iNRCISYFCollegeDropdown"),
                    iData.get("college").trim());
        }

        // ── Custom college free-text — rendered when "not in list" selected ───────────────
        if (iData.containsKey("customCollege"))
        {
            iAction("TEXTBOX", "XPATH",
                    ObjReader.getLocator("iNRCISYFCustomCollegeField"),
                    iData.get("customCollege").trim());
        }

        // ── Qualification dropdown — formcontrolname="qualId" ─────────────────────────────
        if (iData.containsKey("qualification"))
        {
            iAction("LIST", "XPATH",
                    ObjReader.getLocator("iNRCISYFQualificationDropdown"),
                    iData.get("qualification").trim());
        }

        // ── Custom qualification free-text ────────────────────────────────────────────────
        if (iData.containsKey("customQualification"))
        {
            iAction("TEXTBOX", "XPATH",
                    ObjReader.getLocator("iNRCISYFCustomQualificationField"),
                    iData.get("customQualification").trim());
        }

        log.info("[TC13] Qualification details completed | college="
                + iData.getOrDefault("college", "N/A"));
    }


