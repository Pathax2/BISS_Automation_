@Then("the application should be submitted successfully")
public void theApplicationShouldBeSubmittedSuccessfully()
{
    log.info("[STEP] Then the application should be submitted successfully");

    // ── After submission the portal redirects back to the My Clients dashboard ──
    // The submitted herd appears as the first row in the client list table.
    // The BISS Application Status chip for that row should read "Submitted".
    // Scoped to the first client-list-element-row to confirm OUR submission —
    // not just any submitted row that might exist from a previous run.
    String iStatusXpath =
        "(//tr[contains(@class,'client-list-element-row')]" +
        "//div[contains(@class,'chip-style')])[1]";

    String iConfirmation = iAction("GETTEXT", "XPATH", iStatusXpath, null);

    Assertions.assertTrue(
        iConfirmation.trim().equalsIgnoreCase("Submitted"),
        "Expected first row status to be 'Submitted' but found: '" + iConfirmation + "'");

    log.info("✅ Application submitted successfully | Status confirmed: " + iConfirmation);
}

