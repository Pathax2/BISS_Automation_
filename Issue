SELECT v.LVL_YEAR,
       v.LVL_HERD_NO,
       v.LVL_LNU_ID,
       v.LVL_SUB_DIV_NO,
       v.LVL_COMMONAGE_ID,
       v.LVT_DESC,
       v.LVC_DESC,
       v.LVS_DESC,
       v.VDS_SRC_DESC,
       v.LVL_SOURCE_ID,
       (
           SELECT ui.uri_username
           FROM   BPS_CONNECT.tdcr_user_info        ui
           JOIN   BPS_CONNECT.tdco_customer_asscs   ca  ON ca.ca_bcus_id_from = abcus.bcus_id
           JOIN   BPS_CONNECT.tdco_business_customers abcus ON ca.ca_bcus_id_from = abcus.bcus_id
           JOIN   BPS_CONNECT.tdco_business_customers hbcus ON ca.ca_bcus_id_to   = hbcus.bcus_id
           WHERE  hbcus.bcus_bus_id          = v.LVL_HERD_NO
           AND    ui.uri_ccs_bus_id          = abcus.bcus_bus_id
           AND    SYSDATE BETWEEN ca.ca_start_date AND ca.ca_end_date
           AND    ca.ca_cac_code             = 194
           AND    ROWNUM                     = 1
       ) AS LOGIN_ID
FROM (
    SELECT LVL_YEAR,
           LVL_HERD_NO,
           LVL_LNU_ID,
           LVL_SUB_DIV_NO,
           LVL_COMMONAGE_ID,
           LVT_DESC,
           LVC_DESC,
           LVS_DESC,
           VDS_SRC_DESC,
           LVL_SOURCE_ID,
           ROW_NUMBER() OVER (
               PARTITION BY LVC_DESC
               ORDER BY     LVL_HERD_NO
           ) AS RN
    FROM   BISS_DATA.vwbs_land_validation
    WHERE  LVL_YEAR = 2026
    AND    LVT_DESC = 'Preliminary Check'
    AND    LVC_DESC IN ('Agricultural Activity', 'Dual claim', 'Overclaim')
) v
WHERE v.RN = 1
ORDER BY
    CASE v.LVC_DESC
        WHEN 'Agricultural Activity' THEN 1
        WHEN 'Dual claim'            THEN 2
        WHEN 'Overclaim'             THEN 3
    END;
