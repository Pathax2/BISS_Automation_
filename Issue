# ── Land Details | Edit Parcel Drawer — Mandatory Field Locators ──────────────────────────────────

# Date input with red border — only visible when Ownership Status is Rented In or Leased In
iRentalExpiryDateInput=//mat-dialog-container//input[@placeholder='DD/MM/YYYY']

# Red "Required" validation label below Agricultural Activity dropdown
iAgriculturalActivityRequired=//mat-dialog-container//*[contains(normalize-space(),'Required') and ancestor::*[contains(@class,'agricultural')]]

# Agricultural Activity dropdown inside Edit Parcel drawer
iAgriculturalActivitySelect=//mat-dialog-container//*[@formcontrolname='agriculturalActivity']

# Organic Status dropdown — targeted only when currently unset (no selected value)
iOrganicStatusEmpty=//mat-dialog-container//*[@formcontrolname='organicStatus' and not(.//*[normalize-space()!=''])]

# Confirms a row icon has been cleared to check_circle after save — used to verify fix was applied
iLandTableNoErrorRows=//mat-mdc-row[.//mat-icon[normalize-space()='check_circle']]
