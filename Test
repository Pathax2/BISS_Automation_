# ===================================================================================================================================
# SECTION : STAFF PORTAL — MAPS area additional locators
# {ATTR} herd/generated-map attribute   {LABEL} paginator aria-label
# Spot-check against live DOM; values follow existing Angular Material conventions.
# ===================================================================================================================================

# Herd attribute (name/address) shown after a herd search — {ATTR} = logical field
iStaffHerdAttribute                 = //*[@data-field='{ATTR}'] | //span[contains(@class,'herd-{ATTR}')]

# Generated-map metadata cell in the results table — {ATTR} = status/id/herdNumber/date
iStaffGeneratedMapAttribute         = //table[contains(@class,'mdc-data-table') or @id='generated-maps-table']//td[@data-column='{ATTR}']

# Generated-map final/ready status indicator in the results table
iStaffGeneratedMapFinalStatus       = //td[@data-column='status'][normalize-space()='Ready to download'] | //span[contains(@class,'status')][normalize-space()='Complete']

# First "Ready to download" link in the generated maps table
iStaffReadyToDownloadFirst          = (//a[normalize-space()='Ready to download'])[1]

# Paginator button by aria-label — {LABEL} = "Next page"/"Previous page"
iStaffPaginationButton              = //button[@aria-label='{LABEL}']

# Generate Map Setting section container (visible after a successful parcel search)
iStaffGenerateMapSettingSection     = //*[normalize-space()='Generate Map Settings'] | //section[contains(@class,'generate-map-settings')]
