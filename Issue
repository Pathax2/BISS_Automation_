# ── Agricultural Activity — dual-context locators ─────────────────────────────────────────────────

# Required error — covers both Edit Parcel drawer (error text "Required")
# and Add Plot dialog (error text "Please select an agricultural activity.")
# Anchored on the mat-form-field containing any element with formcontrolname='agriculturalActivity'
iAgriculturalActivityRequired=//mat-form-field[.//*[@formcontrolname='agriculturalActivity']]//mat-error

# mat-select trigger — covers both:
#   Edit Parcel drawer: mat-select[@formcontrolname='agriculturalActivity'] (direct)
#   Add Plot dialog:    lib-biss-select-search[@formcontrolname='agriculturalActivity']//mat-select (wrapped)
iAgriculturalActivitySelect=(//mat-select[@formcontrolname='agriculturalActivity'] | //lib-biss-select-search[@formcontrolname='agriculturalActivity']//mat-select)[1]
