    // ***************************************************************************************************************************************************************************************
    // Step          : the agent resets all category selections
    // Description   : Iterates all mat-checkbox elements inside the dialog and unchecks any
    //                 currently selected. State check via mat-mdc-checkbox-checked class (reliable
    //                 for Angular Material 2+). Uncheck via JS click on native input to avoid
    //                 ripple overlay interception.
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026
    // ***************************************************************************************************************************************************************************************
    @And("the agent resets all category selections")
    public void theAgentResetsAllCategorySelections()
    {
        log.info("[STEP] And the agent resets all category selections");

        List<WebElement> iCheckboxes = getDriver().findElements(
                By.xpath(ObjReader.getLocator("iNRCISYFCategoryCheckboxes")));

        if (iCheckboxes.isEmpty())
        {
            log.warning("[TC13] No category checkboxes found — dialog may not be open.");
            return;
        }

        int iUnchecked = 0;
        for (WebElement iCb : iCheckboxes)
        {
            try
            {
                // Angular Material mat-mdc-checkbox-checked class is the reliable state indicator
                String iClass      = iCb.getAttribute("class");
                boolean iIsChecked = iClass != null
                        && iClass.contains("mat-mdc-checkbox-checked");

                if (iIsChecked)
                {
                    // Click native input via JS — avoids ripple/touch-target interception
                    WebElement iNative = iCb.findElement(
                            By.xpath(".//input[@type='checkbox']"));
                    ((JavascriptExecutor) getDriver())
                            .executeScript("arguments[0].click();", iNative);
                    iUnchecked++;
                    log.info("[TC13] Unchecked: "
                            + iCb.getText().trim().replaceAll("\\s+", " "));
                }
            }
            catch (Exception e)
            {
                log.warning("[TC13] Could not reset checkbox: " + e.getMessage());
            }
        }
        log.info("[TC13] Reset complete — unchecked " + iUnchecked
                + " of " + iCheckboxes.size());
    }


    // ***************************************************************************************************************************************************************************************
    // Step          : the agent selects NRCISYF categories (DataTable)
    // Description   : Selects each category in the DataTable by clicking its mdc-label via ObjReader.
    //                 Resolves formcontrolname from A./B./C. prefix — immune to label text changes.
    //                 State check via mat-mdc-checkbox-checked class before clicking.
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026
    // ***************************************************************************************************************************************************************************************
    @And("the agent selects NRCISYF categories")
    public void theAgentSelectsNRCISYFCategories(DataTable pDataTable)
    {
        log.info("[STEP] And the agent selects NRCISYF categories");

        List<String> iCategories = pDataTable.asList();

        for (String iCategory : iCategories)
        {
            String iClean = iCategory.trim();
            log.info("[TC13] Selecting: " + iClean);

            // Resolve ObjReader label key and checkbox key from A./B./C. prefix
            String iLabelKey;
            String iCheckboxKey;

            if      (iClean.startsWith("A."))
            {
                iLabelKey    = "iNRCISYFCatALabel";
                iCheckboxKey = "iNRCISYFCatACheckbox";
            }
            else if (iClean.startsWith("B."))
            {
                iLabelKey    = "iNRCISYFCatBLabel";
                iCheckboxKey = "iNRCISYFCatBCheckbox";
            }
            else if (iClean.startsWith("C."))
            {
                iLabelKey    = "iNRCISYFCatCLabel";
                iCheckboxKey = "iNRCISYFCatCCheckbox";
            }
            else
            {
                log.warning("[TC13] No A/B/C prefix — skipping unknown category: " + iClean);
                continue;
            }

            // Skip if already selected (mat-mdc-checkbox-checked class)
            try
            {
                WebElement iMatCb = getDriver().findElement(
                        By.xpath(ObjReader.getLocator(iCheckboxKey)));
                String iClass = iMatCb.getAttribute("class");
                if (iClass != null && iClass.contains("mat-mdc-checkbox-checked"))
                {
                    log.info("[TC13] '" + iClean + "' already selected — skipping.");
                    continue;
                }
            }
            catch (Exception ignored) {}

            // Click label — fires Angular binding without ripple interception
            String iLabelXpath = ObjReader.getLocator(iLabelKey);
            iAction("WAITVISIBLE",   "XPATH", iLabelXpath, null);
            iAction("WAITCLICKABLE", "XPATH", iLabelXpath, null);
            iAction("CLICK",         "XPATH", iLabelXpath, null);
            log.info("[TC13] Selected: " + iClean);
        }
    }


