    // ***************************************************************************************************************************************************************************************
    // Step          : the agent resets all category selections
    // Description   : Iterates through all category mat-checkboxes and unchecks any that are selected.
    //                 FIX 6: Uses ObjReader iNRCISYFCategoryCheckboxes — not hardcoded cssSelector.
    //                 State check: class contains "mat-mdc-checkbox-checked" OR aria-checked="true".
    //                 Uncheck: clicks native input[@type='checkbox'] inside the mat-checkbox.
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026 | Updated : 21-05-2026
    // ***************************************************************************************************************************************************************************************
    @And("the agent resets all category selections")
    public void theAgentResetsAllCategorySelections()
    {
        log.info("[STEP] And the agent resets all category selections");

        List<WebElement> iCheckboxes = getDriver().findElements(
                By.xpath(ObjReader.getLocator("iNRCISYFCategoryCheckboxes")));

        if (iCheckboxes.isEmpty())
        {
            log.warning("[TC13] No category checkboxes found — dialog may not be open.");
            return;
        }

        int iUnchecked = 0;
        for (WebElement iCb : iCheckboxes)
        {
            try
            {
                // Check state via class (mat-mdc-checkbox-checked) or aria-checked
                String iClass       = iCb.getAttribute("class");
                String iAriaChecked = iCb.getAttribute("aria-checked");
                boolean iIsChecked  = (iClass != null && iClass.contains("mat-mdc-checkbox-checked"))
                        || "true".equalsIgnoreCase(iAriaChecked);

                if (iIsChecked)
                {
                    // Click native input to uncheck — avoids ripple interception
                    WebElement iNativeInput = iCb.findElement(By.xpath(".//input[@type='checkbox']"));
                    ((JavascriptExecutor) getDriver())
                            .executeScript("arguments[0].click();", iNativeInput);
                    iUnchecked++;
                    log.info("[TC13] Unchecked: " + iCb.getText().trim().replaceAll("\\s+", " "));
                }
            }
            catch (Exception e)
            {
                log.warning("[TC13] Could not reset checkbox: " + e.getMessage());
            }
        }
        log.info("[TC13] Reset complete — unchecked " + iUnchecked + " of " + iCheckboxes.size());
    }


    // ***************************************************************************************************************************************************************************************
    // Step          : the agent selects NRCISYF categories (DataTable)
    // Description   : Selects each category from the DataTable by clicking its mdc-label.
    //                 FIX 5: Replaced CHECKBOX action with CLICK on label via ObjReader keys.
    //                 Resolves formcontrolname from A./B./C. prefix — immune to label text changes.
    //                 State check via mat-mdc-checkbox-checked class before clicking.
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026 | Updated : 21-05-2026
    // ***************************************************************************************************************************************************************************************
    @And("the agent selects NRCISYF categories")
    public void theAgentSelectsNRCISYFCategories(DataTable pDataTable)
    {
        log.info("[STEP] And the agent selects NRCISYF categories");

        List<String> iCategories = pDataTable.asList();

        for (String iCategory : iCategories)
        {
            String iClean = iCategory.trim();
            log.info("[TC13] Selecting: " + iClean);

            // Resolve label + checkbox ObjReader key from A./B./C. prefix
            String iLabelKey;
            String iCheckboxKey;
            if      (iClean.startsWith("A.")) { iLabelKey = "iNRCISYFCatALabel"; iCheckboxKey = "iNRCISYFCatACheckbox"; }
            else if (iClean.startsWith("B.")) { iLabelKey = "iNRCISYFCatBLabel"; iCheckboxKey = "iNRCISYFCatBCheckbox"; }
            else if (iClean.startsWith("C.")) { iLabelKey = "iNRCISYFCatCLabel"; iCheckboxKey = "iNRCISYFCatCCheckbox"; }
            else
            {
                // Fallback — match by label text
                log.warning("[TC13] No A/B/C prefix — falling back to text match: " + iClean);
                iLabelKey    = null;
                iCheckboxKey = null;
            }

            // Check current state — skip if already selected
            if (iCheckboxKey != null)
            {
                try
                {
                    WebElement iMatCb = getDriver().findElement(
                            By.xpath(ObjReader.getLocator(iCheckboxKey)));
                    String iClass = iMatCb.getAttribute("class");
                    if (iClass != null && iClass.contains("mat-mdc-checkbox-checked"))
                    {
                        log.info("[TC13] Category already selected — skipping: " + iClean);
                        continue;
                    }
                }
                catch (Exception ignored) {}
            }

            // Click the label (stable — avoids ripple interception)
            String iClickXpath = (iLabelKey != null)
                    ? ObjReader.getLocator(iLabelKey)
                    : "//label[contains(normalize-space(),'" + iClean + "')]";

            iAction("WAITVISIBLE",   "XPATH", iClickXpath, null);
            iAction("WAITCLICKABLE", "XPATH", iClickXpath, null);
            iAction("CLICK",         "XPATH", iClickXpath, null);
            log.info("[TC13] Selected: " + iClean);
        }
    }


