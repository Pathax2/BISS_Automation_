    // ***************************************************************************************************************************************************************************************
    // Function Name : performList
    // Description   : Handles both native HTML <select> elements AND Angular Material <mat-select> components.
    //
    //                 Detection: reads the element tag name after finding it.
    //                   "select"     → native HTML → Selenium Select class
    //                   "mat-select" → Angular MDC → performMatSelect() click-based approach
    //                   other        → fallback to performMatSelect()
    //
    //                 Supported value prefixes (same for both types):
    //                   VISIBLETEXT:value  → match by visible option text (default)
    //                   VALUE:value        → native select only; treated as VISIBLETEXT for mat-select
    //                   INDEX:n            → select by 0-based index
    //                   plain text         → treated as VISIBLETEXT
    // ***************************************************************************************************************************************************************************************
    private static void performList(WebDriver pDriver, WebDriverWait pWait, By pBy, String pValue)
    {
        if (pValue == null || pValue.trim().isEmpty())
        {
            throw new RuntimeException("LIST action requires a selection value.");
        }

        waitForAngularReady(pDriver);

        WebElement iElement = pWait.until(ExpectedConditions.visibilityOfElementLocated(pBy));
        pWait.until(ExpectedConditions.elementToBeClickable(iElement));
        scrollIntoView(pDriver, iElement);
        highlightElement(pDriver, iElement);

        String iTagName   = iElement.getTagName().toLowerCase().trim();
        String iListValue = pValue.trim();

        log.info("[" + getCurrentTimestamp() + "] LIST | tag=<" + iTagName + "> | value=" + iListValue);

        if ("mat-select".equals(iTagName))
        {
            performMatSelect(pDriver, pWait, iElement, iListValue);
        }
        else if ("select".equals(iTagName))
        {
            pWait.until(iWebDriver -> new Select(iElement).getOptions().size() > 0);
            performNativeSelect(iElement, iListValue);
            waitForAngularReady(pDriver);
        }
        else
        {
            log.warning("[" + getCurrentTimestamp() + "] LIST | Unexpected tag <" + iTagName + "> — attempting mat-select approach.");
            performMatSelect(pDriver, pWait, iElement, iListValue);
        }
    }

    // ***************************************************************************************************************************************************************************************
    // Function Name : performMatSelect
    // Description   : Selects an option from an Angular Material <mat-select> component.
    //
    //                 How MDC mat-select works:
    //                   1. Click the mat-select trigger → opens <div role="listbox"> overlay at body level
    //                   2. Wait for overlay panel to appear
    //                   3. Match <mat-option> by text or index
    //                   4. Click the mat-option → panel closes automatically
    //                   5. Wait for Angular to process the selection change event
    // ***************************************************************************************************************************************************************************************
    private static void performMatSelect(WebDriver pDriver, WebDriverWait pWait,
                                         WebElement pElement, String pValue)
    {
        // Step 1: Click trigger to open panel — Angular ready check before click
        waitForAngularReady(pDriver);
        pElement.click();

        // Step 2: Wait for overlay panel — injected at body level, NOT inside mat-select
        By iPanelBy = By.cssSelector(
                "div[role='listbox'].mat-mdc-select-panel, " +
                "div[role='listbox'].mdc-menu-surface--open, " +
                "div[role='listbox']");

        WebElement iPanel = pWait.until(ExpectedConditions.visibilityOfElementLocated(iPanelBy));
        log.info("[" + getCurrentTimestamp() + "] MAT-SELECT | Panel opened.");

        String iUpperValue = pValue.toUpperCase();

        if (iUpperValue.startsWith("INDEX:"))
        {
            // ── INDEX selection ───────────────────────────────────────────────────────────
            int iIndex = Integer.parseInt(pValue.substring("INDEX:".length()).trim());

            List<WebElement> iOptions = pWait.until(iWebDriver ->
            {
                List<WebElement> iOpts = iPanel.findElements(By.cssSelector("mat-option"));
                return iOpts.size() > iIndex ? iOpts : null;
            });

            WebElement iTarget = iOptions.get(iIndex);
            scrollIntoView(pDriver, iTarget);
            highlightElement(pDriver, iTarget);
            iTarget.click();
            log.info("[" + getCurrentTimestamp() + "] MAT-SELECT | Selected by INDEX: " + iIndex);
        }
        else
        {
            // ── VISIBLETEXT / VALUE / plain text ──────────────────────────────────────────
            String iTargetText;

            if (iUpperValue.startsWith("VISIBLETEXT:"))
            {
                iTargetText = pValue.substring("VISIBLETEXT:".length()).trim();
            }
            else if (iUpperValue.startsWith("VALUE:"))
            {
                iTargetText = pValue.substring("VALUE:".length()).trim();
                log.warning("[" + getCurrentTimestamp() + "] MAT-SELECT | VALUE: prefix on mat-select — "
                        + "treating as VISIBLETEXT: '" + iTargetText + "'");
            }
            else
            {
                iTargetText = pValue.trim();
            }

            final String iFinalTarget = iTargetText;

            // Wait until options are present in the panel
            pWait.until(iWebDriver -> iPanel.findElements(By.cssSelector("mat-option")).size() > 0);

            // Find the matching mat-option by trimmed text — handles Angular's whitespace padding
            WebElement iTargetOption = pWait.until(iWebDriver ->
            {
                List<WebElement> iOptions = iPanel.findElements(By.cssSelector("mat-option"));
                for (WebElement iOption : iOptions)
                {
                    try
                    {
                        if (iOption.getText().trim().equalsIgnoreCase(iFinalTarget))
                        {
                            return iOption;
                        }
                    }
                    catch (StaleElementReferenceException ignored) {}
                }
                return null;
            });

            if (iTargetOption == null)
            {
                pressEscape(pDriver);
                throw new RuntimeException("MAT-SELECT | Option not found : '" + iFinalTarget
                        + "' — verify the exact visible text in the panel.");
            }

            scrollIntoView(pDriver, iTargetOption);
            highlightElement(pDriver, iTargetOption);
            iTargetOption.click();
            log.info("[" + getCurrentTimestamp() + "] MAT-SELECT | Selected by text: '" + iFinalTarget + "'");
        }

        // Step 5: Wait for panel to close + Angular to process selection change
        try
        {
            pWait.until(ExpectedConditions.invisibilityOfElementLocated(
                    By.cssSelector("div[role='listbox'].mdc-menu-surface--open")));
        }
        catch (TimeoutException ignored)
        {
            // Panel may have already closed — continue
        }

        waitForAngularReady(pDriver);
        log.info("[" + getCurrentTimestamp() + "] MAT-SELECT | Selection complete and Angular stable.");
    }

    // ***************************************************************************************************************************************************************************************
    // Function Name : performNativeSelect
    // Description   : Handles standard HTML <select> elements using Selenium Select class
    // ***************************************************************************************************************************************************************************************
    private static void performNativeSelect(WebElement pElement, String pListValue)
    {
        Select iSelect     = new Select(pElement);
        String iUpperValue = pListValue.toUpperCase();

        if (iUpperValue.startsWith("VISIBLETEXT:"))
        {
            iSelect.selectByVisibleText(pListValue.substring("VISIBLETEXT:".length()).trim());
        }
        else if (iUpperValue.startsWith("VALUE:"))
        {
            iSelect.selectByValue(pListValue.substring("VALUE:".length()).trim());
        }
        else if (iUpperValue.startsWith("INDEX:"))
        {
            iSelect.selectByIndex(Integer.parseInt(pListValue.substring("INDEX:".length()).trim()));
        }
        else
        {
            iSelect.selectByVisibleText(pListValue);
        }

        log.info("[" + getCurrentTimestamp() + "] NATIVE SELECT | Selected: '" + pListValue + "'");
    }

