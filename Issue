SELECT table_name, column_name, data_type
FROM all_tab_columns
WHERE column_name LIKE '%EXPIR%'
AND table_name NOT LIKE '%$%'
ORDER BY table_name, column_id;

SELECT COUNT(*) as total,
       SUM(CASE WHEN app_submitted_date IS NULL THEN 1 ELSE 0 END) as not_submitted,
       SUM(CASE WHEN app_submitted_date IS NOT NULL THEN 1 ELSE 0 END) as submitted
FROM vwbs_application
WHERE mde_abbrev = 'RI'
AND app_year = 2026;
