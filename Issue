iAgriculturalActivityRequired=//mat-select[@formcontrolname='agriculturalActivity']/ancestor::mat-form-field//mat-error[contains(normalize-space(),'Required')]

# Agricultural Activity mat-select trigger inside Edit Parcel drawer
iAgriculturalActivitySelect=//mat-select[@formcontrolname='agriculturalActivity']

// ── 3. Agricultural Activity ─────────────────────────────────────────────
// Plain mat-select with formcontrolname='agriculturalActivity'
