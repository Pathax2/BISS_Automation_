-- Check 1: what aph_cust_id value exists for J1994001
SELECT a.app_herd_no, a.aph_cust_id, a.aph_app_id, a.mde_abbrev
FROM vwbs_application_herd a
WHERE a.app_herd_no = 'J1994001'
AND a.app_year = 2026
AND a.mde_abbrev = 'I';

-- Check 2: what sph_sps_holding_id exists in TDSP for J1994001
SELECT yfs.sph_sps_holding_id, yfs.yfs_application_year
FROM tdsp_young_farmer_summary yfs
WHERE yfs.yfs_application_year = 2026
AND ROWNUM <= 5;
