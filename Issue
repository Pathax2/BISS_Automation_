@When("the agent provides responses for all parcels on the Prelim Checks screen")
public void theAgentProvidesResponsesForAllParcels()
{
    log.info("[STEP] Provide responses for all parcels");

    // Find all response dropdowns/radio buttons on the Prelim Checks screen and select a response
    List<WebElement> iResponseControls = getDriver().findElements(
            By.xpath(ObjReader.getLocator("iPrelimChecksResponseControls")));

    for (int i = 0; i < iResponseControls.size(); i++)
    {
        try
        {
            WebElement iControl = iResponseControls.get(i);
            if (!iControl.isDisplayed()) continue;

            // Click the control to open it, then select the first available option
            iControl.click();
            iAction("WAITVISIBLE", "XPATH", ObjReader.getLocator("iMatSelectOpenPanel"), null);
            iAction("CLICK", "XPATH",
                    "(//mat-option)[1] | (//mat-radio-button)[1]", null);
            log.info("Response provided for parcel " + (i + 1));
        }
        catch (Exception e)
        {
            log.warning("Could not provide response for parcel " + (i + 1) + ": " + e.getMessage());
        }
    }
    log.info("All parcels responded to.");
}


@When("the agent clears one parcel response to make submission incomplete")
public void theAgentClearsOneParcelResponse()
{
    log.info("[STEP] Clear one parcel response to make submission incomplete");
    // Click the first response control and clear its selection
    try
    {
        iAction("CLICK", "XPATH",
                "(" + ObjReader.getLocator("iPrelimChecksResponseControls") + ")[1]", null);
        iAction("WAITVISIBLE", "XPATH", ObjReader.getLocator("iMatSelectOpenPanel"), null);
        // Select a blank/no-response option if available, or click outside to deselect
        try { iAction("CLICK", "XPATH", "//mat-option[contains(normalize-space(),'Select')]", null); }
        catch (Exception e) { getDriver().findElement(By.tagName("body")).click(); }
    }
    catch (Exception e)
    {
        log.warning("Could not clear parcel response: " + e.getMessage());
    }
}


