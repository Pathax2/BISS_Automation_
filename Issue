    }


    // ***************************************************************************************************************************************************************************************
    // Step          : When the agent fills in the Add Plot form with the following details
    // Description   : DataTable-driven step that fills all fields in the Add Plot dialog.
    //                 Reads field values from the DataTable and calls the appropriate action per field.
    //
    //                 Supported DataTable keys:
    //                   county           — searchable mat-select (lib-biss-select-search)
    //                   townland         — searchable mat-select (depends on county being selected first)
    //                   plotReference    — text input
    //                   ownershipStatus  — standard mat-select
    //                   organicStatus    — standard mat-select
    //                   claimedArea      — number input
    //                   commonage        — checkbox: CHECK or UNCHECK
    //                   islandPlot       — checkbox: CHECK or UNCHECK
    //                   plotUse          — searchable mat-select (lib-biss-select-search)
    //                   mapAmendment     — radio button label text:
    //                                      "Edit Map Online" | "Upload Map" | "Submit Paper Map By Post"
    // ***************************************************************************************************************************************************************************************
    @When("the agent fills in the Add Plot form with the following details")
    public void theAgentFillsInTheAddPlotFormWithTheFollowingDetails(DataTable pDataTable)
    {
        log.info("[STEP] When the agent fills in the Add Plot form with the following details");

        Map<String, String> iFormData = pDataTable.asMap(String.class, String.class);

        // ── County — searchable mat-select ────────────────────────────────────────────────────
        if (iFormData.containsKey("county") && !iFormData.get("county").isBlank())
        {
            selectSearchableMatSelect(
                    "//lib-biss-select-search[@formcontrolname='county']//mat-select",
                    "//input[@placeholder='Enter county']",
                    iFormData.get("county")
            );
        }

        // ── Townland — searchable mat-select (disabled until county selected) ─────────────────
        if (iFormData.containsKey("townland") && !iFormData.get("townland").isBlank())
        {
            // Wait for townland to become enabled after county selection
            waitForMatSelectEnabled("//lib-biss-select-search[@formcontrolname='townland']//mat-select");

            selectSearchableMatSelect(
                    "//lib-biss-select-search[@formcontrolname='townland']//mat-select",
                    "//input[@placeholder='Enter townland']",
                    iFormData.get("townland")
            );
        }

        // ── Plot Reference — text input ───────────────────────────────────────────────────────
        if (iFormData.containsKey("plotReference") && !iFormData.get("plotReference").isBlank())
        {
            iAction("TEXTBOX", "XPATH", "//input[@id='plotReference']", iFormData.get("plotReference"));
        }

        // ── Ownership Status — standard mat-select ────────────────────────────────────────────
        if (iFormData.containsKey("ownershipStatus") && !iFormData.get("ownershipStatus").isBlank())
        {
            iAction("LIST", "XPATH", "//mat-select[@id='ownershipStatus']",
                    "VISIBLETEXT:" + iFormData.get("ownershipStatus"));
        }

        // ── Organic Status — standard mat-select ──────────────────────────────────────────────
        if (iFormData.containsKey("organicStatus") && !iFormData.get("organicStatus").isBlank())
        {
            iAction("LIST", "XPATH", "//mat-select[@id='organicStatus']",
                    "VISIBLETEXT:" + iFormData.get("organicStatus"));
        }

        // ── Claimed Area — number input ───────────────────────────────────────────────────────
        if (iFormData.containsKey("claimedArea") && !iFormData.get("claimedArea").isBlank())
        {
            iAction("TEXTBOX", "XPATH", "//input[@id='claimedArea']", iFormData.get("claimedArea"));
        }

        // ── Commonage Plot checkbox ───────────────────────────────────────────────────────────
        if (iFormData.containsKey("commonage") && !iFormData.get("commonage").isBlank())
        {
            iAction("CHECKBOX", "XPATH", "//input[@id='commonage-checkbox-input']",
                    iFormData.get("commonage").toUpperCase());
        }

        // ── Island Plot checkbox ──────────────────────────────────────────────────────────────
        if (iFormData.containsKey("islandPlot") && !iFormData.get("islandPlot").isBlank())
        {
            iAction("CHECKBOX", "XPATH", "//input[@id='island-checkbox-input']",
                    iFormData.get("islandPlot").toUpperCase());
        }

        // ── Plot Use — searchable mat-select ──────────────────────────────────────────────────
        if (iFormData.containsKey("plotUse") && !iFormData.get("plotUse").isBlank())
        {
            selectSearchableMatSelect(
                    "//lib-biss-select-search[@formcontrolname='plotUse']//mat-select",
                    "//lib-biss-select-search[@formcontrolname='plotUse']//input[contains(@class,'mat-select-search-input') and not(contains(@class,'mat-select-search-hidden'))]",
                    iFormData.get("plotUse")
            );
        }

        // ── Map Amendment Type — radio button ─────────────────────────────────────────────────
        if (iFormData.containsKey("mapAmendment") && !iFormData.get("mapAmendment").isBlank())
        {
            selectMapAmendmentRadio(iFormData.get("mapAmendment"));
        }

        // ── Screenshot after form is fully filled ─────────────────────────────────────────────
        CommonFunctions.addScreenshotToReport(Hooks.iDocument, Hooks.iDocPath, Hooks.iTestCaseID);
    }


