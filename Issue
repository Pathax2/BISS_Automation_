            iAction("WAITVISIBLE", "XPATH", ObjReader.getLocator("iMatSelectOpenPanel"), null);
            try { iAction("CLICK", "XPATH", "//mat-option[contains(normalize-space(),'Select')]", null); }
            catch (Exception e) { getDriver().findElement(By.tagName("body")).click(); }
        }
        catch (Exception e) { log.warning("Could not clear response: " + e.getMessage()); }
    }

