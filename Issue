    // ---------------------------------------------------------------------------------------------------------------------------------
    // Function Name : theSubmissionDetailsShouldShowLatePenaltiesAsFollows
    // Description   : Asserts each named scheme either DOES or DOES NOT carry a late penalty. This is the core of
    //                 the PAYMENTS category: BISS, CISYF and NR have separate deadlines, so a herd can be late for
    //                 one and on time for another. Flagging the wrong scheme means an applicant is docked money
    //                 they should keep - hence the positive AND negative checks in one table.
    // Parameters    : pPenalties (DataTable) - columns: scheme, penalty (yes/no)
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ---------------------------------------------------------------------------------------------------------------------------------
    @Then("the submission details should show late penalties as follows")
    public void theSubmissionDetailsShouldShowLatePenaltiesAsFollows(DataTable pPenalties)
    {
        List<Map<String, String>> iRows = pPenalties.asMaps(String.class, String.class);

        for (Map<String, String> iRow : iRows)
        {
            String iScheme       = iRow.get("scheme");
            String iExpectPenalty = iRow.get("penalty");

            String iErrorLocator = ObjReader.getLocator("iSubmissionDetailError").replace("{FIELD}", iScheme);

            List<WebElement> iErrors = getDriver().findElements(By.xpath(iErrorLocator));
            boolean iHasPenalty = !iErrors.isEmpty() && iErrors.get(0).isDisplayed();

            if ("yes".equalsIgnoreCase(iExpectPenalty) && !iHasPenalty)
            {
                throw new AssertionError(
                        "Expected a late penalty against '" + iScheme + "' but none is shown.");
            }

            if ("no".equalsIgnoreCase(iExpectPenalty) && iHasPenalty)
            {
                throw new AssertionError(
                        "A late penalty is shown against '" + iScheme + "' but none was expected. "
                                + "An applicant may be penalised for a scheme they submitted on time.");
            }
        }
    }

