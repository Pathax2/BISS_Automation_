    // Helper: resolves value from herdValue/parcelValue/referenceValue, enters it, selects year (if any), clicks Search.
    private void searchWithDetails(DataTable pDataTable, String pScreen)
    {
        Map<String, String> iData = pDataTable.asMap(String.class, String.class);
        String iField = iData.get("field").trim();
        String iValue = iData.containsKey("herdValue") ? iData.get("herdValue")
                      : iData.containsKey("parcelValue") ? iData.get("parcelValue")
                      : iData.get("referenceValue");
        iValue = (iValue == null) ? "" : iValue.trim();
        String iYear = iData.containsKey("schemeYear") ? iData.get("schemeYear").trim() : null;

        log.info("[STEP] Staff " + pScreen + " search - field=" + iField + ", value=" + iValue + ", year=" + iYear);
        staffEntersValueInField(iValue, iField);
        if (iYear != null) staffSelectsDropdownValueAs("schemeYear", iYear);
        staffClicksButton("Search");
    }

