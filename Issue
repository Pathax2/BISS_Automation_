# ── Eco AP Screen — Row and Toggle Locators ───────────────────────────────────────────────────────

# All AP rows that have a toggle button (mat-slide-toggle) — these are available for this herd
iEcoAPRowsWithToggle=//tr[contains(@class,'example-element-row')][.//mat-slide-toggle]

# The label cell inside an AP row — used to extract the AP code e.g. "AP1 - Space for Nature"
iEcoAPRowLabelCell=.//td[contains(@class,'mat-column-agriPractice')]

# The toggle switch button inside an AP row
iEcoAPToggleBtn=.//button[@role='switch']

# The expand/collapse arrow button inside an AP row
iEcoAPExpandBtn=.//button[@aria-label='expand row']

# Save & Select button inside an expanded AP panel
iEcoAPSaveAndSelectBtn=//button[.//span[normalize-space()='Save & select']]

# Counter label showing "X of 2 Selected" at the bottom of the Eco screen
iEcoAPSelectedCounter=//div[contains(@class,'message-block-1-message-2')]


# ── Eco AP Panel Fields — AP-specific locators ────────────────────────────────────────────────────

# AP1 — Space for Nature: Standard radio button
iEcoAP1_StandardRadio=//mat-radio-button[@value='AP1']//input[@type='radio']

# AP2 — Extensive Livestock Production: Standard stocking rate radio button
iEcoAP2_StandardRadio=//mat-radio-button[@value='AP2']//input[@type='radio']

# AP3 — Limiting Chemical Nitrogen Usage: confirmation checkbox
iEcoAP3_ConfirmCheckbox=//input[@type='checkbox'][ancestor::*[contains(text(),'Eco-Scheme Nitrates band')]]

# AP5 — GPS Controlled Fertiliser Spreader: "an approved GPS spreader" radio button
iEcoAP5_GPSSpreaderRadio=//input[@type='radio'][following-sibling::*[1][contains(text(),'approved GPS spreader')] or ancestor::label[contains(text(),'approved GPS spreader')]]

# AP5 — Approved Spreader dropdown trigger
iEcoAP5_ApprovedSpreaderDropdown=//mat-select[ancestor::*[contains(normalize-space(),'Approved Spreader')]]

# AP5 — First option in Approved Spreader dropdown (CDK overlay)
iMatSelectFirstOption=(//mat-option)[1]

# AP6 — Soil Sampling: first confirmation checkbox (information correct + obliged under NAP)
iEcoAP6_ConfirmCheckbox1=(//input[@type='checkbox'][ancestor::*[contains(@class,'eco-container')]])[1]

# AP6 — Soil Sampling: second confirmation checkbox (commit to soil samples)
iEcoAP6_ConfirmCheckbox2=(//input[@type='checkbox'][ancestor::*[contains(@class,'eco-container')]])[2]
