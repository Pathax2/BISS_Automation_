# =============================================================================================================================================================================================================================
#                                                                          SECTION 14 : NR / CISYF — CATEGORY DIALOG
#
#  All locators scoped to app-nr-cisyf-category-select-popup to avoid
#  conflicts with other dialogs on the page.
#
#  PLACEHOLDER CONVENTION:
#    {index}  replaced at runtime with 1 (Cat A), 2 (Cat B), or 3 (Cat C)
#             via String.replace("{index}", iIndex) in step definitions
#
#  formcontrolname reference:
#    nrYoungFarmer → Category A — National Reserve (as Young Farmer)
#    nrNewFarmer   → Category B — National Reserve (as New Farmer)
#    nrCisyf       → Category C — Complementary Income Support for Young Farmers
#
#  Author   : Aniket Pathare | aniket.pathare@government.ie
#  Updated  : 19-05-2026
# =============================================================================================================================================================================================================================


# ------------------------------------------------------------------------------------------------NR/CISYF — Dialog Root & Overlay------------------------------------------------------------------------------------------------

# Root component of the Select Category dialog — used for WAITINVISIBLE to confirm dialog closed
iNRCISYFDialogOverlay                 = //app-nr-cisyf-category-select-popup

# Dialog title header
iNRCISYFDialogTitle                   = //app-nr-cisyf-category-select-popup//mat-card-title[contains(normalize-space(),'Select Category')]


# ------------------------------------------------------------------------------------------------NR/CISYF — Info Icons (clickable mat-icon, toggles description)------------------------------------------------------------------------------------------------

# Indexed info icon (1=CatA, 2=CatB, 3=CatC) — mat-icon with class "icon", NOT a button
# Replace {index} at runtime: ObjReader.getLocator("iNRCISYFInfoIcon").replace("{index}", iIndex)
iNRCISYFInfoIcon                      = (//app-nr-cisyf-category-select-popup//mat-icon[contains(@class,'icon')])[{index}]

# Indexed description panel rendered below each checkbox after info icon click
# Replace {index} at runtime: ObjReader.getLocator("iNRCISYFInfoContent").replace("{index}", iIndex)
iNRCISYFInfoContent                   = (//app-nr-cisyf-category-select-popup//div[contains(@class,'info-categories')])[{index}]

# Cat A description panel (by formcontrolname — more stable than index)
iNRCISYFCatADescription               = //mat-checkbox[@formcontrolname='nrYoungFarmer']/following-sibling::div[contains(@class,'info-categories')]

# Cat B description panel
iNRCISYFCatBDescription               = //mat-checkbox[@formcontrolname='nrNewFarmer']/following-sibling::div[contains(@class,'info-categories')]

# Cat C description panel
iNRCISYFCatCDescription               = //mat-checkbox[@formcontrolname='nrCisyf']/following-sibling::div[contains(@class,'info-categories')]


# ------------------------------------------------------------------------------------------------NR/CISYF — Category Checkboxes------------------------------------------------------------------------------------------------

# All three category mat-checkbox elements — used by reset loop to uncheck all
iNRCISYFCategoryCheckboxes            = //app-nr-cisyf-category-select-popup//mat-checkbox

# Cat A native input — formcontrolname='nrYoungFarmer' — click native input for reliable Angular binding
iNRCISYFCatACheckbox                  = //mat-checkbox[@formcontrolname='nrYoungFarmer']//input[@type='checkbox']

# Cat B native input — formcontrolname='nrNewFarmer'
iNRCISYFCatBCheckbox                  = //mat-checkbox[@formcontrolname='nrNewFarmer']//input[@type='checkbox']

# Cat C native input — formcontrolname='nrCisyf'
iNRCISYFCatCCheckbox                  = //mat-checkbox[@formcontrolname='nrCisyf']//input[@type='checkbox']

# Cat A label — alternative click target (more reliable than mat-checkbox in some Angular versions)
iNRCISYFCatALabel                     = //mat-checkbox[@formcontrolname='nrYoungFarmer']//label[contains(@class,'mdc-label')]

# Cat B label
iNRCISYFCatBLabel                     = //mat-checkbox[@formcontrolname='nrNewFarmer']//label[contains(@class,'mdc-label')]

# Cat C label
iNRCISYFCatCLabel                     = //mat-checkbox[@formcontrolname='nrCisyf']//label[contains(@class,'mdc-label')]


# ------------------------------------------------------------------------------------------------NR/CISYF — Dialog Buttons------------------------------------------------------------------------------------------------

# Close button — button.nav-button.clearBtn with span "Close" and mat-icon "close"
iNRCISYFCloseBtn                      = //app-nr-cisyf-category-select-popup//button[contains(@class,'clearBtn')]

# Next button — disabled until at least one category is selected
iNRCISYFNextBtn                       = //app-nr-cisyf-category-select-popup//button[.//span[normalize-space()='Next']]


# ------------------------------------------------------------------------------------------------NR/CISYF — Validation Error------------------------------------------------------------------------------------------------

# "Please select a category" mat-error shown when Next is attempted with no category selected
iNRCISYFCategoryError                 = //app-nr-cisyf-category-select-popup//mat-error


# ------------------------------------------------------------------------------------------------NR/CISYF — Herd Search (NR/CISYF tab on My Clients)------------------------------------------------------------------------------------------------

# Herd number search input on the NR/CISYF tab
iNRCISYFHerdSearchField               = //input[@placeholder='Herd Number' or @formcontrolname='herdNumber'][ancestor::*[contains(@class,'nrcisyf') or contains(@class,'nr-cisyf')]]

# Search button on the NR/CISYF tab
iNRCISYFSearchBtn                     = //button[.//span[normalize-space()='Search']][ancestor::*[contains(@class,'nrcisyf') or contains(@class,'nr-cisyf')]]

# View link on the first matching NR/CISYF result row
iNRCISYFViewLink                      = (//table[contains(@class,'mdc-data-table')]//a[normalize-space()='View'] | //td[contains(@class,'cdk-column-action')]//a[normalize-space()='View'])[1]

# Apply or Edit button on the NR/CISYF landing page for a specific herd
iNRCISYFApplyEditBtn                  = //button[.//span[normalize-space()='Apply'] or .//span[normalize-space()='Edit']][contains(@class,'nav-button') or ancestor::*[contains(@class,'nrcisyf')]]


# ------------------------------------------------------------------------------------------------NR/CISYF — Landing Page------------------------------------------------------------------------------------------------

# Landing page header — confirms we are on the NR/CISYF application overview page
iNRCISYFLandingHeader                 = //h1[contains(normalize-space(),'National Reserve') or contains(normalize-space(),'NR/CISYF')] | //app-nr-cisyf-overview

# Closing date text on the landing page
iNRCISYFCloseDate                     = //*[contains(normalize-space(),'Closing date') or contains(normalize-space(),'closing date')]/following-sibling::* | //*[contains(@class,'close-date')]


# ------------------------------------------------------------------------------------------------NR/CISYF — CISYF Prompt (Additional category)------------------------------------------------------------------------------------------------

# Prompt asking if user wants to also apply for CISYF category — appears after Cat A selection
iNRCISYFCISYFPrompt                   = //mat-dialog-container//*[contains(normalize-space(),'CISYF') and contains(normalize-space(),'category')]

# "Select additional CISYF category and continue" button
iNRCISYFSelectAdditionalCISYFBtn      = //button[contains(normalize-space(),'Select additional CISYF') or contains(normalize-space(),'select CISYF')]

# "Do not select CISYF category and continue" button
iNRCISYFDoNotSelectCISYFBtn           = //button[contains(normalize-space(),'Do not select') or contains(normalize-space(),'do not select CISYF')]

# OK confirmation button that follows category selection or CISYF prompt
iNRCISYFOKBtn                         = //button[.//span[normalize-space()='OK'] or normalize-space()='OK'][not(@disabled)]


# ------------------------------------------------------------------------------------------------NR/CISYF — Farming Entity & Group Members------------------------------------------------------------------------------------------------

# Farming entity type dropdown (Individual / Joint herdowner / Company / Multi-Herd etc.)
iNRCISYFFarmingEntityDropdown         = //mat-select[@formcontrolname='farmingEntity'] | //mat-select[ancestor::*[contains(@class,'entity')]]

# Herd group type dropdown — only visible for Multi-Herd Registered Farm Partnership
iNRCISYFHerdGroupTypeDropdown         = //mat-select[@formcontrolname='herdGroupType'] | //mat-select[ancestor::*[contains(@class,'group-type')]]

# Number of group members dropdown
iNRCISYFMemberCountDropdown           = //mat-select[@formcontrolname='numberOfMembers'] | //mat-select[ancestor::*[contains(@class,'member-count')]]

# Company CRO number input
iNRCISYFCroNumberField                = //input[@formcontrolname='croNumber']

# Company name input
iNRCISYFCompanyNameField              = //input[@formcontrolname='companyName']

# Director name input
iNRCISYFDirectorNameField             = //input[@formcontrolname='directorName']


# ------------------------------------------------------------------------------------------------NR/CISYF — Qualification Form------------------------------------------------------------------------------------------------

# Date of completion input
iNRCISYFDateOfCompletionField         = //input[@formcontrolname='dateOfCompletion'] | //input[@id='dateOfCompletion']

# College / Educational institution dropdown
iNRCISYFCollegeDropdown               = //mat-select[@formcontrolname='college'] | //mat-select[@formcontrolname='educationalInstitution']

# Custom college free-text input — rendered when "not in list" is selected
iNRCISYFCustomCollegeField            = //input[@formcontrolname='customCollege'] | //input[@formcontrolname='customInstitution']

# Qualification dropdown
iNRCISYFQualificationDropdown         = //mat-select[@formcontrolname='qualification']

# Custom qualification free-text input — rendered when "not in list" is selected
iNRCISYFCustomQualificationField      = //input[@formcontrolname='customQualification']

# No-qualification information message
iNRCISYFNoQualMessage                 = //*[contains(normalize-space(),'no qualification') or contains(normalize-space(),'Covid') or contains(@class,'no-qual')]

# Next Farmer button — advances to the next member's qualification form in multi-member flows
iNRCISYFNextFarmerBtn                 = //button[.//span[contains(normalize-space(),'Next Farmer')] or contains(normalize-space(),'Next Farmer')]


# ------------------------------------------------------------------------------------------------NR/CISYF — Stepper Navigation------------------------------------------------------------------------------------------------

# Stepper Next button — advances through form steps
iNRCISYFStepperNextBtn                = //button[.//span[normalize-space()='Next'] or normalize-space()='Next'][contains(@class,'nav-button') or ancestor::*[contains(@class,'stepper')]]

# Stepper "Next to Summary" button — advances to document upload / summary page
iNRCISYFNextToSummaryBtn              = //button[.//span[contains(normalize-space(),'Next')] or contains(normalize-space(),'Summary')][not(@disabled)]

# Stepper "Save and Next" button — saves progress and advances to declaration
iNRCISYFStepperSaveAndNextBtn         = //button[.//span[normalize-space()='Save and Next'] or normalize-space()='Save and Next']

# "Save and Next" confirmation button in dialog
iNRCISYFSaveAndNextBtn                = //button[.//span[normalize-space()='Save and Next'] or normalize-space()='Save and Next'][not(@disabled)]

# Stepper "Save and Exit" button — saves draft and returns to landing page
iNRCISYFStepperSaveAndExitBtn         = //button[.//span[normalize-space()='Save and Exit'] or normalize-space()='Save and Exit']

# "Save and Exit" confirmation button in dialog
iNRCISYFSaveAndExitBtn                = //button[.//span[normalize-space()='Save and Exit'] or normalize-space()='Save and Exit'][not(@disabled)]


# ------------------------------------------------------------------------------------------------NR/CISYF — Document Upload------------------------------------------------------------------------------------------------

# Hidden file input used for all document uploads — type="file"
iNRCISYFFileUploadInput               = //input[@type='file'][ancestor::*[contains(@class,'nrcisyf') or contains(@class,'upload')]]

# Upload Document confirm button inside upload dialog
iNRCISYFUploadDocumentBtn             = //button[.//span[normalize-space()='Upload Document'] or contains(normalize-space(),'Upload Document')]


# ------------------------------------------------------------------------------------------------NR/CISYF — Submission & Declaration------------------------------------------------------------------------------------------------

# Submit Application button on the declaration step
iNRCISYFSubmitApplicationBtn          = //button[.//span[normalize-space()='Submit Application'] or normalize-space()='Submit Application']

# Declaration checkbox 1 (first of two required ticks)
iNRCISYFDeclarationCheckbox1          = (//mat-checkbox[ancestor::*[contains(@class,'declaration')]]//input[@type='checkbox'])[1]

# Declaration checkbox 2 (second of two required ticks)
iNRCISYFDeclarationCheckbox2          = (//mat-checkbox[ancestor::*[contains(@class,'declaration')]]//input[@type='checkbox'])[2]

# Final submit/confirm button in submission dialog
iNRCISYFSubmitConfirmBtn              = //button[.//span[normalize-space()='Submit'] or normalize-space()='Submit'][not(@disabled)][not(contains(@class,'clearBtn'))]


# ------------------------------------------------------------------------------------------------NR/CISYF — Post Submission------------------------------------------------------------------------------------------------

# View Application button on landing page for a submitted herd
iNRCISYFViewApplicationBtn            = //button[.//span[normalize-space()='View Application'] or normalize-space()='View Application']

# Correspondence navigation button / link inside the NR/CISYF application view
iNRCISYFCorrespondenceNavBtn          = //a[normalize-space()='Correspondence'] | //button[contains(normalize-space(),'Correspondence')]


# ------------------------------------------------------------------------------------------------NR/CISYF — Angular Material Panel (CDK)------------------------------------------------------------------------------------------------

# Generic open CDK overlay panel — used to wait for mat-select dropdown to render
iMatSelectOpenPanel                   = //div[contains(@class,'mat-mdc-select-panel') and not(contains(@class,'ng-animating'))]
