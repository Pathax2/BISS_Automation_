    // ***************************************************************************************************************************************************************************************
    // Function Name : resolveValue
    // Description   : Resolves TD:ColumnName syntax to actual test data value.
    //                 Returns raw value unchanged if no TD: prefix.
    // ***************************************************************************************************************************************************************************************
    public static String resolveValue(String pValue)
    {
        if (pValue == null)            { return null; }
