    // ***************************************************************************************************************************************************************************************
    // Function Name : launchBrowser
    // Description   : Launches the specified browser, initialises ThreadLocal driver and wait, and navigates to the given URL.
    //                 Supports Chrome, Firefox, and Edge.
    //                 After navigation, waits for Angular to stabilise before returning so the first step
    //                 always starts from a fully ready application state.
    // Parameters    : pBrowserType (String) - CHROME | FIREFOX | EDGE
    //                 pUrl         (String) - application URL
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 10-03-2026
    // ***************************************************************************************************************************************************************************************
    public static void launchBrowser(String pBrowserType, String pUrl)
    {
        try
        {
            if (pBrowserType == null || pBrowserType.trim().isEmpty())
            {
                throw new RuntimeException("Browser type cannot be blank. Supported: CHROME, FIREFOX, EDGE.");
            }
            if (pUrl == null || pUrl.trim().isEmpty())
            {
                throw new RuntimeException("URL cannot be blank.");
            }

            boolean   iHeadless = Boolean.parseBoolean(System.getProperty("headless", "false"));
            WebDriver iDriver;

            switch (pBrowserType.trim().toUpperCase())
            {
                case "CHROME":
                {
                    ChromeOptions iOptions = new ChromeOptions();
                    iOptions.addArguments("--start-maximized");
                    iOptions.addArguments("--disable-notifications");
                    iOptions.addArguments("--disable-infobars");
                    iOptions.addArguments("--disable-extensions");
                    iOptions.addArguments("--no-sandbox");
                    iOptions.addArguments("--disable-dev-shm-usage");
                    // Disable GPU-based rendering throttling that can cause Angular CD delays
                    iOptions.addArguments("--disable-gpu");
                    // Prevent Chrome from deprioritising background tab rendering
                    iOptions.addArguments("--disable-background-timer-throttling");
                    iOptions.addArguments("--disable-backgrounding-occluded-windows");
                    iOptions.addArguments("--disable-renderer-backgrounding");
                    if (iHeadless)
                    {
                        iOptions.addArguments("--headless=new");
                        iOptions.addArguments("--window-size=1920,1080");
                    }
                    System.setProperty("webdriver.chrome.driver", "drivers/chromedriver.exe");
                    iDriver = new ChromeDriver(iOptions);
                    break;
                }
                case "FIREFOX":
                {
                    FirefoxOptions iOptions = new FirefoxOptions();
                    if (iHeadless)
                    {
                        iOptions.addArguments("-headless");
                    }
                    iDriver = new FirefoxDriver(iOptions);
                    iDriver.manage().window().maximize();
                    break;
                }
                case "EDGE":
                {
                    EdgeOptions iOptions = new EdgeOptions();
                    iOptions.addArguments("--start-maximized");
                    iOptions.addArguments("--disable-notifications");
                    iOptions.addArguments("--disable-background-timer-throttling");
                    if (iHeadless)
                    {
                        iOptions.addArguments("--headless=new");
                        iOptions.addArguments("--window-size=1920,1080");
                    }
                    iDriver = new EdgeDriver(iOptions);
                    break;
                }
                default:
                    throw new RuntimeException("Unsupported browser : '" + pBrowserType + "'. Supported: CHROME, FIREFOX, EDGE.");
            }

            iDriverHolder.set(iDriver);
            iWaitHolder.set(new WebDriverWait(iDriver, Duration.ofSeconds(iExplicitWaitSeconds)));
            iDriver.get(pUrl.trim());

            // Wait for Angular to fully stabilise after initial page load
            waitForAngularReady(iDriver);

            log.info("[" + getCurrentTimestamp() + "] Browser launched | Browser=" + pBrowserType.toUpperCase()
                    + " | Headless=" + iHeadless + " | URL=" + pUrl);
        }
        catch (Exception iException)
        {
            throw new RuntimeException("Browser launch failed [" + pBrowserType + "] : " + iException.getMessage(), iException);
        }
    }

    // ***************************************************************************************************************************************************************************************
    // Function Name : closeBrowser
    // Description   : Quits the WebDriver bound to the current thread and cleans up ThreadLocal references
    // ***************************************************************************************************************************************************************************************
    public static void closeBrowser()
    {
        try
        {
            WebDriver iDriver = iDriverHolder.get();
            if (iDriver != null)
            {
                iDriver.quit();
                log.info("[" + getCurrentTimestamp() + "] Browser closed successfully.");
            }
            else
            {
                log.warning("[" + getCurrentTimestamp() + "] closeBrowser called but no active driver on this thread.");
            }
        }
        catch (Exception iException)
        {
            log.warning("[" + getCurrentTimestamp() + "] Error closing browser : " + iException.getMessage());
        }
        finally
        {
            iDriverHolder.remove();
            iWaitHolder.remove();
        }
    }


