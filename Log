    // Step : Staff assigns the following SSO roles | Per row: filter list (only on change), select role, arrow_forward across.
    // Params: pDataTable columns filter, role | Author: Aniket Pathare | Date: 14-07-2026
    @And("Staff assigns the following SSO roles")
    public void staffAssignsTheFollowingSsoRoles(DataTable pDataTable)
    {
        List<Map<String, String>> iRows = pDataTable.asMaps(String.class, String.class);
        String iLastFilter = null;
        for (Map<String, String> iRow : iRows)
        {
            String iFilter = iRow.get("filter").trim();
            String iRole   = iRow.get("role").trim();
            log.info("[STEP] SSO role assign - filter=" + iFilter + ", role=" + iRole);

            if (!iFilter.equals(iLastFilter))
            {
                iAction("TEXTBOX", "XPATH", ObjReader.getLocator("iStaffSsoRoleFilter"), iFilter);
                iLastFilter = iFilter;
            }
            iAction("CLICK", "XPATH", ObjReader.getLocator("iStaffSsoRoleOption").replace("{ROLE}", iRole), null);
            iAction("CLICK", "XPATH", ObjReader.getLocator("iStaffSsoButton").replace("{BTN}", "arrow_forward"), null);
        }
    }

