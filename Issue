@Then("the following columns should have sorting enabled")
public void theFollowingColumnsShouldHaveSortingEnabled(DataTable pDataTable)
{
    log.info("[STEP] Then the following columns should have sorting enabled");

    List<String> iColumns = pDataTable.asList();

    for (String col : iColumns)
    {
        String iTrimmed = col.trim();

        // The sort header container — confirms the column is registered as sortable
        // with MatSort. Present regardless of hover state.
        String iSortableHeaderXpath = String.format(
                ObjReader.getLocator("iTableHeaderSortable"), iTrimmed);

        // The sort arrow element — Angular always renders this in the DOM for
        // sortable columns; opacity:0 when not hovered, opacity:1 when hovered.
        // findElements picks it up regardless of CSS visibility — no hover needed.
        String iArrowXpath = String.format(
                ObjReader.getLocator("iSortArrowForColumn"), iTrimmed);

        // Re-query both elements fresh each iteration — avoids stale refs from
        // any Angular re-render triggered by the previous column check
        List<WebElement> iSortHeader = getDriver().findElements(By.xpath(iSortableHeaderXpath));
        List<WebElement> iArrow      = getDriver().findElements(By.xpath(iArrowXpath));

        Assertions.assertFalse(iSortHeader.isEmpty(),
                "Sortable header not found for column: " + iTrimmed);
        Assertions.assertFalse(iArrow.isEmpty(),
                "Sort arrow missing for sortable column: " + iTrimmed);

        log.info("  ✓ " + iTrimmed + " — sortable header and arrow present");
    }

    log.info("[STEP] All sortable columns verified: " + iColumns.size() + " column(s) checked.");
}
