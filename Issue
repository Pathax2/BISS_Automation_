SELECT column_name, data_type
FROM all_tab_columns
WHERE table_name = 'TDCO_HERD'
AND column_name LIKE '%END%'
OR (table_name = 'TDCO_HERD' AND column_name LIKE '%EXPIR%')
OR (table_name = 'TDCO_HERD' AND column_name LIKE '%VALID%')
ORDER BY column_id;


