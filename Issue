    @Then("the following parcel actions should be available")
    public void theFollowingParcelActionsShouldBeAvailable(DataTable pActions)
    {
        List<String> iActions = pActions.asList();

        for (String iActionName : iActions)
        {
            iAction("CLICK", "XPATH",
                    ObjReader.getLocator("iParcelActionButton").replace("{LABEL}", iActionName), null);

            switch (iActionName)
            {
                case "View Claimants":
                    iAction("CLICK", "XPATH",
                            ObjReader.getLocator("iDialogButton").replace("{LABEL}", "Cancel"), null);
                    break;

                case "Parcel History":
                    iAction("CLICK", "XPATH",
                            ObjReader.getLocator("iDialogButton").replace("{LABEL}", "Close"), null);
                    break;

                case "View Map":
                    iAction("CLICK", "XPATH", ObjReader.getLocator("iReturnToLandDetailsLink"), null);
                    break;

                default:
                    break;
            }
        }
    }

