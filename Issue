    // @Before("@tc13")
    // Description   : Resolves a random CISYF-eligible J-prefix herd and its agent login
    //                 from BISS_DATA and BISS_INET before the TC_13 NRCISYF scenario runs.
    //
    //                 Strategy:
    //                   1. Query BISS_DATA using "List of individual herds with CISYF scheme"
    //                      (J-prefix, submitted, CISYF scheme applied, no payment yet).
    //                   2. Shuffle the result pool randomly — a different herd is picked each run.
    //                   3. For each candidate, query BISS_INET for the agent login.
    //                   4. Skip candidates with no INET agent or in EXPIRED_AGENTS.
    //                   5. On success: overwrite RUNTIME_HERD and RUNTIME_USERNAME so the
    //                      Background login step and herd search step use the correct CISYF herd.
    //                   6. If all candidates exhausted: retry with a larger limit (up to 5 attempts).
    //
    //                 Why random:
    //                   Shuffling gives a different herd on each run, avoiding repeated use of
    //                   the same herd and making the test suite more robust across environments.
    //
    //                 After this hook:
    //                   Hooks.RUNTIME_HERD     = resolved CISYF J-prefix herd
    //                   Hooks.RUNTIME_USERNAME = agent who owns that herd in BISS_INET
    //                   Hooks.CISYF_HERD       = same as RUNTIME_HERD (kept for clarity in logs)
    //                   Hooks.CISYF_USERNAME   = same as RUNTIME_USERNAME
    //
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-05-2026
    // ***************************************************************************************************************************************************************************************
    // ===============================================================================================================================
    // Function Name : resolveStaffRuntimeData
    // Description   : Resolves every runtime data pool a staff scenario declares, before it runs.
    //
    //                 The feature declares what it needs as tags, e.g.:
    //                     @staffdata @herds:5:submitted @parcels:14 @refs:5
    //
    //                 This hook reads those tags, runs the matching DBRouter query for each, and fills the
    //                 corresponding STAFF_* pool. StaffSteps.java then walks each pool with its own cursor, so a
    //                 feature can say "the next submitted herd" without ever naming a row index.
    //
    //                 Why pools rather than a single RUNTIME_HERD: a staff scenario chains many sections and often
    //                 needs a DIFFERENT herd per section (TC_21 walks six), or several DIFFERENT KINDS at once
    //                 (TC_12 compares a penalty herd against a clean one). A single field cannot express that.
    //
    //                 Supported tags:
    //                     @herds:N:submitted    - submitted applications
    //                     @herds:N:penalty      - submitted WITH an application penalty
    //                     @herds:N:noamend      - submitted with no amendment raised
    //                     @herds:N:admincheck   - no admin check started
    //                     @herds:N:queryletter  - no query letter submitted
    //                     @herds:N:simopted     - submitted with SIM opted in
    //                     @herds:N:payments     - carrying payments
    //                     @parcels:N            - LPIS parcels
    //                     @refs:N               - TRN reference numbers
    //
    //                 Scheme year comes from -Dstaff.year, defaulting to 2024.
    //
    // Parameters    : pScenario (Scenario) - supplies the tag list for this scenario
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ===============================================================================================================================
    @Before("@staffdata")
    public void resolveStaffRuntimeData(Scenario pScenario)
    {
        clearStaffPools();

        CommonFunctions.log.info("[STAFF-DATA] Resolving runtime pools for: " + pScenario.getName());

        boolean iAnyPoolRequested = false;

        for (String iTag : pScenario.getSourceTagNames())
        {
            Matcher iMatcher = STAFF_POOL_TAG.matcher(iTag.trim());

            if (!iMatcher.matches())
            {
                continue;
            }

            iAnyPoolRequested = true;

            String iPoolType = iMatcher.group(1);
            String iCount    = iMatcher.group(2);
            String iKind     = iMatcher.group(3);

            CommonFunctions.log.info("[STAFF-DATA] Tag " + iTag + " -> type=" + iPoolType
                    + ", count=" + iCount + ", kind=" + (iKind == null ? "n/a" : iKind));

            try
            {
                switch (iPoolType)
                {
                    case "herds":
                        resolveHerdPool(iKind, iCount);
                        break;

                    case "parcels":
                        fillPool(STAFF_PARCELS,
                                "Get LPIS parcels", "LPS_PARCEL_LABEL", new String[]{ iCount });
                        break;

                    case "refs":
                        fillPool(STAFF_REFERENCES,
                                "Get reference numbers", "APP_HERD_NO", new String[]{ STAFF_DEFAULT_YEAR, iCount });
                        break;

                    default:
                        CommonFunctions.log.warning("[STAFF-DATA] Unknown pool type in tag: " + iTag);
                        break;
                }
            }
            catch (Exception iException)
            {
                // Fail loudly. A scenario that runs with an empty pool will either throw an obscure error deep in a
                // step, or worse, silently skip the data it was meant to exercise.
                throw new IllegalStateException(
                        "[STAFF-DATA] Failed to resolve pool for tag " + iTag + ": " + iException.getMessage(),
                        iException);
            }
        }

        if (!iAnyPoolRequested)
        {
            CommonFunctions.log.warning("[STAFF-DATA] Scenario is tagged @staffdata but declares no pool tags "
                    + "(e.g. @herds:5:submitted). No runtime data has been resolved.");
        }

        CommonFunctions.log.info("[STAFF-DATA] Pools resolved — "
                + "submitted=" + STAFF_SUBMITTED_HERDS.size()
                + ", penalty=" + STAFF_PENALTY_HERDS.size()
                + ", noamend=" + STAFF_NOAMEND_HERDS.size()
                + ", admincheck=" + STAFF_ADMINCHECK_HERDS.size()
                + ", queryletter=" + STAFF_QUERYLETTER_HERDS.size()
                + ", simopted=" + STAFF_SIMOPTED_HERDS.size()
                + ", payments=" + STAFF_PAYMENT_HERDS.size()
                + ", parcels=" + STAFF_PARCELS.size()
                + ", refs=" + STAFF_REFERENCES.size());
    }

    // ===============================================================================================================================
    // Function Name : resolveHerdPool
    // Description   : Routes a @herds:N:<kind> tag to its DBRouter query and target pool.
    // Parameters    : pKind  (String) - the kind suffix from the tag; defaults to submitted when absent
    //                 pCount (String) - how many rows to fetch
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ===============================================================================================================================
    private void resolveHerdPool(String pKind, String pCount)
    {
        String iKind = (pKind == null || pKind.trim().isEmpty()) ? "submitted" : pKind.trim().toLowerCase();

        switch (iKind)
        {
            case "submitted":
                fillPool(STAFF_SUBMITTED_HERDS,
                        "Get submitted herds", "APP_HERD_NO", new String[]{ STAFF_DEFAULT_YEAR, pCount });
                break;

            case "penalty":
                fillPool(STAFF_PENALTY_HERDS,
                        "Get submitted herds with penalty", "APP_HERD_NO", new String[]{ STAFF_DEFAULT_YEAR, pCount });
                break;

            case "noamend":
                fillPool(STAFF_NOAMEND_HERDS,
                        "Get submitted herds with no amendment", "APP_HERD_NO",
                        new String[]{ STAFF_DEFAULT_YEAR, pCount });
                break;

            case "admincheck":
                fillPool(STAFF_ADMINCHECK_HERDS,
                        "Get herds with admin check not started", "APP_HERD_NO",
                        new String[]{ STAFF_DEFAULT_YEAR, pCount });
                break;

            case "queryletter":
                fillPool(STAFF_QUERYLETTER_HERDS,
                        "Get herds with query letter not started", "APP_HERD_NO",
                        new String[]{ STAFF_DEFAULT_YEAR, pCount });
                break;

            case "simopted":
                fillPool(STAFF_SIMOPTED_HERDS,
                        "Get submitted herds with SIM opted in", "APP_HERD_NO",
                        new String[]{ STAFF_DEFAULT_YEAR, pCount });
                break;

            case "payments":
                fillPool(STAFF_PAYMENT_HERDS,
                        "Get herds with payments", "PHD_HERD_NO", new String[]{ STAFF_DEFAULT_YEAR, pCount });
                break;

            default:
                throw new IllegalArgumentException("[STAFF-DATA] Unknown herd kind '" + iKind
                        + "'. Supported: submitted, penalty, noamend, admincheck, queryletter, simopted, payments.");
        }
    }

    // ===============================================================================================================================
    // Function Name : fillPool
    // Description   : Runs a DBRouter query and fills a pool from one column of the result set.
    //
    //                 Blacklisted herds are skipped, reusing the BLACKLISTED_HERDS guard the CISYF hook relies on -
    //                 those herds are known to break scenarios and must not enter any pool.
    //
    //                 Duplicates are skipped: a scenario asking for 5 distinct herds must not silently receive the
    //                 same herd twice, which would make two sections operate on one application.
    //
    // Parameters    : pPool       (List<String>) - target pool
    //                 pLabel      (String)       - DBRouter query label
    //                 pColumn     (String)       - column to read from each row
    //                 pParams     (String[])     - query parameters
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ===============================================================================================================================
    private void fillPool(List<String> pPool, String pLabel, String pColumn, String[] pParams)
    {
        database.DBRouter.runDB("DATA", pLabel, pParams);

        List<Map<String, Object>> iRows = database.DBRouter.getRows();

        if (iRows == null || iRows.isEmpty())
        {
            CommonFunctions.log.warning("[STAFF-DATA] Query '" + pLabel + "' returned no rows.");
            return;
        }

        for (Map<String, Object> iRow : iRows)
        {
            Object iRaw = iRow.get(pColumn);

            if (iRaw == null)
            {
                continue;
            }

            String iValue = String.valueOf(iRaw).trim();

            if (iValue.isEmpty() || BLACKLISTED_HERDS.contains(iValue) || pPool.contains(iValue))
            {
                continue;
            }

            pPool.add(iValue);
        }

        CommonFunctions.log.info("[STAFF-DATA] Query '" + pLabel + "' -> " + pPool.size() + " usable value(s).");
    }

    // ===============================================================================================================================
    // Function Name : clearStaffPools
    // Description   : Empties every staff pool. Called before resolution and again after each scenario, so data
    //                 from one scenario can never leak into the next.
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ===============================================================================================================================
    private static void clearStaffPools()
    {
        STAFF_SUBMITTED_HERDS.clear();
        STAFF_PENALTY_HERDS.clear();
        STAFF_NOAMEND_HERDS.clear();
        STAFF_ADMINCHECK_HERDS.clear();
        STAFF_QUERYLETTER_HERDS.clear();
        STAFF_SIMOPTED_HERDS.clear();
        STAFF_PAYMENT_HERDS.clear();
        STAFF_PARCELS.clear();
        STAFF_REFERENCES.clear();
    }


    @Before("@tc13")
    public void resolveRuntimeCISYFHerd(Scenario pScenario)
    {
        final String YEAR      = System.getProperty("herd.year",  "2026").trim();
        final int    MAX_TRIES = 50;

        CommonFunctions.log.info("[TC13-HOOK] Resolving random CISYF J-prefix herd for: " + pScenario.getName());

        boolean iFound = false;

        for (int iAttempt = 1; iAttempt <= MAX_TRIES && !iFound; iAttempt++)
        {
            // Increase limit on each retry to surface more candidates
            int iLimit = 50 + ((iAttempt - 1) * 25);

            CommonFunctions.log.info("[TC13-HOOK] Attempt " + iAttempt + "/" + MAX_TRIES + " — querying BISS_DATA (year=" + YEAR + ", limit=" + iLimit + ")");

            database.DBRouter.runDB("DATA", "LIST OF NOT STARTED INDIVIDUAL HERDS ELIGIBLE FOR CISYF", YEAR, String.valueOf(iLimit));

            List<Map<String, Object>> iRows = database.DBRouter.getRows();

            if (iRows == null || iRows.isEmpty())
            {
                CommonFunctions.log.warning("[TC13-HOOK] BISS_DATA returned no CISYF herds " + "at limit=" + iLimit + ". Retrying...");
                continue;
            }

            CommonFunctions.log.info("[TC13-HOOK] Candidate pool: " + iRows.size() + " herd(s).");

            // ── Shuffle for random selection — different herd each run ────────────────
            List<String> iCandidates = new java.util.ArrayList<>();
            for (Map<String, Object> iRow : iRows)
            {
                String iHerd = Objects.toString(iRow.get("APP_HERD_NO"), "").trim();
                if (!iHerd.isEmpty()) iCandidates.add(iHerd);
            }
            java.util.Collections.shuffle(iCandidates, new java.util.Random(System.nanoTime()));

            CommonFunctions.log.info("[TC13-HOOK] Pool shuffled. Evaluating candidates...");

            int iIdx = 0;
            for (String iCandidate : iCandidates)
            {
                iIdx++;

                // Skip blacklisted herds
                if (BLACKLISTED_HERDS.contains(iCandidate))
                {
                    CommonFunctions.log.warning("[TC13-HOOK] Candidate [" + iIdx + "] " + iCandidate + " is blacklisted — skipping.");
                    continue;
                }

                // Query BISS_INET for agent login
                database.DBRouter.runDB("INET", "Get Login Id for herd", iCandidate);
                String iUsername = database.DBRouter.getValue("USERNAME");

                if (iUsername == null || iUsername.isBlank())
                {
                    CommonFunctions.log.warning("[TC13-HOOK] Candidate [" + iIdx + "] " + iCandidate + " — no INET agent found. Skipping.");
                    continue;
                }

                iUsername = iUsername.trim();

                // Skip agents with expired SSO accounts
                if (EXPIRED_AGENTS.contains(iUsername))
                {
                    CommonFunctions.log.warning("[TC13-HOOK] Candidate [" + iIdx + "] " + iCandidate + " — agent " + iUsername + " is in EXPIRED_AGENTS. Skipping.");
                    continue;
                }

                // ── Valid candidate found ─────────────────────────────────────────────
                CISYF_HERD     = iCandidate;
                CISYF_USERNAME = iUsername;

                // Overwrite RUNTIME_HERD and RUNTIME_USERNAME so Background login
                // and herd search steps use the correct CISYF herd automatically
                RUNTIME_HERD     = iCandidate;
                RUNTIME_USERNAME = iUsername;

                iFound = true;

                CommonFunctions.log.info("[TC13-HOOK] ✓ CISYF herd resolved:");
                CommonFunctions.log.info("[TC13-HOOK]   Herd     = " + CISYF_HERD);
                CommonFunctions.log.info("[TC13-HOOK]   Username = " + CISYF_USERNAME);
                break;
            }

            if (!iFound)
            {
                CommonFunctions.log.warning("[TC13-HOOK] No valid candidate in attempt " + iAttempt + " — retrying with larger limit.");
            }
        }

        if (!iFound)
        {
            throw new RuntimeException(
                    "[TC13-HOOK] Could not resolve a CISYF J-prefix herd after " + MAX_TRIES + " attempts for year=" + YEAR + ". " + "Verify the query 'List of individual herds with CISYF scheme' " + "returns rows in BISS_DATA for this environment.");
        }
    }
    // =================================================================================================
// BEFORE — runs before every scenario
// =================================================================================================
    @Before
    public void beforeScenarioExecution(Scenario pScenario)
    {
        SoftAssertManager.reset();
        RetryAnalyser.clearRetryState();
        iScenarioStartTime = System.currentTimeMillis();
        CommonFunctions.log.info("---------- Scenario START : " + pScenario.getName() + " ----------");

        String iScenarioTags = String.join(" ", pScenario.getSourceTagNames());
        ReportManager.beginTestCase(iTestCaseID, pScenario.getName(), iScenarioTags);
    }

    // =================================================================================================
// AFTER — runs after every scenario
// =================================================================================================
    @After
    public void afterScenarioExecution(Scenario pScenario)
    {
        SoftAssertManager.assertAll();

        // Empty the staff runtime pools so this scenario's herds cannot leak into the next one.
        clearStaffPools();

        long iScenarioDuration = System.currentTimeMillis() - iScenarioStartTime;
        utilities.ScreenshotManager.appendScenarioDivider(iDocument, pScenario.getName(), !pScenario.isFailed(), iScenarioDuration);

        try
        {
            if (pScenario.isFailed())
            {
                CommonFunctions.log.severe("---------- Scenario FAILED : " + pScenario.getName()
                        + " ----------");

                iAccumulatedErrors.append("Scenario [").append(pScenario.getName())
                        .append("] FAILED. Status=").append(pScenario.getStatus().name()).append("\n");

                try
                {
                    if (iDocument != null && !iDocPath.isEmpty())
                    {
                        iLastScreenshotPath = CommonFunctions.addScreenshotToReport(iDocument, iDocPath, iTestCaseID);
                    }
                    else
                    {
                        String iSafeName = iTestCaseID + "_" + pScenario.getName().replaceAll("[^a-zA-Z0-9]", "_");
                        iLastScreenshotPath = CommonFunctions.takeScreenshot(iSafeName);
                    }
                }
                catch (Exception iShotException)
                {
                    CommonFunctions.log.severe("Screenshot failed : " + iShotException.getMessage());
                }
            }
            else
            {
                CommonFunctions.log.info("---------- Scenario PASSED : " + pScenario.getName()
                        + " ----------");
            }
        }
        catch (Exception iException)
        {
            CommonFunctions.log.severe("After hook error : " + iException.getMessage());
        }
    }

    // =================================================================================================
// AFTER ALL — runs once after all scenarios complete
// =================================================================================================
    @AfterAll
    public static void afterAllExecution()
    {
        try
        {
            if (iAccumulatedErrors.length() > 0)
            {
                System.setProperty("lastFailureReason." + iTestCaseID,
                        iAccumulatedErrors.toString().trim());
            }
            if (!iLastScreenshotPath.isEmpty())
            {
                System.setProperty("lastScreenshotPath." + iTestCaseID, iLastScreenshotPath);
            }
        }
        catch (Exception iException)
        {
            CommonFunctions.log.severe("Failed to publish failure properties : "
                    + iException.getMessage());
        }

        try
        {
            if (iDocument != null && !iDocPath.isEmpty())
            {
                CommonFunctions.finalizeWordReport(iDocument, iDocPath);
            }
        }
        catch (Exception iException)
        {
            CommonFunctions.log.severe("Word report finalization failed : " + iException.getMessage());
        }

        try
        {
            CommonFunctions.closeBrowser();
        }
        catch (Exception iException)
        {
            CommonFunctions.log.severe("Browser close failed : " + iException.getMessage());
        }

        CommonFunctions.log.info("========== EXECUTION END : " + iTestCaseID + " ==========");
    }

    // =================================================================================================
// UTILITY
