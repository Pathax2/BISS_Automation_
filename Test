select app_herd_no, applicant_type
from vwbs_application_herd
where mde_abbrev = 'I' 
and applicant_type = 'I' -- Get individual herd_no
and exists (select 1 from tdbs_application_land x where x.apl_year = app_year and x.apl_aph_id = aph_id and x.apl_app_id = aph_app_id and x.apl_deleted_ind = 'N') -- With lands
and not exists (select 1 from tdbs_payment_application x where x.pap_app_id = aph_app_id and x.pap_payment_ind = 'Y') -- There is no payments
and app_year = 2026 -- year
and nvl(pkbs_payment_utils.fn_GetSchemeApplied(aph_app_id,3),'N') = 'Y' -- 'CISYF' scheme
and substr(app_herd_no,1,1) > 'J' -- avoid TRNs
and rownum <= 5 -- only x rows
order by 1 asc;

SELECT curr.app_herd_no, curr.app_year, curr.aph_herd_type
FROM vwbs_application_herd curr
WHERE curr.mde_abbrev     = 'RI'          -- Not Started (current year)
AND   curr.app_herd_no    LIKE 'J%'       -- J-prefix individual
AND   curr.applicant_type = 'I'           -- Individual only
AND   curr.app_year       = 2026          -- Current year
AND EXISTS (
    SELECT 1
    FROM tdbs_application_land x
    WHERE x.apl_year        = curr.app_year
    AND   x.apl_aph_id      = curr.aph_id
    AND   x.apl_app_id      = curr.aph_app_id
    AND   x.apl_deleted_ind = 'N'
)
-- CISYF was applied in previous year's submitted application
AND EXISTS (
    SELECT 1
    FROM vwbs_application_herd prev
    WHERE prev.app_herd_no = curr.app_herd_no
    AND   prev.app_year    = curr.app_year - 1
    AND   prev.mde_abbrev  = 'I'
    AND   NVL(pkbs_payment_utils.fn_GetSchemeApplied(prev.aph_app_id, 3), 'N') = 'Y'
)
AND SUBSTR(curr.app_herd_no, 1, 1) > 'A'
AND ROWNUM <= 50
ORDER BY curr.app_herd_no ASC;
