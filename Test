    static public String getQueryForHerdWithPayments(int NumberOfRowsToFetch) {
        HashMap<String, String> paidherdmap = new HashMap<>();
        String herdwithpayment = "select * from tdbs_payment_header tdh \n" +
                                 "join TDBS_APPLICATION ta on ta.app_id = tdh.phd_app_id \n" +
                                 "where tdh.phd_year=2024 \n" +
                                 "and tdh.phd_ptp_code=9 \n" +
                                 "fetch first "+NumberOfRowsToFetch+" rows only";
