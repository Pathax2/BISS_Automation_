TEST DATA

BISS_DATA - Find herd with AMS Round 1 findings:
select * from VWBS_AMS_NOTIFIED_HERD where scheme_year = 2026 and expired = 0 and rownum <= 5 order by herd_no;

BISS_DATA - Find parcel with AMS Artificial Surface finding:
SELECT app_herd_no, aph_herd_no, parcel_id FROM vwbs_error_land WHERE eor_year = 2026 AND ers_abbrev = ‘A’ AND ety_code = 2028 AND pkbs_inspection.fn_CheckAdminInsp(app_id,‘C’) = ‘N’ ORDER BY app_herd_no;

BISS_INET - Get agent login for herd:
SELECT hbcus.bcus_bus_id AS HERDNO, MIN(ui.uri_username) AS USERNAME FROM tdco_customer_asscs ca, tdco_business_customers abcus, tdco_business_customers hbcus, tdcr_user_info ui WHERE SYSDATE BETWEEN ca.ca_start_date AND ca.ca_end_date AND ca.ca_cac_code = 194 AND ca.ca_bcus_id_from = abcus.bcus_id AND ca.ca_bcus_id_to = hbcus.bcus_id AND ui.uri_ccs_bus_id = abcus.bcus_bus_id AND hbcus.bcus_bus_id = ‘<HERD_NUMBER>’ GROUP BY hbcus.bcus_bus_id HAVING COUNT(DISTINCT ui.uri_username) = 1;

