# ================================================================================
TC_01 - ACCEPT FINDINGS AND TICK THE EH CHANGE CHECKBOX

SQL QUERIES - EXECUTE IN ORDER

– STEP 1: Find a herd with Red AMS R1 Artificial Surface notification
– Purpose: Get your test herd and parcel number
SELECT *
FROM VWBS_AMS_NOTIFIED_HERD
WHERE amn_year = 2026
AND amn_round = 1
AND amn_notification_type = ‘Artificial Surface’
AND ROWNUM <= 10
ORDER BY amn_herd_no;

– STEP 2: Confirm herd is pre-submit (DO NOT SUBMIT)
– Purpose: Ensure mde_code is 1, 2 or 3 before testing
– Replace :herd_no with value from Step 1
SELECT app_herd_no, app_mde_code, app_year
FROM vwbs_application_herd
WHERE app_mde_code IN (1, 2, 3)
AND app_year = 2026
AND app_herd_no = :herd_no;

– STEP 3: Confirm herd business is active
– Purpose: Ensure herd is not closed or expired
– Replace :herd_no with value from Step 1
SELECT bcus_bus_id, bcus_bus_end_date
FROM vwco_biss_business_details
WHERE bcus_bus_end_date > SYSDATE
AND bcus_bus_id = :herd_no;

– STEP 4 (POST-CONDITION): Confirm response was persisted after successful save
– Purpose: Positive check - must return a row after TC_01 save
– Replace :herd_no and :parcel_no with values from Step 1
SELECT *
FROM vwbs_ams_response
WHERE lvl_submit_id IS NOT NULL
AND amr_year = 2026
AND amr_herd_no = :herd_no
AND amr_parcel_no = :parcel_no;

