    // ---------------------------------------------------------------------------------------------------------------------------------
    // Function Name : theGeneratedMapShouldBeRecordedWithTheFollowingDetails
    // Description   : Verifies the generated map row carries every named metadata field. Replaces four separate
    //                 "verifies the X of the generated map" steps with one assertion over a table.
    // Parameters    : pFields (DataTable) - single column: status / id / herdNumber / date
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ---------------------------------------------------------------------------------------------------------------------------------
    @Then("the generated map should be recorded with the following details")
    public void theGeneratedMapShouldBeRecordedWithTheFollowingDetails(DataTable pFields) throws InterruptedException {
        Thread.sleep(2000);
        log.info("[STEP] the generated map should be recorded with the following details");

        List<String> iFields = pFields.asList();

        Map<String, String> iColumnClassMap = new HashMap<>();
        iColumnClassMap.put("id", "mat-column-id");
        iColumnClassMap.put("herdNumber", "mat-column-herdNumber");
        iColumnClassMap.put("date", "mat-column-date");
        iColumnClassMap.put("mapType", "mat-column-mapType");
        iColumnClassMap.put("mapError", "mat-column-mapError");
        iColumnClassMap.put("status", "mat-column-status");

        for (String iField : iFields)
        {
            String iColumnClass = iColumnClassMap.get(iField);

            if (iColumnClass == null)
            {
                throw new IllegalArgumentException("Unsupported generated map field: " + iField);
            }

            String iXpath =
                    "//mat-card[.//mat-card-title[contains(normalize-space(),'Generated Maps')]]" +
                            "//tbody[contains(@class,'mdc-data-table__content')]" +
                            "/tr[1]/td[contains(@class,'" + iColumnClass + "')]";

            WebElement iElement = getDriver().findElement(By.xpath(iXpath));

            String iValue = iElement.getAttribute("textContent").trim();

            if (iValue.isEmpty())
            {
                throw new AssertionError("Expected value for generated map field '" + iField + "' but none was displayed.");
            }

            iAction("VERIFYELEMENT", "XPATH", iXpath, null);

            log.info("Verified " + iField + " : " + iValue);
        }
    }




