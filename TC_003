    // ***************************************************************************************************************************************************************************************
    // Function Name : performClick
    // Description   : Clicks an element using a four-tier fallback strategy designed for Angular Material.
    //
    //                 Tier 0 — Angular readiness gate
    //                   waitForAngularReady() runs first to ensure no pending HTTP/Zone tasks.
    //
    //                 Tier 1 — mat-icon / span / div parent escalation (pre-check)
    //                   Angular Material icon buttons structure is <button><mat-icon>...</mat-icon></button>.
    //                   The click handler lives on the parent <button>, not the <mat-icon>.
    //                   This tier walks up the DOM to find the nearest <button> or <a> ancestor.
    //
    //                 Tier 2 — Standard Selenium click
    //                   Direct element.click() — fast and reliable for most elements.
    //
    //                 Tier 3 — JavaScript click
    //                   Fires on ElementClickInterceptedException (MDC ripple overlay interception).
    //
    //                 Tier 4 — Actions chain click
    //                   Last resort — moves to element centre and clicks via Actions API.
    // ***************************************************************************************************************************************************************************************
    private static void performClick(WebDriver pDriver, WebDriverWait pWait, By pBy, String pObjectName)
    {
        // Angular readiness gate — before every click
        waitForAngularReady(pDriver);

        WebElement iElement = pWait.until(ExpectedConditions.visibilityOfElementLocated(pBy));
        pWait.until(ExpectedConditions.elementToBeClickable(iElement));
        scrollIntoView(pDriver, iElement);
        highlightElement(pDriver, iElement);

        String iTagName = iElement.getTagName().toLowerCase().trim();

        // ── Tier 1 : Parent escalation for Angular Material icon/span/div elements ──────────
        if ("mat-icon".equals(iTagName) || "span".equals(iTagName) || "div".equals(iTagName))
        {
            WebElement iAncestor = findClickableAncestor(pDriver, iElement);
            if (iAncestor != null)
            {
                log.info("[" + getCurrentTimestamp() + "] CLICK | Escalating from <" + iTagName
                        + "> to parent <" + iAncestor.getTagName() + "> | Locator: " + pObjectName);
                scrollIntoView(pDriver, iAncestor);
                highlightElement(pDriver, iAncestor);
                try
                {
                    iAncestor.click();
                    log.info("[" + getCurrentTimestamp() + "] CLICK | Parent escalation succeeded | " + pObjectName);
                    waitForAngularReady(pDriver);
                    return;
                }
                catch (Exception iAncestorEx)
                {
                    log.warning("[" + getCurrentTimestamp() + "] CLICK | Parent escalation failed — falling through | " + iAncestorEx.getMessage());
                }
            }
        }

        // ── Tier 2 : Standard Selenium click ─────────────────────────────────────────────────
        try
        {
            iElement.click();
            log.info("[" + getCurrentTimestamp() + "] CLICK | Standard click succeeded | " + pObjectName);
            waitForAngularReady(pDriver);
            return;
        }
        catch (ElementClickInterceptedException iIntercepted)
        {
            log.warning("[" + getCurrentTimestamp() + "] CLICK | Intercepted — retrying with JS click | " + pObjectName);
        }
        catch (Exception iStandardEx)
        {
            log.warning("[" + getCurrentTimestamp() + "] CLICK | Standard failed — retrying with JS click | " + iStandardEx.getMessage());
        }

        // ── Tier 3 : JavaScript click ─────────────────────────────────────────────────────────
        try
        {
            ((JavascriptExecutor) pDriver).executeScript("arguments[0].click();", iElement);
            log.info("[" + getCurrentTimestamp() + "] CLICK | JS click succeeded | " + pObjectName);
            waitForAngularReady(pDriver);
            return;
        }
        catch (Exception iJsEx)
        {
            log.warning("[" + getCurrentTimestamp() + "] CLICK | JS click failed — retrying with Actions | " + iJsEx.getMessage());
        }

        // ── Tier 4 : Actions moveToElement + click ────────────────────────────────────────────
        try
        {
            new Actions(pDriver).moveToElement(iElement).click().perform();
            log.info("[" + getCurrentTimestamp() + "] CLICK | Actions click succeeded | " + pObjectName);
            waitForAngularReady(pDriver);
        }
        catch (Exception iActionsEx)
        {
            throw new RuntimeException("CLICK failed on all strategies (parent escalation / standard / JS / Actions) for : "
                    + pObjectName + " | " + iActionsEx.getMessage(), iActionsEx);
        }
    }

    // ***************************************************************************************************************************************************************************************
    // Function Name : findClickableAncestor
    // Description   : Walks up the DOM from a given element to find the nearest <button>, <a>, or role=button ancestor.
    //                 Used by performClick to resolve Angular Material icon button targets.
    // ***************************************************************************************************************************************************************************************
    private static WebElement findClickableAncestor(WebDriver pDriver, WebElement pElement)
    {
        try
        {
            WebElement iCurrent = pElement;
            for (int iLevel = 0; iLevel < 5; iLevel++)
            {
                try
                {
                    iCurrent = (WebElement) ((JavascriptExecutor) pDriver)
                            .executeScript("return arguments[0].parentElement;", iCurrent);

                    if (iCurrent == null) { break; }

                    String iTag  = iCurrent.getTagName().toLowerCase().trim();
                    String iRole = iCurrent.getAttribute("role");

                    if ("button".equals(iTag) || "a".equals(iTag) || "button".equals(iRole))
                    {
                        log.info("[" + getCurrentTimestamp() + "] findClickableAncestor | Found <" + iTag + "> at level " + (iLevel + 1));
                        return iCurrent;
                    }
                }
                catch (Exception iLevelEx)
                {
                    break;
                }
            }
        }
        catch (Exception e)
        {
            log.warning("[" + getCurrentTimestamp() + "] findClickableAncestor error : " + e.getMessage());
        }
        return null;
    }

