# ===================================================================================================================================
# SECTION : STAFF PORTAL — Shared parameterised locators for StaffSteps.java
# ---------------------------------------------------------------------------------------------------------------------------------
# Keys ending in a {TOKEN} carry a placeholder that StaffSteps.java replaces at runtime via
# String.replace(...) before passing to iAction (same idea as the existing %s keys, but token-named).
#   {APP}   application tile name        {TAB}    top-level tab label
#   {LINK}  navbar link text             {FIELD}  logical input-field name
#   {YEAR}  scheme year                  {BTN}    button visible text
#   {DD}    multi/single dropdown name   {OPT}    dropdown option text
#   {TYPE}  map printing type            {MSG}    error message text
#   {TABLE}/{ACTION}/{ROW}  results-table action link
# Verify each XPath against the live DOM before committing — values below follow the framework's
# existing Angular Material / Keycloak conventions but the Staff screens should be spot-checked.
# ===================================================================================================================================

# ---- Login (Keycloak) ----
# Staff username field on the Keycloak login form
iStaffUsernameField                 = //input[@id='username']

# Staff password field on the Keycloak login form
iStaffPasswordField                 = //input[@id='password']

# Data Protection consent checkbox on the staff login page
iStaffDataProtectionCheckbox        = //input[@type='checkbox' and @id='dataProtection'] | //mat-checkbox[contains(.,'Data Protection')]//input[@type='checkbox']

# Login / submit button
iStaffLoginBtn                      = //*[@id='kc-login'] | //button[normalize-space()='Login']

# ---- Application entry ----
# Application tile on the Authorised Applications home screen — {APP} = tile display name
iStaffApplicationTile               = //span[normalize-space()='{APP}']/ancestor::a | //*[normalize-space()='{APP}' and (self::a or self::button)]

# ---- Tabs / navigation ----
# Top-level tab on the Staff portal — {TAB} = visible tab label
iStaffGenericTab                    = //div[@role='tab' and normalize-space()='{TAB}'] | //a[normalize-space()='{TAB}'] | //span[normalize-space()='{TAB}']/ancestor::*[self::a or self::button][1]

# Left-hand navbar link inside an opened application — {LINK} = link text
iStaffNavbarLink                    = //a[normalize-space()='{LINK}'] | //span[normalize-space()='{LINK}']/ancestor::a[1]

# Results-table action link on a given row — {TABLE} id, {ACTION} link text, {ROW} 1-based index
iStaffTableActionLink               = (//table[@id='{TABLE}']//a[normalize-space()='{ACTION}'])[{ROW}]

# ---- Search inputs ----
# Generic staff input field by logical name — {FIELD} maps to formcontrolname/id
iStaffInputField                    = //input[@formcontrolname='{FIELD}'] | //input[@id='{FIELD}']

# schemeYear dropdown trigger
iStaffSchemeYearDropdown            = //mat-select[@formcontrolname='schemeYear']

# schemeYear option in the open panel — {YEAR} = year value
iStaffSchemeYearOption              = //mat-option//span[normalize-space()='{YEAR}']

# ---- Generic buttons ----
# Any button by visible text — {BTN} = button label
iStaffGenericButton                 = //button[normalize-space()='{BTN}']

# ---- Multi-option dropdowns (parcelSelect / vectorSelect / imagerySelect etc.) ----
# Multi-select trigger by formcontrolname — {DD} = control name
iStaffMultiDropdown                 = //mat-select[@formcontrolname='{DD}']

# First selectable option in the open multi-select panel
iStaffMultiDropdownFirstOption      = (//mat-option[not(@aria-disabled='true')])[1]

# "Select all" option in the open multi-select panel
iStaffMultiDropdownSelectAll        = //mat-option//span[normalize-space()='Select All'] | //mat-option[@aria-label='Select All']

# Close the open dropdown panel (backdrop click)
iStaffMultiDropdownClosePanel       = //div[contains(@class,'cdk-overlay-backdrop')]

# ---- Single-select map generation dropdowns ----
# Single-select trigger by formcontrolname — {DD} = control name (mapTypeSelect/imagerySelect/rasterSelect)
iStaffSingleSelectDropdown          = //mat-select[@formcontrolname='{DD}']

# Single-select option in the open panel — {OPT} = option text
iStaffSingleSelectOption            = //mat-option//span[normalize-space()='{OPT}']

# ---- Map Printing specifics ----
# Map Printing type radio/segmented control — {TYPE} = "Parcel"/"Herd"
iStaffMapPrintingType               = //mat-radio-button[.//*[normalize-space()='{TYPE}']] | //label[normalize-space()='{TYPE}']

# Legend Indicator checkbox in the map generation settings panel
iStaffLegendIndicatorCheckbox       = //mat-checkbox[contains(.,'Legend')]//input[@type='checkbox'] | //input[@id='legendIndicator']

# ---- Validation ----
# Generic on-screen error message by text — {MSG} = expected error text
iStaffErrorMessage                  = //*[contains(@class,'mat-error') or contains(@class,'error') or self::mat-error][normalize-space()='{MSG}']
