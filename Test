-- ============================================================
-- Query 1 — Check what scheme codes exist
-- ============================================================
SELECT DISTINCT sch_code, sch_abbrev, sch_desc
FROM tdbs_scheme
ORDER BY sch_code;

-- ============================================================
-- Query 2 — Check NR/CISYF flag on J1994001 application
-- ============================================================
SELECT app_herd_no, app_year, app_mde_code, mde_abbrev, mde_desc
FROM vwbs_application_herd
WHERE app_herd_no = 'J1994001'
AND   app_year    = 2026;

-- ============================================================
-- Query 3 — Find scheme selection related tables
-- ============================================================
SELECT table_name
FROM all_tables
WHERE (table_name LIKE '%SCHEME%APP%'
OR     table_name LIKE '%APP%SCHEME%'
OR     table_name LIKE '%SCHEME_SEL%')
AND    table_name LIKE 'T%'
ORDER BY table_name;

-- ============================================================
-- Query 4 — All accessible TDBS and VWBS tables
-- ============================================================
SELECT table_name
FROM all_tables
WHERE table_name LIKE 'TDBS%'
OR    table_name LIKE 'VWBS%'
ORDER BY table_name;
