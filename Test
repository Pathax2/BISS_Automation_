SELECT
    a.app_herd_no,
    a.mde_abbrev,
    nvl(pkbs_payment_utils.fn_GetSchemeApplied(a.aph_app_id, 3), 'N') AS cisyf_applied,
    (SELECT COUNT(*) FROM tdsp_young_farmer_summary yfs
     JOIN vwbs_application_herd h2 ON h2.aph_cust_id = yfs.sph_sps_holding_id
     WHERE h2.app_herd_no = a.app_herd_no
     AND yfs.yfs_application_year = a.app_year) AS nrcisyf_submission_count
FROM vwbs_application_herd a
WHERE a.app_herd_no IN ('J1994001', 'A1010207')
AND a.app_year = 2026
AND a.mde_abbrev = 'I';
