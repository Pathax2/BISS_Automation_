// ===================================================================================================================================
//  PRIVATE — HERD SWAP (DB re-query + INET validation + re-login if agent changed)
// ===================================================================================================================================

// ***************************************************************************************************************************************************************************************
// Function Name : swapPrelimHerd
// Description   : Fetches next candidate herd from BISS_DATA for pCheckType at pStartOffset.
//                 Validates against BISS_INET. If valid:
//                   - Agent changed → performLogout() + performLogin() + navigateToMyClients()
//                   - Same agent    → update Hooks fields only, no re-login
//                 Tries 3 consecutive offsets per call to skip INET-invalid herds.
// Parameters    : pCheckType       — OVERCLAIM | DUAL_CLAIM | AGRI_ACTIVITY
//                 pStartOffset     — DB offset to start from
//                 pYear            — scheme year
//                 pCurrentUsername — currently logged-in agent (for change detection)
// Returns       : true if replacement found and committed to Hooks, false if exhausted
// Author        : Aniket Pathare | aniket.pathare@government.ie
// Date          : 17-04-2026
// ***************************************************************************************************************************************************************************************
private boolean swapPrelimHerd(String pCheckType, int pStartOffset,
                               String pYear, String pCurrentUsername)
{
    // Map the ALLCAPS hook key to the LVC_DESC value in BISS_DATA
    String iLvcDescTarget;
    switch (pCheckType.trim().toUpperCase())
    {
        case "OVERCLAIM":     iLvcDescTarget = "Overclaim";             break;
        case "DUAL_CLAIM":    iLvcDescTarget = "Dual claim";            break;
        case "AGRI_ACTIVITY": iLvcDescTarget = "Agricultural Activity"; break;
        default: throw new IllegalArgumentException("Unknown check type: " + pCheckType);
    }

    for (int iOff = pStartOffset; iOff < pStartOffset + 3; iOff++)
    {
        log.info("[PRELIM-SWAP] BISS_DATA query | LVC_DESC='" + iLvcDescTarget
                + "' | offset=" + iOff);

        database.DBRouter.runDB("DATA", "Preliminary checks herds",
                pYear, String.valueOf(iOff));

        List<Map<String, Object>> iRows = database.DBRouter.getRows();

        if (iRows == null || iRows.isEmpty())
        {
            log.warning("[PRELIM-SWAP] 0 rows from BISS_DATA at offset=" + iOff
                    + " — no more candidates.");
            return false;
        }

        for (Map<String, Object> iRow : iRows)
        {
            String iLvc  = Objects.toString(iRow.get("LVC_DESC"),    "").trim();
            String iHerd = Objects.toString(iRow.get("LVL_HERD_NO"), "").trim();

            if (!iLvc.equals(iLvcDescTarget) || iHerd.isEmpty()) continue;

            database.DBRouter.runDB("INET", "Get Login Id for herd", iHerd);
            String iUsername = database.DBRouter.getValue("USERNAME");

            if (iUsername == null || iUsername.isBlank())
            {
                log.info("[PRELIM-SWAP] No INET agent for " + iLvcDescTarget
                        + " herd=" + iHerd + " (offset=" + iOff + ") — skipping.");
                continue;
            }

            iUsername = iUsername.trim();
            log.info("[PRELIM-SWAP] Replacement: " + iLvcDescTarget
                    + " → herd=" + iHerd + " | username=" + iUsername);

            if (!iUsername.equalsIgnoreCase(pCurrentUsername))
            {
                log.info("[PRELIM-SWAP] Agent change: "
                        + pCurrentUsername + " → " + iUsername
                        + " | logout → login → navigate.");
                performLogout();
                performLogin(iUsername);
                navigateToMyClients();
                Hooks.RUNTIME_USERNAME = iUsername;
            }
            else
            {
                log.info("[PRELIM-SWAP] Same agent (" + iUsername + ") — no re-login.");
            }

            setPrelimHerd(pCheckType, iHerd, iUsername);
            return true;
        }
    }

    log.warning("[PRELIM-SWAP] Exhausted offsets " + pStartOffset
            + "–" + (pStartOffset + 2) + " for " + pCheckType + " — no replacement found.");
    return false;
}


