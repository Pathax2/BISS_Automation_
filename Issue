    // ---------------------------------------------------------------------------------------------------------------------------------
    // Function Name : theForceMajeureStateShouldBeReadableFromTheFollowingTabs
    // Description   : Reads the Force Majeure state via each named tab. Legacy AT-TC-02 is titled "Force Majeure
    //                 Save" but its save steps are commented out - it only navigates and reads. Reproduced as
    //                 written; TC_23 Section 2 holds the working save coverage.
    // Parameters    : pTabs (DataTable) - single column of tab names
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ---------------------------------------------------------------------------------------------------------------------------------
    @Then("the Force Majeure state should be readable from the following tabs")
    public void theForceMajeureStateShouldBeReadableFromTheFollowingTabs(DataTable pTabs)
    {
        List<String> iTabs = pTabs.asList();

        for (String iTab : iTabs)
        {
            iAction("CLICK", "XPATH", ObjReader.getLocator("iNavbarLink").replace("{LINK}", iTab), null);
        }

        iAction("VERIFYELEMENT", "XPATH", ObjReader.getLocator("iForceMajeureInput"), null);
    }

