    // ***************************************************************************************************************************************************************************************
    // Method        : fillQualificationForm
    // Description   : Shared logic for both single and per-member qualification form filling.
    //                 Reads key-value pairs from the DataTable map and fills each field.
    //                 Handles: hasQualification, dateOfCompletion, certificateAwarded,
    //                          college, customCollege, qualification, customQualification
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026
    // ***************************************************************************************************************************************************************************************
    private void fillQualificationForm(Map<String, String> pData)
    {
        // Has qualification radio — Yes / No
        String iHasQual = pData.getOrDefault("hasQualification", "Yes").trim();
        iAction("CLICK", "XPATH",
                "//mat-radio-button[contains(.,'" + iHasQual + "')]"
                        + " | //label[contains(normalize-space(),'" + iHasQual + "')]",
                null);

        if ("No".equalsIgnoreCase(iHasQual))
        {
            log.info("[TC13] hasQualification=No — skipping remaining qualification fields.");
            return;
        }

        // Date of completion
        if (pData.containsKey("dateOfCompletion"))
        {
            iAction("TEXTBOX", "XPATH",
                    ObjReader.getLocator("iNRCISYFDateOfCompletionField"),
                    pData.get("dateOfCompletion").trim());
        }

        // Certificate awarded
        if (pData.containsKey("certificateAwarded"))
        {
            String iCert = pData.get("certificateAwarded").trim();
            iAction("CLICK", "XPATH",
                    "(//mat-radio-button[contains(.,'" + iCert + "')])[last()]"
                            + " | (//label[contains(normalize-space(),'" + iCert + "')])[last()]",
                    null);
        }

        // College / institution dropdown
        if (pData.containsKey("college"))
        {
            iAction("LIST", "XPATH",
                    ObjReader.getLocator("iNRCISYFCollegeDropdown"),
                    pData.get("college").trim());
        }

        // Custom college free-text — only when "not in list" selected
        if (pData.containsKey("customCollege"))
        {
            iAction("TEXTBOX", "XPATH",
                    ObjReader.getLocator("iNRCISYFCustomCollegeField"),
                    pData.get("customCollege").trim());
        }

        // Qualification dropdown
        if (pData.containsKey("qualification"))
        {
            iAction("LIST", "XPATH",
                    ObjReader.getLocator("iNRCISYFQualificationDropdown"),
                    pData.get("qualification").trim());
        }

        // Custom qualification free-text — only when "not in list" selected
        if (pData.containsKey("customQualification"))
        {
            iAction("TEXTBOX", "XPATH",
                    ObjReader.getLocator("iNRCISYFCustomQualificationField"),
                    pData.get("customQualification").trim());
        }

        log.info("[TC13] Qualification form filled: college="
                + pData.getOrDefault("college", "N/A"));
    }


    // ***************************************************************************************************************************************************************************************
    // Method        : isVisible
    // Description   : Short-wait visibility check — returns true/false, never throws
    // Parameters    : pLocator — By locator
    //                 pSeconds — max wait in seconds
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 31-03-2026
    // ***************************************************************************************************************************************************************************************
    private boolean isVisible(By pLocator, int pSeconds)
    {
        try
        {
            new WebDriverWait(getDriver(), Duration.ofSeconds(pSeconds))
                    .until(ExpectedConditions.visibilityOfElementLocated(pLocator));
            return true;
        }
        catch (Exception e)
        {
            return false;
        }
    }
