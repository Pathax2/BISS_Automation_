Sim parcels with error

SELECT apl.app_id,
             apl.app_herd_no,
             apl.aph_herd_no,
             apl.app_year,
             apl.app_mde_code,
             apl.apl_lnu_id,
             apl.apl_sub_div_no,
             apl.apl_commonage_ind,
             CASE
                WHEN COALESCE(DECODE(sia.sma_sim_ind,'Y', NULL, sia.sma_sim_ind) , sim.sml_sim_ind, apl.apl_sim_ind) = 'Y' AND crins.cru_crp_code IS NOT NULL AND (crins.cru_sim_cereals_ind = 'N' AND crins.cru_sim_oilseeds_ind = 'N')
                   THEN 'Y'
                WHEN COALESCE(DECODE(sia.sma_sim_ind,'Y', NULL, sia.sma_sim_ind), sim.sml_sim_ind, apl.apl_sim_ind) = 'Y' AND crapp.cru_crp_code IS NOT NULL AND (crapp.cru_sim_cereals_ind = 'N' AND crapp.cru_sim_oilseeds_ind = 'N')
                   THEN 'Y'
                ELSE 'N'
             END AS sim_invalid_crop_ind
      FROM   vwbs_application_land_eh apl,
             vwbs_inspection_land ins,
             tsbs_crop_usage crapp,
             tsbs_crop_usage crins,
             vwbs_sim_area_land sim,
             tdbs_sim_area_application sia
      WHERE  apl.apl_id           = ins.apl_id (+)
      AND    apl.app_id           = ins.app_id (+)
      AND    ins.ist_abbrev (+)   = 'C' -- Completed
      AND    apl.apl_crp_code     = crapp.cru_crp_code (+)
      AND    apl.app_year         BETWEEN crapp.cru_start_year(+) AND crapp.cru_end_year(+)
      AND    ins.inl_crp_code     = crins.cru_crp_code (+)
      AND    ins.app_year         BETWEEN crins.cru_start_year(+) AND crins.cru_end_year(+)
      AND    apl.apl_deleted_ind  = 'N'
      AND    apl.apl_lnu_id       IS NOT NULL
      AND    apl.app_year         = 2023 -- adapt here
      AND    apl.mde_abbrev       = 'I' -- iNet
       AND    sim.smh_aph_id(+)    = apl.aph_id
       AND    sml_lnu_id(+)        = apl.apl_lnu_id
       AND    sml_deleted_ind(+)   = 'N'
       AND    COALESCE(sim.sml_sub_div_no(+),0) = COALESCE(apl.apl_sub_div_no,0)
      AND    sia.sma_app_id(+)    = apl.app_id
      AND    CASE
                WHEN COALESCE(DECODE(sia.sma_sim_ind,'Y', NULL, sia.sma_sim_ind) , sim.sml_sim_ind, apl.apl_sim_ind) = 'Y' AND crins.cru_crp_code IS NOT NULL AND (crins.cru_sim_cereals_ind = 'N' AND crins.cru_sim_oilseeds_ind = 'N')
                   THEN 'Y'
                WHEN COALESCE(DECODE(sia.sma_sim_ind,'Y', NULL, sia.sma_sim_ind), sim.sml_sim_ind, apl.apl_sim_ind) = 'Y' AND crapp.cru_crp_code IS NOT NULL AND (crapp.cru_sim_cereals_ind = 'N' AND crapp.cru_sim_oilseeds_ind = 'N')
                   THEN 'Y'
                ELSE 'N'
             END = 'Y' -- SIM Parcel in ERROR
