    // ***************************************************************************************************************************************************************************************
    // Function Name : verifyErrorMessage
    // Description   : Validates expected message is contained in actual message (case-insensitive)
    // ***************************************************************************************************************************************************************************************
    public static String verifyErrorMessage(String pActualErrorMessage, String pExpectedErrorMessage)
    {
        if (pActualErrorMessage == null)
        {
            throw new AssertionError("Actual error message is NULL. Expected : '" + pExpectedErrorMessage + "'");
        }
        if (pExpectedErrorMessage == null || pExpectedErrorMessage.trim().isEmpty())
        {
            throw new AssertionError("Expected error message cannot be NULL or empty.");
        }

        String iActual   = pActualErrorMessage.trim();
        String iExpected = pExpectedErrorMessage.trim();

        if (!iActual.toLowerCase().contains(iExpected.toLowerCase()))
        {
            throw new AssertionError("Error message validation FAILED"
                    + "\n  Expected (partial match) : '" + iExpected + "'"
                    + "\n  Actual                   : '" + iActual + "'");
        }

        log.info("[" + getCurrentTimestamp() + "] Error message verified | Expected: '" + iExpected + "' | Actual: '" + iActual + "'");
        return "Error message verified: '" + iExpected + "'";
    }


