# Save and Exit button — page-level navigation row (no span, mat-icon discriminator)
# DOM: plain div.non-bordered-div, text sits directly in button alongside mat-icon
iNRCISYFEduSaveExitBtn              = //div[contains(@class,'non-bordered-div')]//button[.//mat-icon[normalize-space()='save']]

# Save and Exit button — inside confirmation dialog (has span, scoped to mat-dialog-actions)
# DOM: mat-dialog-actions, span text = "Save and Exit", excludes Cancel (clearBtn class)
iNRCISYFSaveExitDialogBtn           = //mat-dialog-actions//button[.//span[normalize-space()='Save and Exit'] and not(contains(@class,'clearBtn'))]
