    // ---------------------------------------------------------------------------------------------------------------------------------
    // Function Name : theMapGenerationRequestShouldBeAccepted
    // Description   : Confirms the request was accepted - the generated maps table shows a row for it.
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ---------------------------------------------------------------------------------------------------------------------------------
    @Then("the map generation request should be accepted")
    public void theMapGenerationRequestShouldBeAccepted() throws InterruptedException
    {

        log.info("[STEP] the map generation request should be accepted");

        boolean iReadyToDownload = false;

        for (int i = 1; i <= 500; i++)
        {
            String iStatus = getDriver().findElement(By.xpath(ObjReader.getLocator("iGeneratedMapFirstRow"))).getText().trim();

            log.info("Attempt " + i + " | First row status : " + iStatus);

            if (iStatus.contains("Ready to download"))
            {
                log.info("Ready to download found on first row.");

                iReadyToDownload = true;

                iAction("VERIFYELEMENT", "XPATH", ObjReader.getLocator("iGeneratedMapFirstRow"), null);
                break;
            }

            log.info("Waiting for map generation...");
            Thread.sleep(5000);
        }

        if (!iReadyToDownload)
        {
            throw new RuntimeException("'Ready to download' was not displayed on the first row within the expected time.");
        }

    }

