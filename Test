-- Check if there's an NR/CISYF indicator on the application itself
SELECT app_herd_no,
       app_year,
       mde_abbrev,
       nvl(pkbs_payment_utils.fn_GetSchemeApplied(aph_app_id, 3), 'N') AS cisyf_applied,
       nvl(pkbs_payment_utils.fn_GetSchemeApplied(aph_app_id, 9), 'N') AS nr_applied
FROM vwbs_application_herd
WHERE app_herd_no = 'J1994001'
AND   app_year    = 2026;
