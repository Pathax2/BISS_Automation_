# AP4 — Planting of Native Trees and/or Hedgerows
iEcoAP4_FirstOptionRadio = (//biss-eco-ap4-content//td[contains(@class,'cdk-column-selectOption')]//mat-radio-button)[1]
iEcoAP4_CommitCheckbox   = //biss-eco-ap4-content//input[@type='checkbox'][ancestor::mat-checkbox]


case "AP4":
    // ── Step 1: Select the first radio option ─────────────────────────────────────
    // The native <input type="radio"> inside mat-radio-button has opacity:0 applied
    // by Angular Material CSS — Selenium's visibility check fails on it.
    // Target the mat-radio-button wrapper (which IS visible) and JS-click it
    // to bypass both the opacity issue and any overlay interception.
    iAction("WAITVISIBLE", "XPATH", ObjReader.getLocator("iEcoAP4_FirstOptionRadio"), null);
    org.openqa.selenium.WebElement iAP4Radio = getDriver()
            .findElement(By.xpath(ObjReader.getLocator("iEcoAP4_FirstOptionRadio")));
    ((org.openqa.selenium.JavascriptExecutor) getDriver())
            .executeScript("arguments[0].click();", iAP4Radio);
    log.info("AP4: Selected first radio option (Standard Trees) via JS click.");

    // ── Step 2: Tick the "I commit to planting" checkbox ─────────────────────────
    iAction("WAITVISIBLE",   "XPATH", ObjReader.getLocator("iEcoAP4_CommitCheckbox"), null);
    iAction("WAITCLICKABLE", "XPATH", ObjReader.getLocator("iEcoAP4_CommitCheckbox"), null);
    iAction("CHECKBOX",      "XPATH", ObjReader.getLocator("iEcoAP4_CommitCheckbox"), "CHECK");
    log.info("AP4: Ticked 'I commit to planting' checkbox.");

    // Note: Upload receipts skipped — not required in test environment.
    // Note: Save & Select handled by caller after this method returns.
    break;
