    // ---------------------------------------------------------------------------------------------------------------------------------
    // Function Name : theFollowingParcelActionsShouldBeAvailable
    // Description   : Exercises each parcel action named in the table and confirms it opens. Dialog actions are
    //                 dismissed and the map action returns to Land Details, leaving the screen ready for the next.
    // Parameters    : pActions (DataTable) - single column of action button labels
    // Author        : Aniket Pathare | aniket.pathare@government.ie
    // Date Created  : 15-07-2026
    // ---------------------------------------------------------------------------------------------------------------------------------
    @Then("the following parcel actions should be available")
    public void theFollowingParcelActionsShouldBeAvailable(DataTable pActions)
    {
        log.info("[STEP] the following parcel actions should be available");
        List<String> iActions = pActions.asList();

        for (String iActionName : iActions)
        {
            iAction("CLICK", "XPATH",
                    ObjReader.getLocator("iParcelActionButton").replace("{LABEL}", iActionName), null);

            switch (iActionName)
            {
                case "View Claimants":
                    iAction("CLICK", "XPATH",
                            ObjReader.getLocator("iDialogButton").replace("{LABEL}", "Cancel"), null);
                    break;

                case "Parcel History":
                    iAction("CLICK", "XPATH",
                            ObjReader.getLocator("iDialogButton").replace("{LABEL}", "Close"), null);
                    break;

                case "View Map":
                    iAction("CLICK", "XPATH", ObjReader.getLocator("iReturnToLandDetailsLink"), null);
                    break;

                default:
                    break;
            }
        }
    }

